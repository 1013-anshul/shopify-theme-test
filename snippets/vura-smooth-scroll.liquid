{% comment %}
  Momentum smooth-scroll for the desktop mouse wheel only.

  Touch is deliberately left alone: a window-level touchmove handler with
  preventDefault turns every drag into vertical page scrolling, which stops
  horizontal scrollers (the product image slider) from ever seeing a swipe.
  Phones already scroll smoothly on their own, so we let the OS do it.

  Guards so the wheel easing never fights other gestures:
   - the gallery card-stack (its own drag handler),
   - inner scrollables (cart drawer, menus, modals, code blocks),
   - form fields, and any open overlay / scroll-locked state.
  Respects prefers-reduced-motion. Self-contained; remove the render from
  theme.liquid to disable.
{% endcomment %}
<script>
  (function () {
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !('requestAnimationFrame' in window)) return;

    var docEl = document.documentElement;
    var current = window.scrollY || window.pageYOffset || 0;
    var target = current;
    var running = false;
    var EASE = 0.12;

    function maxScroll() { return Math.max(0, docEl.scrollHeight - window.innerHeight); }
    function clamp(v) { var m = maxScroll(); return v < 0 ? 0 : (v > m ? m : v); }

    function scrollLocked() {
      var b = document.body;
      return getComputedStyle(b).overflowY === 'hidden' ||
        b.classList.contains('overflow-hidden') ||
        docEl.classList.contains('overflow-hidden');
    }

    // Elements whose own scroll/gesture we must not hijack.
    var OVERLAY_SEL = 'dialog,[role="dialog"],.modal,product-media-modal,.media-modal,' +
      'cart-drawer,.cart-drawer,.drawer,.menu-drawer,.search-modal,.gradient__media-modal';
    function insideExcluded(t) {
      if (!t || t.nodeType !== 1) return false;
      if (t.closest('[data-gallery-track]')) return true;                 // gallery has its own swipe
      if (t.closest('input,textarea,select,[contenteditable]')) return true;
      if (t.closest(OVERLAY_SEL)) return true;
      var node = t;
      while (node && node !== docEl && node !== document.body) {
        if (node.nodeType === 1) {
          var oy = getComputedStyle(node).overflowY;
          if ((oy === 'auto' || oy === 'scroll') && node.scrollHeight > node.clientHeight + 1) return true;
        }
        node = node.parentNode;
      }
      return false;
    }

    function tick() {
      var diff = target - current;
      if (Math.abs(diff) < 0.5) {
        current = target;
        window.scrollTo(0, Math.round(current));
        running = false;
        return;
      }
      current += diff * EASE;
      window.scrollTo(0, current);
      requestAnimationFrame(tick);
    }
    function startTick() { if (!running) { running = true; requestAnimationFrame(tick); } }

    /* ---------- Desktop: wheel ---------- */
    function onWheel(e) {
      if (e.ctrlKey || e.defaultPrevented || scrollLocked()) return;
      var dy = e.deltaY;
      if (!dy) return;
      if (e.deltaMode === 1) dy *= 32;
      else if (e.deltaMode === 2) dy *= window.innerHeight;
      if (insideExcluded(e.target)) return;
      e.preventDefault();
      if (!running) current = window.scrollY;
      target = clamp((running ? target : current) + dy);
      startTick();
    }

    function onScroll() { if (!running) current = target = window.scrollY; }

    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', function () { target = clamp(target); });
  })();
</script>
