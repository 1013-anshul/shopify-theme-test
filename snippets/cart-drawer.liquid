{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }
  .drawer__close {
    width: 44px !important;
    height: 44px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: transparent !important;
    border: 0 none !important;
    color: #8D3B2D !important; /* Vura Terracotta */
    font-size: 32px !important; /* Large, clear cross */
    font-weight: 300 !important;
    cursor: pointer !important;
    position: absolute !important;
    top: 12px !important;
    right: 16px !important;
    z-index: 9999 !important;
    margin: 0 !important;
  }
  .drawer__close .close-text {
    line-height: 44px !important;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>

    {%- comment -%} VURA: pack dropdown + upgrade nudge + offer-unlock celebration {%- endcomment -%}
    <style>
      .vura-pack-select-wrap { position: relative; display: inline-block; }
      .vura-pack-select {
        -webkit-appearance: none; appearance: none;
        font-family: var(--font-body, Inter, sans-serif);
        font-size: 1.25rem; font-weight: 600; color: #1A2A22;
        background: #fff; border: 1.5px solid rgba(26,42,34,0.15); border-radius: 8px;
        padding: 8px 32px 8px 12px; cursor: pointer; line-height: 1.2; max-width: 100%;
      }
      .vura-pack-select:hover { border-color: #637746; }
      .vura-pack-select:focus { outline: none; border-color: #637746; box-shadow: 0 0 0 2px rgba(99,119,70,0.2); }
      .vura-pack-select__chevron { position: absolute; right: 9px; top: 50%; transform: translateY(-50%); pointer-events: none; color: #4A5750; display: flex; }
      .vura-pack-cell { vertical-align: middle; }

      .vura-nudge { position: fixed; inset: 0; z-index: 10001; display: none; align-items: center; justify-content: center; padding: 20px; background: rgba(14,33,24,0.30); -webkit-backdrop-filter: blur(3px); backdrop-filter: blur(3px); }
      .vura-nudge.show { display: flex; animation: vuraNudgeFade .22s ease; }
      @keyframes vuraNudgeFade { from { opacity: 0; } to { opacity: 1; } }
      .vura-nudge__card { position: relative; width: 100%; max-width: 400px; background: var(--vura-paper, #F8F3E7); border-radius: 16px; padding: 24px 20px 20px; box-shadow: 0 24px 60px rgba(14,33,24,0.34); text-align: center; animation: vuraNudgeUp .34s cubic-bezier(.22,.61,.36,1); }
      @keyframes vuraNudgeUp { from { transform: translateY(24px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
      .vura-nudge__dismiss { position: absolute; top: 8px; right: 12px; background: none; border: 0; font-size: 24px; line-height: 1; color: #7A857F; cursor: pointer; }
      .vura-nudge__icon { font-size: 36px; line-height: 1; }
      .vura-nudge__title { font-family: var(--font-display, Georgia, serif); font-size: 2.2rem; color: #162D24; margin: 8px 0 4px; }
      .vura-nudge__sub { font-family: var(--font-body, Inter, sans-serif); font-size: 1.35rem; color: #4A5750; margin: 0 0 18px; line-height: 1.4; }
      .vura-nudge__row { display: flex; gap: 10px; align-items: stretch; }
      .vura-nudge__select-wrap { flex: 1; }
      .vura-nudge__select-wrap .vura-pack-select { width: 100%; height: 100%; font-size: 1.35rem; }
      .vura-nudge__cta { flex-shrink: 0; background: var(--vura-saffron, #FFC03F); color: #1A2A22; border: 0; border-radius: 8px; font-family: var(--font-body, Inter, sans-serif); font-weight: 700; font-size: 1.3rem; letter-spacing: 0.02em; padding: 12px 18px; cursor: pointer; transition: transform .12s ease, filter .12s ease; }
      .vura-nudge__cta:hover { transform: translateY(-1px); filter: brightness(1.04); }

      .vura-unlock-toast { position: fixed; top: 22px; left: 50%; transform: translate(-50%, -16px); z-index: 10002; display: flex; align-items: center; gap: 8px; background: var(--vura-forest, #162D24); color: var(--vura-paper, #F8F3E7); font-family: var(--font-body, Inter, sans-serif); font-size: 1.35rem; font-weight: 600; padding: 11px 20px; border-radius: 99px; box-shadow: 0 12px 34px rgba(14,33,24,0.4); opacity: 0; pointer-events: none; transition: opacity .3s ease, transform .3s ease; }
      .vura-unlock-toast.show { opacity: 1; transform: translate(-50%, 0); }
      .vura-unlock-toast__emoji { font-size: 1.6rem; }
      .vura-unlock-toast strong { color: var(--vura-saffron, #FFC03F); }
    </style>

    <div class="vura-nudge" id="vura-upgrade-nudge" aria-hidden="true">
      <div class="vura-nudge__card" role="dialog" aria-label="Unlock the offer">
        <button class="vura-nudge__dismiss" id="vura-nudge-dismiss" type="button" aria-label="Dismiss">&times;</button>
        <div class="vura-nudge__icon">&#127873;</div>
        <div class="vura-nudge__title">Unlock the offer</div>
        <div class="vura-nudge__sub">Choose the 3-Pack — pay for 2, get 1 free.</div>
        <div class="vura-nudge__row">
          <div class="vura-pack-select-wrap vura-nudge__select-wrap">
            <select class="vura-pack-select" id="vura-nudge-select" aria-label="Choose pack"></select>
            <span class="vura-pack-select__chevron" aria-hidden="true"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
          </div>
          <button class="vura-nudge__cta" id="vura-nudge-confirm" type="button">Unlock the offer</button>
        </div>
      </div>
    </div>

    <div class="vura-unlock-toast" id="vura-unlock-toast" aria-hidden="true">
      <span class="vura-unlock-toast__emoji">&#127881;</span>
      <span>Offer unlocked! <strong>Buy 2, Get 1 Free</strong></span>
    </div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                <span class="close-text">&times;</span>
              </button>
              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>

              {%- if shop.customer_accounts_enabled and customer == null -%}
                <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                <p class="cart__login-paragraph">
                  {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                </p>
              {%- endif -%}
            </div>
          </div>
          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="drawer__header">
        <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="close-text">&times;</span>
        </button>
      </div>
      <!-- VURA Cart Drawer Announcement Slider -->
      <div class="vura-cart-announcements">
        <div class="vura-announcement-slider">
          <div class="vura-announcement-slide">3-Pack: Buy 2, Get 1 Free!</div>
          <div class="vura-announcement-slide">Get 2% Vura Coins on every Prepaid order!!</div>
          <div class="vura-announcement-slide">Earn Vura Points on every purchase!</div>
        </div>
      </div>
      <form
        action="{{ routes.cart_url }}"
        id="CartDrawer-Form"
        class="cart__contents cart-drawer__form"
        method="post"
      >
        <cart-drawer-items
          {% if cart == empty %}
            class=" is-empty"
          {% endif %}
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              {%- comment -%} Bundle savings now live in the pack-size variants; the Buy-2-Get-1 progress/unlock UI was removed. {%- endcomment -%}
              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">


                  <tbody role="rowgroup">
                    {%- assign processed_variant_ids = "" -%}
                    {%- for item in cart.items -%}
                      {%- assign var_id_string = item.variant_id | prepend: '[' | append: ']' -%}
                      {%- unless processed_variant_ids contains var_id_string -%}
                        {%- assign processed_variant_ids = processed_variant_ids | append: var_id_string -%}
                        
                        {%- assign total_qty = 0 -%}
                        {%- assign total_original_line_price = 0 -%}
                        {%- assign total_final_line_price = 0 -%}
                        {%- assign aggregated_discounts = "" -%}
                        {%- assign row_index = item.index | plus: 1 -%}
                        {%- assign paid_line_index = nil -%}
                        {%- assign free_qty = 0 -%}
                        
                        {%- for inner_item in cart.items -%}
                          {%- if inner_item.variant_id == item.variant_id -%}
                            {%- assign total_qty = total_qty | plus: inner_item.quantity -%}
                            {%- if inner_item.final_price > 0 -%}
                              {%- assign paid_line_index = inner_item.index | plus: 1 -%}
                            {%- else -%}
                              {%- assign free_qty = free_qty | plus: inner_item.quantity -%}
                            {%- endif -%}
                            {%- assign total_original_line_price = total_original_line_price | plus: inner_item.original_line_price -%}
                            {%- assign total_final_line_price = total_final_line_price | plus: inner_item.final_line_price -%}
                            
                            {%- for discount in inner_item.line_level_discount_allocations -%}
                              {%- assign d_title = discount.discount_application.title -%}
                              {%- unless aggregated_discounts contains d_title -%}
                                {%- if aggregated_discounts != "" -%}{%- assign aggregated_discounts = aggregated_discounts | append: "||" -%}{%- endif -%}
                                {%- assign aggregated_discounts = aggregated_discounts | append: d_title -%}
                              {%- endunless -%}
                            {%- endfor -%}
                          {%- endif -%}
                        {%- endfor -%}
                        {%- assign paid_line_index = paid_line_index | default: row_index -%}
                        
                        <tr
                          id="CartDrawer-Item-{{ row_index }}"
                          class="cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                          role="row"
                          data-pack="{{ item.variant.title | escape }}"
                          data-line-key="{{ item.key }}"
                          {% if item.parent_relationship.parent != null %}
                            aria-label="{{- 'products.product.nested_label' | t: title: item.product.title, parent_title: item.parent_relationship.parent.title | escape -}}"
                          {% endif %}
                        >
                          <td
                            class="cart-item__media"
                            role="cell"
                            headers="CartDrawer-ColumnProductImage"
                          >
                            {% if item.image %}
                              {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                              <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                              <img
                                class="cart-item__image"
                                src="{{ item.image | image_url: width: 300 }}"
                                alt="{{ item.image.alt | escape }}"
                                loading="lazy"
                                width="150"
                                height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                              >
                            {% endif %}
                          </td>

                          <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                            {%- if settings.show_vendor -%}
                              <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                            {%- endif -%}

                            <div class="cart-item__name-wrapper">
                              <a href="{{ item.url }}" class="cart-item__name h4 break">
                                {{- item.product.title | escape -}}
                              </a>
                              <cart-remove-button id="CartDrawer-Remove-{{ row_index }}" data-index="{{ paid_line_index }}">
                                <button type="button" class="button button--tertiary cart-remove-button" aria-label="Remove item">
                                  <svg class="icon icon-trash" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                    <line x1="10" y1="11" x2="10" y2="17"></line>
                                    <line x1="14" y1="11" x2="14" y2="17"></line>
                                  </svg>
                                </button>
                              </cart-remove-button>
                            </div>

                            {%- unless item.product.has_only_default_variant -%}
                              <div class="cart-item__pack" style="font-size:1.3rem;color:#7A857F;margin-top:2px;">{{ item.variant.title }}</div>
                            {%- endunless -%}

                            <ul
                              class="discounts list-unstyled"
                              role="list"
                              aria-label="{{ 'customer.order.discount' | t }}"
                            >
                              {%- assign discount_array = aggregated_discounts | split: "||" -%}
                              {%- for disc_title in discount_array -%}
                                {%- if disc_title != "" -%}
                                  <li class="discounts__discount">
                                    {{ disc_title }}
                                  </li>
                                {%- endif -%}
                              {%- endfor -%}
                            </ul>
                          </td>

                          <td class="cart-item__totals right" role="cell" headers="CartDrawer-ColumnTotal">
                            {%- render 'loading-spinner' -%}
                            <div class="cart-item__price-wrapper">
                              {%- if total_original_line_price != total_final_line_price -%}
                                <div class="cart-item__discounted-prices">
                                  <span class="visually-hidden">
                                    {{ 'products.product.price.regular_price' | t }}
                                  </span>
                                  <s class="cart-item__old-price price price--end">
                                    {{ total_original_line_price | money }}
                                  </s>
                                  <span class="visually-hidden">
                                    {{ 'products.product.price.sale_price' | t }}
                                  </span>
                                  <span class="price price--end">
                                    {{ total_final_line_price | money }}
                                  </span>
                                </div>
                              {%- else -%}
                                <span class="price price--end">
                                  {{ total_original_line_price | money }}
                                </span>
                              {%- endif -%}

                              {%- if item.variant.available and item.unit_price_measurement -%}
                                {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                              {%- endif -%}
                            </div>
                          </td>
                          <td class="cart-item__quantity vura-pack-cell" role="cell" headers="CartDrawer-ColumnQuantity">
                            {%- unless item.product.has_only_default_variant -%}
                              <label class="visually-hidden" for="VuraPackSelect-{{ row_index }}">Choose pack size</label>
                              <div class="vura-pack-select-wrap">
                                <select class="vura-pack-select" id="VuraPackSelect-{{ row_index }}" data-line-key="{{ item.key }}" data-current="{{ item.variant_id }}" aria-label="Choose pack size">
                                  {%- for v in item.product.variants -%}
                                    <option value="{{ v.id }}"{% if v.id == item.variant_id %} selected{% endif %}{% unless v.available %} disabled{% endunless %}>{{ v.title }} &mdash; {{ v.price | money }}{% unless v.available %} &middot; Sold out{% endunless %}</option>
                                  {%- endfor -%}
                                </select>
                                <span class="vura-pack-select__chevron" aria-hidden="true"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
                              </div>
                            {%- endunless -%}
                            <div id="CartDrawer-LineItemError-{{ row_index }}" class="cart-item__error" role="alert">
                              <small class="cart-item__error-text"></small>
                              <span class="svg-wrapper">{{ 'icon-error.svg' | inline_asset_content }}</span>
                            </div>
                          </td>
                        </tr>
                      {%- endunless -%}
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </cart-drawer-items>
        <div class="drawer__footer">
        {%- if settings.show_cart_note -%}
          <details id="Details-CartDrawer">
            <summary>
              <span class="summary__title">
                {{ 'sections.cart.note' | t }}
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </summary>
            <cart-note class="cart__note field">
              <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
              <textarea
                id="CartDrawer-Note"
                class="text-area text-area--resize-vertical field__input"
                name="note"
                placeholder="{{ 'sections.cart.note' | t }}"
              >{{ cart.note }}</textarea>
            </cart-note>
          </details>
        {%- endif -%}

        <!-- Start blocks -->
        <!-- Subtotals -->

        <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
          <div>
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                {%- for discount in cart.cart_level_discount_applications -%}
                  <li class="discounts__discount discounts__discount--end">
                    {{- 'icon-discount.svg' | inline_asset_content -}}
                    {{ discount.title | escape }}
                    (-{{ discount.total_allocated_amount | money }})
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <div class="totals" role="status">
            <h2 class="totals__total">Total</h2>
            <p class="totals__total-value">{{ cart.total_price | money }}</p>
          </div>

          <small class="tax-note caption-large rte">
            {%- if cart.duties_included and cart.taxes_included -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included == false and cart.taxes_included -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included and cart.taxes_included == false -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- endif -%}
          </small>
        </div>

        <!-- VURA Coins Points System -->
        {%- if cart != empty -%}
          {%- assign coins = cart.total_price | divided_by: 5000 | floor -%}
          {%- if coins > 0 -%}
            <div class="vura-coins-container">
              <div class="vura-coins-box" id="vura-coins-msg">
                <div class="vura-coins-title">
                  <span class="vura-coin-emoji">🪙</span> You'll earn <strong>{{ coins }} Vura Coins</strong> on this order!
                </div>
                <div class="vura-coins-subtext">
                  1 coin = ₹0.50 · Redeemable on your next purchase
                </div>
              </div>
              
              <details class="vura-coins-education">
                <summary class="vura-coins-summary">
                  <span>How do Vura Coins work?</span>
                  <span class="vura-coins-arrow">▼</span>
                </summary>
                <div class="vura-coins-details">
                  <ul>
                    <li><strong>Earn:</strong> Get 2% back in coins on every order (value calculated on subtotal).</li>
                    <li><strong>Value:</strong> 1 Vura Coin = ₹0.50. E.g., {{ coins }} coins = {{ coins | times: 50 | money }} savings.</li>
                    <li><strong>Auto-Credit:</strong> Coins are auto-credited to your account after delivery.</li>
                    <li><strong>Redeem:</strong> Redeem coins at checkout on your next purchase automatically!</li>
                  </ul>
                </div>
              </details>
            </div>
          {%- endif -%}
        {%- endif -%}

        <!-- CTAs -->

        <div class="cart__ctas" {{ block.shopify_attributes }}>
          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cart__checkout-button button"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}
              disabled
            {% endif %}
          >
            <span class="vura-checkout-text">{{ 'sections.cart.checkout' | t }}</span>
            <span class="vura-checkout-badge-spacer"></span>
            <span class="vura-checkout-payment-icons">
              <img src="https://cdn.gokwik.co/v4/images/upi-icons.svg" alt="Payment Icons" width="51" height="20" loading="lazy">
            </span>
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    if (window.__vuraCartPackUX) return;
    window.__vuraCartPackUX = true;

    var R = window.routes || {};
    var CART_URL = R.cart_url || '/cart';
    var CHANGE_URL = R.cart_change_url || '/cart/change.js';
    var ADD_URL = R.cart_add_url || '/cart/add.js';

    function drawerEl() { return document.querySelector('cart-drawer'); }
    function isOpen() { var d = drawerEl(); return !!(d && d.classList.contains('active')); }
    function lineEls() { return Array.prototype.slice.call(document.querySelectorAll('#CartDrawer-CartItems .cart-item')); }
    function packs() { return lineEls().map(function (l) { return (l.getAttribute('data-pack') || '').trim(); }); }
    function has3or6() { return packs().some(function (p) { return p === '3-Pack' || p === '6-Pack'; }); }
    function onePackLine() { return lineEls().filter(function (l) { return (l.getAttribute('data-pack') || '').trim() === '1-Pack'; })[0]; }
    function hasOnly1() { return !!onePackLine() && !has3or6(); }

    var toast, nudge, nudgeSelect;
    function els() {
      toast = document.getElementById('vura-unlock-toast');
      nudge = document.getElementById('vura-upgrade-nudge');
      nudgeSelect = document.getElementById('vura-nudge-select');
    }

    function celebrate() {
      if (typeof window.triggerConfetti === 'function') window.triggerConfetti();
      if (toast) { toast.classList.add('show'); clearTimeout(window.__vuraToastT); window.__vuraToastT = setTimeout(function () { toast.classList.remove('show'); }, 2600); }
    }
    function showNudge() {
      if (!nudge || !nudgeSelect) return;
      if (nudgeSelect.options.length === 0) {
        var lineSelect = document.querySelector('.vura-pack-select[id^="VuraPackSelect"]');
        if (lineSelect) {
          Array.prototype.forEach.call(lineSelect.options, function (o) {
            if (/3-Pack|6-Pack/.test(o.textContent) && !o.disabled) {
              var opt = document.createElement('option');
              opt.value = o.value; opt.textContent = o.textContent;
              nudgeSelect.appendChild(opt);
            }
          });
          Array.prototype.forEach.call(nudgeSelect.options, function (o) { if (/3-Pack/.test(o.textContent)) o.selected = true; });
        }
      }
      nudge.classList.add('show');
    }
    function hideNudge() { if (nudge) nudge.classList.remove('show'); }

    function evaluate() {
      els();
      var now3 = has3or6();
      if (!now3) window.__vuraCelebrated = false;
      if (now3 && isOpen() && !window.__vuraCelebrated) { celebrate(); window.__vuraCelebrated = true; }
      if (!window.__vuraNudgeDismissed && hasOnly1() && isOpen()) { showNudge(); } else { hideNudge(); }
    }

    function refreshDrawer() {
      return fetch(CART_URL + '?section_id=cart-drawer')
        .then(function (r) { return r.text(); })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var ni = doc.querySelector('#CartDrawer-CartItems'), ci = document.querySelector('#CartDrawer-CartItems');
          if (ni && ci) ci.innerHTML = ni.innerHTML;
          var nf = doc.querySelector('.cart-drawer__footer'), cf = document.querySelector('.cart-drawer__footer');
          if (nf && cf) cf.innerHTML = nf.innerHTML;
          evaluate();
        });
    }

    function swapVariant(lineKey, newId) {
      if (!lineKey || !newId) return Promise.resolve();
      return fetch(CHANGE_URL, { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ id: lineKey, quantity: 0 }) })
        .then(function () {
          return fetch(ADD_URL, { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ items: [{ id: parseInt(newId, 10), quantity: 1 }] }) });
        })
        .then(function () { return refreshDrawer(); })
        .catch(function () { refreshDrawer(); });
    }

    document.addEventListener('change', function (e) {
      var sel = e.target.closest && e.target.closest('.vura-pack-select[id^="VuraPackSelect"]');
      if (!sel) return;
      if (sel.value === sel.getAttribute('data-current')) return;
      sel.disabled = true;
      swapVariant(sel.getAttribute('data-line-key'), sel.value);
    });

    document.addEventListener('click', function (e) {
      if (e.target.closest && e.target.closest('#vura-nudge-confirm')) {
        e.preventDefault();
        els();
        var line = onePackLine();
        var newId = nudgeSelect ? nudgeSelect.value : null;
        if (line && newId) { hideNudge(); swapVariant(line.getAttribute('data-line-key'), newId); }
        return;
      }
      if (e.target.closest && (e.target.closest('#vura-nudge-dismiss') || e.target === nudge)) {
        e.preventDefault();
        window.__vuraNudgeDismissed = true;
        hideNudge();
      }
    });

    var evalTimer;
    function scheduleEval() { clearTimeout(evalTimer); evalTimer = setTimeout(evaluate, 70); }
    function dedupe(sel) { var n = document.querySelectorAll(sel); for (var i = 1; i < n.length; i++) n[i].remove(); }

    function boot() {
      // Dawn re-renders the whole #CartDrawer on add, so overlays stay as Liquid
      // singletons (no moving to body). Clear any stray duplicates defensively.
      dedupe('#vura-upgrade-nudge');
      dedupe('#vura-unlock-toast');
      els();
      window.__vuraCelebrated = has3or6(); // don't celebrate a pre-existing 3-Pack on first open
      var d = drawerEl();
      if (!d) return;
      // Open/close of the drawer.
      new MutationObserver(function () {
        els();
        if (d.classList.contains('active')) { scheduleEval(); }
        else { hideNudge(); if (toast) toast.classList.remove('show'); }
      }).observe(d, { attributes: true, attributeFilter: ['class'] });
      // Any re-render of the drawer contents (Dawn add, or our swap).
      new MutationObserver(scheduleEval).observe(d, { childList: true, subtree: true });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
</script>
</cart-drawer>
