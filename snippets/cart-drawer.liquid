{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }
  .drawer__close {
    width: 44px !important;
    height: 44px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: transparent !important;
    border: 0 none !important;
    color: #8D3B2D !important; /* Vura Terracotta */
    font-size: 32px !important; /* Large, clear cross */
    font-weight: 300 !important;
    cursor: pointer !important;
    position: absolute !important;
    top: 12px !important;
    right: 16px !important;
    z-index: 9999 !important;
    margin: 0 !important;
  }
  .drawer__close .close-text {
    line-height: 44px !important;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>

    {%- comment -%} VURA: pack dropdown + inline upgrade nudge + expanding offer-unlock celebration {%- endcomment -%}
    <style>
      .vura-pack-cell { vertical-align: middle; }

      /* Inline upgrade nudge (below the cart line) */
      .vura-inline-nudge { overflow: hidden; max-height: 0; opacity: 0; transform: translateY(-6px); transition: max-height .4s ease, opacity .35s ease, transform .35s ease, margin .35s ease; margin: 0 1.5rem; }
      .vura-inline-nudge.show { max-height: 220px; opacity: 1; transform: translateY(0); margin: 0 1.5rem 1.2rem; }
      .vura-inline-nudge__card { position: relative; display: flex; align-items: center; gap: 12px; background: linear-gradient(180deg, rgba(255,192,63,0.16), rgba(255,192,63,0.08)); border: 1.5px solid rgba(255,192,63,0.55); border-radius: 12px; padding: 13px 15px; }
      .vura-inline-nudge__icon { flex-shrink: 0; width: 32px; height: 32px; color: var(--vura-terracotta, #8D3B2D); }
      .vura-inline-nudge__text { flex: 1; min-width: 0; }
      .vura-inline-nudge__title { font-family: var(--font-body, Inter, sans-serif); font-size: 1.35rem; font-weight: 500; color: #162D24; line-height: 1.25; }
      .vura-inline-nudge__sub { font-family: var(--font-body, Inter, sans-serif); font-size: 1.15rem; color: #4A5750; line-height: 1.3; }
      .vura-inline-nudge__btn { position: relative; overflow: hidden; flex-shrink: 0; background: var(--vura-forest, #162D24); color: var(--vura-paper, #F8F3E7); border: 1px solid var(--vura-forest-deep, #0E2118); border-radius: 999px; box-shadow: 2px 2px 0 0 var(--vura-terracotta, #8D3B2D); font-family: var(--font-body, Inter, sans-serif); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; font-size: 1.15rem; padding: 10px 18px; cursor: pointer; white-space: nowrap; transition: transform .14s cubic-bezier(0.2,0.7,0.2,1), box-shadow .14s ease, background-color .14s ease; animation: vuraNudgeCta 1.8s ease-in-out infinite; }
      .vura-inline-nudge__btn::after { content: ''; position: absolute; top: 0; left: -150%; width: 60%; height: 100%; background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(248,243,231,0.5) 50%, rgba(255,255,255,0) 100%); transform: skewX(-25deg); animation: vuraNudgeShine 2.8s infinite linear; pointer-events: none; }
      .vura-inline-nudge__btn:hover { background: var(--vura-forest-hover, #234935); transform: translate(-1px, -1px); box-shadow: 3px 3px 0 0 var(--vura-terracotta, #8D3B2D); animation: none; }
      .vura-inline-nudge__btn:active { transform: translate(2px, 2px); box-shadow: 0 0 0 0 var(--vura-terracotta, #8D3B2D); background: var(--vura-forest-deep, #0E2118); animation: none; }
      .vura-inline-nudge__btn[disabled] { opacity: 0.6; cursor: default; animation: none; box-shadow: 2px 2px 0 0 var(--vura-terracotta, #8D3B2D); }
      .vura-inline-nudge__btn[disabled]::after { display: none; }
      @keyframes vuraNudgeCta { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-2px) scale(1.03); } }
      @keyframes vuraNudgeShine { 0% { left: -150%; } 60% { left: 150%; } 100% { left: 150%; } }
      @media (prefers-reduced-motion: reduce) { .vura-inline-nudge__btn { animation: none; } .vura-inline-nudge__btn::after { animation: none; opacity: 0; } }
      .vura-inline-nudge__dismiss { position: absolute; top: 3px; right: 7px; background: none; border: 0; font-size: 18px; line-height: 1; color: #9AA39D; cursor: pointer; }
      @media (max-width: 480px) { .vura-inline-nudge__card { flex-wrap: wrap; } .vura-inline-nudge__btn { width: 100%; } }

      /* Expanding offer-unlock celebration (top of cart) */
      .vura-celebrate { overflow: hidden; max-height: 0; opacity: 0; transition: max-height .5s cubic-bezier(.22,.61,.36,1), opacity .4s ease, margin .5s ease; margin: 0 1.5rem; }
      .vura-celebrate.show { max-height: 180px; opacity: 1; margin: 0.6rem 1.5rem 1.2rem; }
      .vura-celebrate__card { display: flex; align-items: center; gap: 13px; background: var(--vura-forest, #162D24); color: var(--vura-paper, #F8F3E7); border-radius: 14px; padding: 16px 18px; box-shadow: 0 12px 30px rgba(14,33,24,0.28); }
      .vura-celebrate__icon { flex-shrink: 0; width: 40px; height: 40px; color: var(--vura-saffron, #FFC03F); }
      .vura-celebrate__title { font-family: var(--font-display, Georgia, serif); font-size: 1.95rem; line-height: 1.1; }
      .vura-celebrate__sub { font-family: var(--font-body, Inter, sans-serif); font-size: 1.2rem; color: var(--vura-cream-dim, #D9D2C2); margin-top: 2px; }
      .vura-celebrate__sub strong { color: var(--vura-saffron, #FFC03F); }

      /* Mobile: larger, tap-friendly popups */
      @media (max-width: 749px) {
        .vura-inline-nudge, .vura-inline-nudge.show { margin-left: 1.2rem; margin-right: 1.2rem; }
        .vura-inline-nudge__card { gap: 12px; padding: 14px 15px; }
        .vura-inline-nudge__title { font-size: 1.55rem; }
        .vura-inline-nudge__sub { font-size: 1.3rem; }
        .vura-inline-nudge__btn { min-height: 44px; font-size: 1.4rem; padding: 11px 16px; }
        .vura-celebrate.show { margin-left: 1.2rem; margin-right: 1.2rem; }
        .vura-celebrate__card { padding: 15px 16px; gap: 12px; }
        .vura-celebrate__title { font-size: 2.1rem; }
        .vura-celebrate__sub { font-size: 1.35rem; }
      }
    </style>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                <span class="close-text">&times;</span>
              </button>
              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>

              {%- if shop.customer_accounts_enabled and customer == null -%}
                <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                <p class="cart__login-paragraph">
                  {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                </p>
              {%- endif -%}
            </div>
          </div>
          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="drawer__header">
        <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="close-text">&times;</span>
        </button>
      </div>
      <!-- VURA Cart Drawer Announcement Slider -->
      <div class="vura-cart-announcements">
        <div class="vura-announcement-slider">
          <div class="vura-announcement-slide">3-Pack: Buy 2, Get 1 Free!</div>
          <div class="vura-announcement-slide">Get 2% Vura Coins on every Prepaid order!!</div>
          <div class="vura-announcement-slide">Earn Vura Points on every purchase!</div>
        </div>
      </div>
      <form
        action="{{ routes.cart_url }}"
        id="CartDrawer-Form"
        class="cart__contents cart-drawer__form"
        method="post"
      >
        <cart-drawer-items
          {% if cart == empty %}
            class=" is-empty"
          {% endif %}
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              {%- comment -%} Bundle savings now live in the pack-size variants; the Buy-2-Get-1 progress/unlock UI was removed. {%- endcomment -%}
              <div class="drawer__cart-items-wrapper">
                {%- liquid
                  assign vura_has_one = false
                  assign vura_has_three_six = false
                  assign vura_one_variant = nil
                  for it in cart.items
                    if it.variant.title == '1-Pack'
                      assign vura_has_one = true
                      assign vura_one_variant = it.variant_id
                    endif
                    if it.variant.title == '3-Pack' or it.variant.title == '6-Pack'
                      assign vura_has_three_six = true
                    endif
                  endfor
                  assign vura_three_variant = nil
                  if cart.items.first
                    assign vura_three_variant = cart.items.first.product.variants | where: 'title', '3-Pack' | first
                  endif
                -%}
                {%- comment -%} VURA offer-unlock celebration — JS expands this on the unlock transition {%- endcomment -%}
                <div class="vura-celebrate" id="vura-celebrate" aria-hidden="true">
                  <div class="vura-celebrate__card">
                    <svg class="vura-celebrate__icon" viewBox="0 0 32 32" aria-hidden="true"><path d="M16 4c1.1 5 2.9 6.9 8 8-5.1 1.1-6.9 3-8 8-1.1-5-2.9-6.9-8-8 5.1-1.1 6.9-3 8-8z" fill="currentColor"/><path d="M25 6c.4 2 1.1 2.7 3.1 3.1-2 .4-2.7 1.1-3.1 3.1-.4-2-1.1-2.7-3.1-3.1 2-.4 2.7-1.1 3.1-3.1z" fill="currentColor" opacity="0.85"/><path d="M8 20c.35 1.6.9 2.15 2.5 2.5-1.6.35-2.15.9-2.5 2.5-.35-1.6-.9-2.15-2.5-2.5 1.6-.35 2.15-.9 2.5-2.5z" fill="currentColor" opacity="0.7"/></svg>
                    <div>
                      <div class="vura-celebrate__title">Offer unlocked!</div>
                      <div class="vura-celebrate__sub">You're getting <strong>1 bottle free</strong> &mdash; Buy 2, Get 1.</div>
                    </div>
                  </div>
                </div>
                <table class="cart-items" role="table">


                  <tbody role="rowgroup">
                    {%- assign processed_variant_ids = "" -%}
                    {%- for item in cart.items -%}
                      {%- assign var_id_string = item.variant_id | prepend: '[' | append: ']' -%}
                      {%- unless processed_variant_ids contains var_id_string -%}
                        {%- assign processed_variant_ids = processed_variant_ids | append: var_id_string -%}
                        
                        {%- assign total_qty = 0 -%}
                        {%- assign total_original_line_price = 0 -%}
                        {%- assign total_final_line_price = 0 -%}
                        {%- assign aggregated_discounts = "" -%}
                        {%- assign row_index = item.index | plus: 1 -%}
                        {%- assign paid_line_index = nil -%}
                        {%- assign free_qty = 0 -%}
                        
                        {%- for inner_item in cart.items -%}
                          {%- if inner_item.variant_id == item.variant_id -%}
                            {%- assign total_qty = total_qty | plus: inner_item.quantity -%}
                            {%- if inner_item.final_price > 0 -%}
                              {%- assign paid_line_index = inner_item.index | plus: 1 -%}
                            {%- else -%}
                              {%- assign free_qty = free_qty | plus: inner_item.quantity -%}
                            {%- endif -%}
                            {%- assign total_original_line_price = total_original_line_price | plus: inner_item.original_line_price -%}
                            {%- assign total_final_line_price = total_final_line_price | plus: inner_item.final_line_price -%}
                            
                            {%- for discount in inner_item.line_level_discount_allocations -%}
                              {%- assign d_title = discount.discount_application.title -%}
                              {%- unless aggregated_discounts contains d_title -%}
                                {%- if aggregated_discounts != "" -%}{%- assign aggregated_discounts = aggregated_discounts | append: "||" -%}{%- endif -%}
                                {%- assign aggregated_discounts = aggregated_discounts | append: d_title -%}
                              {%- endunless -%}
                            {%- endfor -%}
                          {%- endif -%}
                        {%- endfor -%}
                        {%- assign paid_line_index = paid_line_index | default: row_index -%}
                        
                        <tr
                          id="CartDrawer-Item-{{ row_index }}"
                          class="cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                          role="row"
                          data-pack="{{ item.variant.title | escape }}"
                          data-line-key="{{ item.key }}"
                          {% if item.parent_relationship.parent != null %}
                            aria-label="{{- 'products.product.nested_label' | t: title: item.product.title, parent_title: item.parent_relationship.parent.title | escape -}}"
                          {% endif %}
                        >
                          <td
                            class="cart-item__media"
                            role="cell"
                            headers="CartDrawer-ColumnProductImage"
                          >
                            {% if item.image %}
                              {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                              <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                              <img
                                class="cart-item__image"
                                src="{{ item.image | image_url: width: 300 }}"
                                alt="{{ item.image.alt | escape }}"
                                loading="lazy"
                                width="150"
                                height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                              >
                            {% endif %}
                          </td>

                          <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                            {%- if settings.show_vendor -%}
                              <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                            {%- endif -%}

                            <div class="cart-item__name-wrapper">
                              <a href="{{ item.url }}" class="cart-item__name h4 break">
                                {{- item.product.title | escape -}}
                              </a>
                              <cart-remove-button id="CartDrawer-Remove-{{ row_index }}" data-index="{{ paid_line_index }}">
                                <button type="button" class="button button--tertiary cart-remove-button" aria-label="Remove item">
                                  <svg class="icon icon-trash" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                    <line x1="10" y1="11" x2="10" y2="17"></line>
                                    <line x1="14" y1="11" x2="14" y2="17"></line>
                                  </svg>
                                </button>
                              </cart-remove-button>
                            </div>

                            {%- unless item.product.has_only_default_variant -%}
                              <div class="cart-item__pack" style="font-size:1.3rem;color:#7A857F;margin-top:2px;">{{ item.variant.title }}</div>
                            {%- endunless -%}

                            <ul
                              class="discounts list-unstyled"
                              role="list"
                              aria-label="{{ 'customer.order.discount' | t }}"
                            >
                              {%- assign discount_array = aggregated_discounts | split: "||" -%}
                              {%- for disc_title in discount_array -%}
                                {%- if disc_title != "" -%}
                                  <li class="discounts__discount">
                                    {{ disc_title }}
                                  </li>
                                {%- endif -%}
                              {%- endfor -%}
                            </ul>
                          </td>

                          <td class="cart-item__totals right" role="cell" headers="CartDrawer-ColumnTotal">
                            {%- render 'loading-spinner' -%}
                            <div class="cart-item__price-wrapper">
                              {%- if total_original_line_price != total_final_line_price -%}
                                <div class="cart-item__discounted-prices">
                                  <span class="visually-hidden">
                                    {{ 'products.product.price.regular_price' | t }}
                                  </span>
                                  <s class="cart-item__old-price price price--end">
                                    {{ total_original_line_price | money }}
                                  </s>
                                  <span class="visually-hidden">
                                    {{ 'products.product.price.sale_price' | t }}
                                  </span>
                                  <span class="price price--end">
                                    {{ total_final_line_price | money }}
                                  </span>
                                </div>
                              {%- else -%}
                                <span class="price price--end">
                                  {{ total_original_line_price | money }}
                                </span>
                              {%- endif -%}

                              {%- if item.variant.available and item.unit_price_measurement -%}
                                {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                              {%- endif -%}
                            </div>
                          </td>
                          <td class="cart-item__quantity vura-pack-cell" role="cell" headers="CartDrawer-ColumnQuantity">
                            <div id="CartDrawer-LineItemError-{{ row_index }}" class="cart-item__error" role="alert">
                              <small class="cart-item__error-text"></small>
                              <span class="svg-wrapper">{{ 'icon-error.svg' | inline_asset_content }}</span>
                            </div>
                          </td>
                        </tr>
                      {%- endunless -%}
                    {%- endfor -%}
                  </tbody>
                </table>
                {%- if vura_has_one and vura_has_three_six == false and vura_three_variant -%}
                  <div class="vura-inline-nudge" id="vura-inline-nudge" data-old="{{ vura_one_variant }}" data-new="{{ vura_three_variant.id }}" aria-hidden="true">
                    <div class="vura-inline-nudge__card">
                      <button class="vura-inline-nudge__dismiss" id="vura-nudge-dismiss" type="button" aria-label="Dismiss">&times;</button>
                      <svg class="vura-inline-nudge__icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h22v4H5z"/><path d="M7 16v11h18V16"/><path d="M16 12v15"/><path d="M16 12s-5 .6-6.6-1.2C8 9 9 6.4 11 7c2.1.6 5 5 5 5z"/><path d="M16 12s5 .6 6.6-1.2C24 9 23 6.4 21 7c-2.1.6-5 5-5 5z"/></svg>
                      <div class="vura-inline-nudge__text">
                        <div class="vura-inline-nudge__title">Your 3rd bottle's on us</div>
                        <div class="vura-inline-nudge__sub">Pay for 2, get 3 bottles.</div>
                      </div>
                      <button class="vura-inline-nudge__btn" id="vura-nudge-switch" type="button">Get 1 bottle FREE</button>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </cart-drawer-items>
        <div class="drawer__footer">
        {%- if settings.show_cart_note -%}
          <details id="Details-CartDrawer">
            <summary>
              <span class="summary__title">
                {{ 'sections.cart.note' | t }}
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </summary>
            <cart-note class="cart__note field">
              <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
              <textarea
                id="CartDrawer-Note"
                class="text-area text-area--resize-vertical field__input"
                name="note"
                placeholder="{{ 'sections.cart.note' | t }}"
              >{{ cart.note }}</textarea>
            </cart-note>
          </details>
        {%- endif -%}

        <!-- Start blocks -->
        <!-- Subtotals -->

        <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
          <div>
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                {%- for discount in cart.cart_level_discount_applications -%}
                  <li class="discounts__discount discounts__discount--end">
                    {{- 'icon-discount.svg' | inline_asset_content -}}
                    {{ discount.title | escape }}
                    (-{{ discount.total_allocated_amount | money }})
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <div class="totals" role="status">
            <h2 class="totals__total">Total</h2>
            <p class="totals__total-value">{{ cart.total_price | money }}</p>
          </div>

          <small class="tax-note caption-large rte">
            {%- if cart.duties_included and cart.taxes_included -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included == false and cart.taxes_included -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included and cart.taxes_included == false -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- endif -%}
          </small>
        </div>

        <!-- VURA Coins Points System -->
        {%- if cart != empty -%}
          {%- assign coins = cart.total_price | divided_by: 5000 | floor -%}
          {%- if coins > 0 -%}
            <div class="vura-coins-container">
              <div class="vura-coins-box" id="vura-coins-msg">
                <div class="vura-coins-title">
                  <span class="vura-coin-emoji">🪙</span> You'll earn <strong>{{ coins }} Vura Coins</strong> on this order!
                </div>
                <div class="vura-coins-subtext">
                  1 coin = ₹0.50 · Redeemable on your next purchase
                </div>
              </div>
              
              <details class="vura-coins-education">
                <summary class="vura-coins-summary">
                  <span>How do Vura Coins work?</span>
                  <span class="vura-coins-arrow">▼</span>
                </summary>
                <div class="vura-coins-details">
                  <ul>
                    <li><strong>Earn:</strong> Get 2% back in coins on every order (value calculated on subtotal).</li>
                    <li><strong>Value:</strong> 1 Vura Coin = ₹0.50. E.g., {{ coins }} coins = {{ coins | times: 50 | money }} savings.</li>
                    <li><strong>Auto-Credit:</strong> Coins are auto-credited to your account after delivery.</li>
                    <li><strong>Redeem:</strong> Redeem coins at checkout on your next purchase automatically!</li>
                  </ul>
                </div>
              </details>
            </div>
          {%- endif -%}
        {%- endif -%}

        <!-- CTAs -->

        <div class="cart__ctas" {{ block.shopify_attributes }}>
          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cart__checkout-button button"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}
              disabled
            {% endif %}
          >
            <span class="vura-checkout-text">{{ 'sections.cart.checkout' | t }}</span>
            <span class="vura-checkout-badge-spacer"></span>
            <span class="vura-checkout-payment-icons">
              <img src="https://cdn.gokwik.co/v4/images/upi-icons.svg" alt="Payment Icons" width="51" height="20" loading="lazy">
            </span>
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    if (window.__vuraCartPackUX) return;
    window.__vuraCartPackUX = true;

    var R = window.routes || {};
    var CART_URL = R.cart_url || '/cart';
    var UPDATE_URL = R.cart_update_url || '/cart/update.js';

    function drawerEl() { return document.querySelector('cart-drawer'); }
    function isOpen() { var d = drawerEl(); return !!(d && d.classList.contains('active')); }
    function el(id) { return document.getElementById(id); }
    function lineEls() { return Array.prototype.slice.call(document.querySelectorAll('#CartDrawer-CartItems .cart-item')); }
    function packs() { return lineEls().map(function (l) { return (l.getAttribute('data-pack') || '').trim(); }); }
    function has3or6() { return packs().some(function (p) { return p === '3-Pack' || p === '6-Pack'; }); }
    function hasOnly1() { var p = packs(); return p.indexOf('1-Pack') !== -1 && !has3or6(); }

    /* ---- celebration: expanding in-cart banner ---- */
    function celebrate() {
      var c = el('vura-celebrate');
      if (c) {
        c.classList.add('show');
        clearTimeout(window.__vuraCelebT);
        window.__vuraCelebT = setTimeout(function () { var cc = el('vura-celebrate'); if (cc) cc.classList.remove('show'); }, 3800);
      }
    }

    /* ---- inline nudge (revealed ~2s after the drawer opens) ---- */
    function showNudge() { var n = el('vura-inline-nudge'); if (n) n.classList.add('show'); }
    function hideNudge() { var n = el('vura-inline-nudge'); if (n) n.classList.remove('show'); }
    var nudgeTimer;
    // Arm the 2s reveal on discrete triggers (drawer open / after a swap) — NOT on every
    // evaluate, or drawer mutations would keep resetting it and it would never show.
    function armNudge() {
      clearTimeout(nudgeTimer);
      if (window.__vuraNudgeDismissed) return;
      nudgeTimer = setTimeout(function () {
        if (hasOnly1() && isOpen() && !window.__vuraNudgeDismissed) showNudge();
      }, 2000);
    }

    function evaluate() {
      var now3 = has3or6();
      if (!now3) window.__vuraCelebrated = false;
      if (now3 && isOpen() && !window.__vuraCelebrated) { celebrate(); window.__vuraCelebrated = true; }
      if (!(hasOnly1() && isOpen())) hideNudge();
    }

    /* ---- swap the line's variant (atomic; no empty-cart flash) ---- */
    function refreshDrawer() {
      return fetch(CART_URL + '?section_id=cart-drawer')
        .then(function (r) { return r.text(); })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var ni = doc.querySelector('#CartDrawer-CartItems'), ci = document.querySelector('#CartDrawer-CartItems');
          if (ni && ci) ci.innerHTML = ni.innerHTML;
          var nf = doc.querySelector('.cart-drawer__footer'), cf = document.querySelector('.cart-drawer__footer');
          if (nf && cf) cf.innerHTML = nf.innerHTML;
          evaluate();
          armNudge();
        });
    }
    function swapVariant(oldId, newId) {
      if (!oldId || !newId || String(oldId) === String(newId)) return Promise.resolve();
      var updates = {};
      updates[oldId] = 0;
      updates[newId] = 1;
      return fetch(UPDATE_URL, { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ updates: updates }) })
        .then(function () { return refreshDrawer(); })
        .catch(function () { refreshDrawer(); });
    }


    /* Nudge button (Switch to 3-Pack) + dismiss */
    document.addEventListener('click', function (e) {
      var sw = e.target && e.target.closest && e.target.closest('#vura-nudge-switch');
      if (sw) {
        e.preventDefault();
        var n = el('vura-inline-nudge');
        if (n) { sw.disabled = true; hideNudge(); swapVariant(n.getAttribute('data-old'), n.getAttribute('data-new')); }
        return;
      }
      if (e.target && e.target.closest && e.target.closest('#vura-nudge-dismiss')) {
        e.preventDefault();
        window.__vuraNudgeDismissed = true;
        clearTimeout(nudgeTimer);
        hideNudge();
      }
    });

    var evalTimer;
    function scheduleEval() { clearTimeout(evalTimer); evalTimer = setTimeout(evaluate, 70); }

    function boot() {
      window.__vuraCelebrated = has3or6(); // don't celebrate a pre-existing 3-Pack on first open
      var d = drawerEl();
      if (!d) return;
      new MutationObserver(function () {
        if (d.classList.contains('active')) { scheduleEval(); armNudge(); }
        else { clearTimeout(nudgeTimer); hideNudge(); var c = el('vura-celebrate'); if (c) c.classList.remove('show'); }
      }).observe(d, { attributes: true, attributeFilter: ['class'] });
      new MutationObserver(scheduleEval).observe(d, { childList: true, subtree: true });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
</script>
</cart-drawer>
