{%- comment -%}
  VURA Sticky Add-to-Cart Bar
  Renders a fixed bottom bar on product pages that is always visible on page load.
  Shows product image, name, price, quantity selector, and a pill-shaped Add to Cart CTA.
{%- endcomment -%}

{%- if request.page_type == 'product' -%}
  <style>
    .vura-sticky-atc__inner,
    .vura-sticky-atc__qty,
    .vura-sticky-atc__btn { transition: padding 0.25s ease, height 0.25s ease, font-size 0.25s ease; }
    .vura-sticky-atc.vura-sticky-atc--minimized .vura-sticky-atc__image,
    .vura-sticky-atc.vura-sticky-atc--minimized .vura-sticky-atc__info { display: none !important; }
    .vura-sticky-atc.vura-sticky-atc--minimized .vura-sticky-atc__inner { padding: 8px 16px !important; justify-content: center !important; gap: 12px !important; }
    .vura-sticky-atc.vura-sticky-atc--minimized .vura-sticky-atc__qty { height: 34px !important; }
    .vura-sticky-atc.vura-sticky-atc--minimized .vura-sticky-atc__btn { height: 34px !important; padding: 0 20px !important; font-size: 11px !important; flex: 1 !important; }
  </style>
  <div class="vura-sticky-atc is-visible" id="VuraStickyAtc">
    <div class="vura-sticky-atc__inner">
      <div class="vura-sticky-atc__left">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 120, height: 120, crop: 'center' }}" alt="{{ product.title | escape }}" class="vura-sticky-atc__image" width="60" height="60" loading="lazy">
        {%- endif -%}
        <div class="vura-sticky-atc__info">
          <div class="vura-sticky-atc__title">{{ product.title }}</div>
          <div class="vura-sticky-atc__price">
            {{ product.selected_or_first_available_variant.price | money }}
            {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
              <s style="opacity:0.5; margin-left:4px;">{{ product.selected_or_first_available_variant.compare_at_price | money }}</s>
            {%- endif -%}
          </div>
        </div>
      </div>
      
      <div class="vura-sticky-atc__actions">
        <div class="vura-sticky-atc__qty">
          <button type="button" class="vura-sticky-qty-btn minus" aria-label="Decrease quantity">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <input type="number" id="StickyQtyInput" value="3" min="1" readonly aria-label="Quantity">
          <button type="button" class="vura-sticky-qty-btn plus" aria-label="Increase quantity">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
        </div>
        
        <button
          type="button"
          class="vura-sticky-atc__btn btn-press"
          id="VuraStickyAtcBtn"
          {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
        >
          <span>
            {%- if product.selected_or_first_available_variant.available -%}
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </span>
        </button>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var bar = document.getElementById('VuraStickyAtc');
      var btn = document.getElementById('VuraStickyAtcBtn');
      if (!bar || !btn) return;

      // Ensure the bar is always visible by default
      bar.classList.add('is-visible');

      // Shrink (hide image) on scroll down, restore to full size on scroll up.
      // Self-contained here so it works regardless of global.js execution.
      var lastScrollY = window.pageYOffset || document.documentElement.scrollTop || 0;
      window.addEventListener('scroll', function() {
        var y = window.pageYOffset || document.documentElement.scrollTop || 0;
        if (y > lastScrollY && y > 150) {
          bar.classList.add('vura-sticky-atc--minimized');
        } else if (y < lastScrollY) {
          bar.classList.remove('vura-sticky-atc--minimized');
        }
        lastScrollY = y;
      }, { passive: true });

      // Click handler: find and click the real Add to Cart button
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var realBtn = document.querySelector('.product-form__submit');
        if (realBtn && !realBtn.disabled) {
          realBtn.click();

          // Brief visual feedback
          btn.style.opacity = '0.7';
          btn.querySelector('span').textContent = 'Adding...';
          setTimeout(function() {
            btn.style.opacity = '1';
            btn.querySelector('span').textContent = 'Add to Cart';
          }, 1200);
        }
      });

      // Quantity Selector Logic & Syncing
      var qtyInput = document.getElementById('StickyQtyInput');
      var minusBtn = bar.querySelector('.vura-sticky-qty-btn.minus');
      var plusBtn = bar.querySelector('.vura-sticky-qty-btn.plus');

      function getMainQtyInput() {
        return document.querySelector('.product-form__quantity input[name="quantity"]') || document.querySelector('input[name="quantity"]');
      }

      function syncQuantity(newVal) {
        if (newVal < 1) newVal = 1;
        qtyInput.value = newVal;

        var mainQty = getMainQtyInput();
        if (mainQty) {
          mainQty.value = newVal;
          // Trigger change event to fire any theme listeners
          mainQty.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // Also update selected card in the bundle picker if newVal is 1, 3, or 6
        var bundlePicker = document.querySelector('.vura-bundle-picker');
        if (bundlePicker) {
          var targetCard = bundlePicker.querySelector('.vura-bundle-card[data-qty="' + newVal + '"]');
          if (targetCard) {
            // Click the card to update selection
            targetCard.click();
          }
        }
      }

      if (minusBtn && plusBtn && qtyInput) {
        minusBtn.addEventListener('click', function() {
          var val = parseInt(qtyInput.value) || 1;
          syncQuantity(val - 1);
        });
        plusBtn.addEventListener('click', function() {
          var val = parseInt(qtyInput.value) || 1;
          syncQuantity(val + 1);
        });
      }

      // Sync from bundle picker to sticky quantity input
      document.addEventListener('click', function(e) {
        var card = e.target.closest('.vura-bundle-card');
        if (card) {
          var qty = card.getAttribute('data-qty');
          if (qty && qtyInput) {
            qtyInput.value = qty;
          }
        }
      });

      // Initial sync from main quantity input on load
      setTimeout(function() {
        var mainQty = getMainQtyInput();
        if (mainQty && qtyInput) {
          qtyInput.value = mainQty.value;
        }
      }, 500);
    })();
  </script>
{%- endif -%}
