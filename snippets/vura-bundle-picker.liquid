{% comment %}
  Renders selectable pack-size cards that drive Dawn's native <variant-selects>.
  Each card maps to a real product variant (1-Pack / 3-Pack / 6-Pack), so the
  correct variant + SKU is what gets added to cart. The native picker is kept in
  the DOM (its engine updates price/availability/[name=id]) but hidden visually.

  Accepts:
  - product: {Object} Product Liquid object

  Usage:
  {% render 'vura-bundle-picker', product: product %}
{% endcomment %}

{%- assign unit_price = product.variants.first.price -%}

<div class="vura-bundle-picker" data-unit-price="{{ unit_price }}">
  {%- for variant in product.variants -%}
    {%- liquid
      assign count = variant.title | split: '-' | first | times: 1
      if count < 1
        assign count = 1
      endif
      assign was = unit_price | times: count
      assign savings = was | minus: variant.price

      case variant.title
        when '1-Pack'
          assign card_label = 'TRY IT'
        when '3-Pack'
          assign card_label = 'BUY 2 GET 1'
        when '6-Pack'
          assign card_label = 'FAMILY PACK'
        else
          assign card_label = variant.title
      endcase

      assign is_recommended = false
      if variant.title == '3-Pack'
        assign is_recommended = true
      endif
    -%}
    <label
      class="vura-bundle-card{% if is_recommended %} vura-bundle-card--selected vura-bundle-card--featured-gradient{% endif %}{% unless variant.available %} vura-bundle-card--soldout{% endunless %}"
      data-variant-id="{{ variant.id }}"
      data-variant-value="{{ variant.title | escape }}"
    >
      <input
        type="radio"
        name="vura-bundle"
        value="{{ variant.id }}"
        class="vura-bundle-radio visually-hidden"
        {% if is_recommended %}checked{% endif %}
      >
      {%- if is_recommended -%}<span class="vura-bundle-card__badge">RECOMMENDED</span>{%- endif -%}
      <div class="vura-bundle-card__inner">
        <div class="vura-bundle-card__header">
          <span class="vura-bundle-card__label">{{ card_label }}</span>
        </div>
        <div class="vura-bundle-card__body">
          <span class="vura-bundle-card__qty">{{ variant.title }}</span>
          <span class="vura-bundle-card__price">{{ variant.price | money }}</span>
          {%- if savings > 0 and variant.available -%}
            <span class="vura-bundle-card__was"><s>{{ was | money }}</s></span>
            <span class="vura-bundle-card__savings">Save {{ savings | money }}</span>
          {%- endif -%}
          {%- unless variant.available -%}
            <span class="vura-bundle-card__soldout">Sold out</span>
          {%- endunless -%}
        </div>
      </div>
    </label>
  {%- endfor -%}
</div>

<style>
  /* The native Pack Size picker still powers price/availability — keep it in the
     DOM but hidden; these cards are the visible selector. */
  variant-selects {
    display: none !important;
  }
  .vura-bundle-picker {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin: 1.5rem 0;
  }
  @media screen and (max-width: 749px) {
    .vura-bundle-picker {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
  .vura-bundle-card {
    position: relative;
    cursor: pointer;
    border: 1.5px solid rgba(26,42,34,0.12);
    border-radius: 8px;
    background: #fff;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
    overflow: visible;
  }
  .vura-bundle-card:hover {
    border-color: rgba(99,119,70,0.4);
  }
  @keyframes vuraCardGlow {
    0%, 100% {
      box-shadow: 0 0 0 1px #637746, 0 0 0 0 rgba(99, 119, 70, 0);
    }
    50% {
      box-shadow: 0 0 0 1.5px #637746, 0 0 8px 3px rgba(99, 119, 70, 0.3);
    }
  }
  .vura-bundle-card--selected {
    border-color: #637746;
    background: rgba(99,119,70,0.03);
    animation: vuraCardGlow 2.5s infinite ease-in-out;
  }
  @keyframes vuraBadgeGlare {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
  .vura-bundle-card__badge {
    position: absolute;
    top: -9px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(120deg, #637746 0%, #637746 40%, #a2b884 50%, #637746 60%, #637746 100%);
    background-size: 200% 100%;
    animation: vuraBadgeGlare 3s infinite linear;
    color: #fff;
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 12px;
    border-radius: 99px;
    white-space: nowrap;
    line-height: 1.4;
    box-shadow: 0 2px 8px rgba(99, 119, 70, 0.35);
  }
  .vura-bundle-card__inner {
    padding: 18px 14px 14px;
    text-align: center;
  }
  .vura-bundle-card__header {
    margin-bottom: 6px;
  }
  .vura-bundle-card__label {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4A5750;
  }
  .vura-bundle-card__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .vura-bundle-card__qty {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 16px;
    font-weight: 700;
    color: #1A2A22;
    line-height: 1.3;
  }
  .vura-bundle-card__price {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 15px;
    font-weight: 600;
    color: #1A2A22;
  }
  .vura-bundle-card__was {
    font-size: 12px;
    color: #7A857F;
  }
  .vura-bundle-card__was s {
    text-decoration: line-through;
  }
  .vura-bundle-card__savings {
    display: inline-block;
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #3D4B22;
    background: rgba(99,119,70,0.12);
    padding: 2px 8px;
    border-radius: 99px;
    margin-top: 4px;
  }
  .vura-bundle-card__soldout {
    display: inline-block;
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #9A5B4E;
    margin-top: 4px;
  }
  .vura-bundle-card--soldout {
    cursor: not-allowed;
    opacity: 0.5;
  }
  .vura-bundle-card--soldout:hover {
    border-color: rgba(26,42,34,0.12);
  }

  /* Mobile: horizontal layout inside cards */
  @media screen and (max-width: 749px) {
    .vura-bundle-card__inner {
      display: flex;
      align-items: center;
      gap: 14px;
      text-align: left;
      padding: 18px 18px;
      min-height: 64px;
    }
    .vura-bundle-card__header {
      margin-bottom: 0;
      min-width: 84px;
    }
    .vura-bundle-card__label {
      font-size: 11px;
    }
    .vura-bundle-card__body {
      flex-direction: row;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 4px 10px;
    }
    .vura-bundle-card__qty {
      font-size: 18px;
    }
    .vura-bundle-card__price {
      font-size: 16px;
    }
    .vura-bundle-card__badge {
      left: auto;
      right: 14px;
      transform: none;
      top: -8px;
      font-size: 9px;
      padding: 3px 11px;
    }
  }

  .vura-bundle-card--featured-gradient.vura-bundle-card--selected {
    border-color: #637746 !important;
    animation: vuraBreathingGradient 3.5s infinite ease-in-out !important;
  }
  @keyframes vuraBreathingGradient {
    0%, 100% {
      background-position: 0% 50%;
      box-shadow: 0 0 0 1px #637746, 0 0 4px rgba(99, 119, 70, 0.15);
    }
    50% {
      background-position: 100% 50%;
      box-shadow: 0 0 0 1.5px #637746, 0 0 12px 3px rgba(99, 119, 70, 0.35);
    }
  }
  /* Enforce clean standard borders on unselected cards to clear highlight */
  .vura-bundle-card:not(.vura-bundle-card--selected) {
    border: 1.5px solid rgba(26,42,34,0.12) !important;
    box-shadow: none !important;
  }
</style>

<script>
  (function() {
    const picker = document.querySelector('.vura-bundle-picker');
    if (!picker) return;

    const cards = picker.querySelectorAll('.vura-bundle-card');

    // The native Dawn variant picker (drives price / [name=id] / availability).
    function getVariantSelects() {
      return document.querySelector('variant-selects');
    }

    // Force a quantity of 1 — pack size is now the variant, not the quantity.
    function setQuantityOne() {
      const qtyInput =
        document.querySelector('.product-form__quantity input[name="quantity"]') ||
        document.querySelector('input[name="quantity"]');
      if (qtyInput) qtyInput.value = 1;
      const stickyQty = document.getElementById('StickyQtyInput');
      if (stickyQty) stickyQty.value = 1;
    }

    // Select a variant by its option value ("1-Pack" / "3-Pack" / "6-Pack") by
    // checking the matching native radio and firing change so Dawn updates.
    function selectVariant(value) {
      const vs = getVariantSelects();
      if (!vs) return;
      const inputs = vs.querySelectorAll('input[type="radio"], option');
      for (let i = 0; i < inputs.length; i++) {
        if (inputs[i].value === value) {
          const el = inputs[i];
          if (el.tagName === 'OPTION') {
            const select = el.closest('select');
            if (select) {
              select.value = value;
              select.dispatchEvent(new Event('change', { bubbles: true }));
            }
          } else if (!el.checked) {
            el.checked = true;
            el.dispatchEvent(new Event('change', { bubbles: true }));
          }
          break;
        }
      }
    }

    function selectCard(card) {
      if (card.classList.contains('vura-bundle-card--soldout')) return;
      cards.forEach(c => c.classList.remove('vura-bundle-card--selected'));
      card.classList.add('vura-bundle-card--selected');
      const radio = card.querySelector('.vura-bundle-radio');
      if (radio) radio.checked = true;
      selectVariant(card.dataset.variantValue);
      setQuantityOne();
    }

    cards.forEach(card => {
      card.addEventListener('click', function () { selectCard(this); });
    });

    // Apply the default selection (3-Pack) once Dawn's variant engine is ready.
    const defaultSelected = picker.querySelector('.vura-bundle-card--selected');
    if (defaultSelected) {
      setTimeout(function () { selectCard(defaultSelected); }, 300);
    }
  })();
</script>
