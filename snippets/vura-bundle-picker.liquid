{% comment %}
  Renders selectable bundle purchase cards replacing the standard quantity picker.
  Accepts:
  - product: {Object} Product Liquid object

  Usage:
  {% render 'vura-bundle-picker', product: product %}
{% endcomment %}

{%- assign unit_price = product.selected_or_first_available_variant.price -%}
{%- assign unit_price_money = unit_price | money -%}
{%- assign two_pack_price = unit_price | times: 2 -%}
{%- assign two_pack_money = two_pack_price | money -%}
{%- assign three_pack_total = unit_price | times: 3 -%}
{%- assign three_pack_savings = unit_price -%}
{%- assign three_pack_savings_money = three_pack_savings | money -%}
{%- assign six_pack_price = unit_price | times: 5 -%}
{%- assign six_pack_money = six_pack_price | money -%}
{%- assign six_pack_savings = unit_price -%}
{%- assign six_pack_savings_money = six_pack_savings | money -%}
{%- assign six_pack_total = unit_price | times: 6 -%}

<div class="vura-bundle-picker" data-unit-price="{{ unit_price }}">
  <!-- 1 Pack -->
  <label class="vura-bundle-card" data-qty="1">
    <input type="radio" name="vura-bundle" value="1" class="vura-bundle-radio visually-hidden">
    <div class="vura-bundle-card__inner">
      <div class="vura-bundle-card__header">
        <span class="vura-bundle-card__label">TRY IT</span>
      </div>
      <div class="vura-bundle-card__body">
        <span class="vura-bundle-card__qty">1 Pack</span>
        <span class="vura-bundle-card__price">{{ unit_price_money }}</span>
      </div>
    </div>
  </label>

  <!-- 3 Pack (Best Value — Buy 2 Get 1) -->
  <label class="vura-bundle-card vura-bundle-card--selected vura-bundle-card--featured-gradient" data-qty="3">
    <input type="radio" name="vura-bundle" value="3" checked class="vura-bundle-radio visually-hidden">
    <span class="vura-bundle-card__badge">RECOMMENDED</span>
    <div class="vura-bundle-card__inner">
      <div class="vura-bundle-card__header">
        <span class="vura-bundle-card__label">BUY 2 GET 1</span>
      </div>
      <div class="vura-bundle-card__body">
        <span class="vura-bundle-card__qty">3 Pack</span>
        <span class="vura-bundle-card__price">{{ two_pack_money }}</span>
        <span class="vura-bundle-card__was">
          <s>{{ three_pack_total | money }}</s>
        </span>
        <span class="vura-bundle-card__savings">Save {{ three_pack_savings_money }}</span>
      </div>
    </div>
  </label>

  <!-- 6 Pack (Family) -->
  <label class="vura-bundle-card" data-qty="6">
    <input type="radio" name="vura-bundle" value="6" class="vura-bundle-radio visually-hidden">
    <div class="vura-bundle-card__inner">
      <div class="vura-bundle-card__header">
        <span class="vura-bundle-card__label">FAMILY PACK</span>
      </div>
      <div class="vura-bundle-card__body">
        <span class="vura-bundle-card__qty">6 Pack</span>
        <span class="vura-bundle-card__price">{{ six_pack_money }}</span>
        <span class="vura-bundle-card__was">
          <s>{{ six_pack_total | money }}</s>
        </span>
        <span class="vura-bundle-card__savings">Save {{ six_pack_savings_money }}+</span>
      </div>
    </div>
  </label>
</div>

<style>
  .vura-bundle-picker {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin: 1.5rem 0;
  }
  @media screen and (max-width: 749px) {
    .vura-bundle-picker {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
  .vura-bundle-card {
    position: relative;
    cursor: pointer;
    border: 1.5px solid rgba(26,42,34,0.12);
    border-radius: 8px;
    background: #fff;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
    overflow: visible;
  }
  .vura-bundle-card:hover {
    border-color: rgba(99,119,70,0.4);
  }
  @keyframes vuraCardGlow {
    0%, 100% {
      box-shadow: 0 0 0 1px #637746, 0 0 0 0 rgba(99, 119, 70, 0);
    }
    50% {
      box-shadow: 0 0 0 1.5px #637746, 0 0 8px 3px rgba(99, 119, 70, 0.3);
    }
  }
  .vura-bundle-card--selected {
    border-color: #637746;
    background: rgba(99,119,70,0.03);
    animation: vuraCardGlow 2.5s infinite ease-in-out;
  }
  @keyframes vuraBadgeGlare {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
  .vura-bundle-card__badge {
    position: absolute;
    top: -9px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(120deg, #637746 0%, #637746 40%, #a2b884 50%, #637746 60%, #637746 100%);
    background-size: 200% 100%;
    animation: vuraBadgeGlare 3s infinite linear;
    color: #fff;
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 12px;
    border-radius: 99px;
    white-space: nowrap;
    line-height: 1.4;
    box-shadow: 0 2px 8px rgba(99, 119, 70, 0.35);
  }
  .vura-bundle-card__inner {
    padding: 18px 14px 14px;
    text-align: center;
  }
  .vura-bundle-card__header {
    margin-bottom: 6px;
  }
  .vura-bundle-card__label {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4A5750;
  }
  .vura-bundle-card__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .vura-bundle-card__qty {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 16px;
    font-weight: 700;
    color: #1A2A22;
    line-height: 1.3;
  }
  .vura-bundle-card__price {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 15px;
    font-weight: 600;
    color: #1A2A22;
  }
  .vura-bundle-card__was {
    font-size: 12px;
    color: #7A857F;
  }
  .vura-bundle-card__was s {
    text-decoration: line-through;
  }
  .vura-bundle-card__savings {
    display: inline-block;
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #3D4B22;
    background: rgba(99,119,70,0.12);
    padding: 2px 8px;
    border-radius: 99px;
    margin-top: 4px;
  }

  /* Mobile: horizontal layout inside cards */
  @media screen and (max-width: 749px) {
    .vura-bundle-card__inner {
      display: flex;
      align-items: center;
      gap: 16px;
      text-align: left;
      padding: 16px 18px;
    }
    .vura-bundle-card__header {
      margin-bottom: 0;
      min-width: 80px;
    }
    .vura-bundle-card__body {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }
    .vura-bundle-card__badge {
      left: auto;
      right: 15px;
      transform: none;
      top: -9px;
    }
  }

  /* Breathing green gradient for featured Buy 2 Get 1 card */
  .vura-bundle-card--featured-gradient {
    background: linear-gradient(135deg, rgba(99, 119, 70, 0.04) 0%, rgba(99, 119, 70, 0.12) 50%, rgba(99, 119, 70, 0.04) 100%) !important;
    background-size: 200% 200% !important;
  }
  .vura-bundle-card--featured-gradient.vura-bundle-card--selected {
    border-color: #637746 !important;
    animation: vuraBreathingGradient 3.5s infinite ease-in-out !important;
  }
  @keyframes vuraBreathingGradient {
    0%, 100% {
      background-position: 0% 50%;
      box-shadow: 0 0 0 1px #637746, 0 0 4px rgba(99, 119, 70, 0.15);
    }
    50% {
      background-position: 100% 50%;
      box-shadow: 0 0 0 1.5px #637746, 0 0 12px 3px rgba(99, 119, 70, 0.35);
    }
  }
  /* Enforce clean standard borders on unselected cards to clear highlight */
  .vura-bundle-card:not(.vura-bundle-card--selected) {
    border: 1.5px solid rgba(26,42,34,0.12) !important;
    box-shadow: none !important;
  }
</style>

<script>
  (function() {
    const picker = document.querySelector('.vura-bundle-picker');
    if (!picker) return;

    const cards = picker.querySelectorAll('.vura-bundle-card');
    const radios = picker.querySelectorAll('.vura-bundle-radio');

    // Find the quantity input in the product form
    function getQuantityInput() {
      const parent = picker.closest('.product-form__quantity') || document.querySelector('.product-form__quantity');
      if (parent) {
        return parent.querySelector('input[name="quantity"]');
      }
      return document.querySelector('input[name="quantity"]');
    }

    // Update the submit button text
    function updateCTAText(qty) {
      const btn = document.querySelector('.product-form__submit span');
      if (!btn) return;
      if (qty == 3) {
        btn.textContent = 'Add 3 to Cart — You Pay for 2';
      } else if (qty == 6) {
        btn.textContent = 'Add 6 to Cart — Best Price';
      } else {
        btn.textContent = 'Add to Cart';
      }
    }

    function selectCard(selectedCard) {
      cards.forEach(c => c.classList.remove('vura-bundle-card--selected'));
      selectedCard.classList.add('vura-bundle-card--selected');
      const qty = selectedCard.dataset.qty;
      const qtyInput = getQuantityInput();
      if (qtyInput) qtyInput.value = qty;
      updateCTAText(qty);
    }

    cards.forEach(card => {
      card.addEventListener('click', function() {
        selectCard(this);
        this.querySelector('.vura-bundle-radio').checked = true;
      });
    });

    // Initialize with default selection (3 pack)
    const defaultSelected = picker.querySelector('.vura-bundle-card--selected');
    if (defaultSelected) {
      const qty = defaultSelected.dataset.qty;
      // Ensure quantity input exists; if not, create one
      setTimeout(function() {
        const qtyInput = getQuantityInput();
        if (qtyInput) {
          qtyInput.value = qty;
        }
        updateCTAText(qty);
      }, 300);
    }
  })();
</script>
