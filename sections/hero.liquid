<section class="hero-section">

  <!-- Background Video Loop -->
  {%- if section.settings.show_video_bg and section.settings.video_url != blank -%}
    <video autoplay loop muted playsinline class="hero-video-bg">
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- endif -%}

  <!-- Botanical florals (decorative, aria-hidden, with breeze-drift animations) -->
  <img src="{{ 'flower-marigold.png' | asset_url }}" 
       alt="" 
       class="hero-floral-right vura-drift" 
       style="--vura-drift-base-rotate: 6deg;"
       aria-hidden="true">
  <img src="{{ 'flower-bouquet.png' | asset_url }}" 
       alt="" 
       class="hero-floral-left vura-drift" 
       style="--vura-drift-base-rotate: -8deg;"
       aria-hidden="true">

  <!-- Mineral Archive Seal with rotation hover -->
  <img src="{{ 'seal-mineral-archive.png' | asset_url }}" 
       alt="Mineral Archive Registry" 
       class="hero-seal vura-spin-hover" 
       aria-hidden="true">

  <div class="container">
    <div class="hero-split-grid">
      <!-- Left Column: Copy & Actions -->
      <div class="hero-split-text">
        {%- if section.settings.eyebrow != blank -%}
          <div class="eyebrow" style="margin-bottom: var(--s-3);">{{ section.settings.eyebrow | escape }}</div>
        {%- endif -%}

        <h1 class="hero-title">{{ section.settings.title | default: shop.name | escape }}</h1>

        {%- if section.settings.devanagari != blank -%}
          <div class="hero-devanagari dev" lang="hi">{{ section.settings.devanagari | escape }}</div>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="hero-lede">{{ section.settings.text | escape }}</p>
        {%- endif -%}

        <div class="hero-cta">
          {%- if section.settings.btn_label != blank -%}
            <a href="{{ section.settings.btn_link | default: '#FeaturedProduct' }}" 
               class="button button-primary">
              {{ section.settings.btn_label | escape }}
            </a>
          {%- endif -%}
          {%- if section.settings.ghost_btn_label != blank -%}
            <a href="{{ section.settings.ghost_btn_link | default: '#FeaturedProduct' }}" 
               class="button button-ghost">
              {{ section.settings.ghost_btn_label | escape }} &rarr;
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Right Column: Premium Floating Product Visual (Vura Can Video) -->
      <div class="hero-split-visual">
        <div class="can-stage" aria-label="Rotate to view the Vura can">
          <div class="can-float">
            <div class="can-wobble">
              <video
                class="can-video"
                src="{{ 'Vura_can_rotating_360_degrees_202605251302.mp4' | asset_url }}#t=0.1"
                preload="auto"
                muted
                playsinline
                disablepictureinpicture
                aria-hidden="true">
              </video>
            </div>
          </div>
          <div class="can-hint" data-hint>Drag to rotate</div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .can-stage {
      position: relative;
      width: min(520px, 80vw);
      aspect-ratio: 1 / 1;
      margin-inline: auto;
      touch-action: pan-y;        /* let vertical scroll work; we own horizontal */
      cursor: grab;
      user-select: none;
      -webkit-user-select: none;
      z-index: 5;
    }
    .can-stage:active,
    .can-stage.dragging { cursor: grabbing; }

    .can-float {
      width: 100%; height: 100%;
      animation: can-bob 3.2s ease-in-out infinite;
      will-change: transform;
    }
    .can-wobble {
      width: 100%; height: 100%;
      animation: can-wobble 5.7s ease-in-out infinite;
      transform-origin: 50% 60%;   /* tilt pivot near base of can */
      will-change: transform;
    }
    .can-video {
      width: 100%; height: 100%;
      object-fit: contain;
      display: block;
      background: var(--vura-paper);
      pointer-events: none;        /* drag handled by parent */
      border-radius: 18px;
    }

    @keyframes can-bob {
      0%, 100% { transform: translateY(-6px); }
      50%      { transform: translateY( 6px); }
    }
    @keyframes can-wobble {
      0%, 100% { transform: rotate(-1.6deg); }
      50%      { transform: rotate( 1.6deg); }
    }

    .can-hint {
      position: absolute;
      bottom: -28px; left: 50%;
      translate: -50% 0;
      font-family: var(--font-body);
      font-size: 11px;
      letter-spacing: var(--track-loose);
      text-transform: uppercase;
      color: var(--vura-cream-dim);
      opacity: 1;
      transition: opacity 600ms var(--ease-out);
      pointer-events: none;
    }
    .can-stage.touched .can-hint { opacity: 0; }

    /* Reduced motion: kill float + wobble, but allow user drag. */
    @media (prefers-reduced-motion: reduce) {
      .can-float, .can-wobble { animation: none; }
    }
  </style>

  <script>
    (() => {
      const stage = document.querySelector('.can-stage');
      const video = stage?.querySelector('.can-video');
      if (!stage || !video) return;

      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

      // -------- Tunables --------
      const PX_PER_FULL_ROTATION = 360;   // horizontal pixels of drag = one full spin
      const IDLE_RESUME_MS       = 2400;  // wait after release before autoplay resumes
      const AUTOSPIN_SECONDS_PER_TURN = 8; // ambient spin speed
      // --------------------------

      let duration = 0;
      let isDragging = false;
      let dragStartX = 0;
      let dragStartTime = 0;
      let idleTimer = null;
      let rafAuto = null;

      video.addEventListener('loadedmetadata', () => {
        duration = video.duration || 0;
        if (!reduce) startAutoSpin();
      });

      // Fallback if metadata is already loaded/cached
      if (video.readyState >= 1) {
        duration = video.duration || 0;
        if (!reduce) startAutoSpin();
      }

      function startAutoSpin() {
        cancelAutoSpin();
        let last = performance.now();
        const tick = (now) => {
          const dt = (now - last) / 1000;
          last = now;
          if (duration) {
            const advance = (duration / AUTOSPIN_SECONDS_PER_TURN) * dt;
            video.currentTime = (video.currentTime + advance) % duration;
          }
          rafAuto = requestAnimationFrame(tick);
        };
        rafAuto = requestAnimationFrame(tick);
      }
      function cancelAutoSpin() {
        if (rafAuto) cancelAnimationFrame(rafAuto);
        rafAuto = null;
      }

      stage.addEventListener('pointerdown', (e) => {
        if (!duration) return;
        isDragging = true;
        stage.classList.add('dragging', 'touched');
        cancelAutoSpin();
        clearTimeout(idleTimer);
        dragStartX = e.clientX;
        dragStartTime = video.currentTime;
        stage.setPointerCapture(e.pointerId);
      });

      stage.addEventListener('pointermove', (e) => {
        if (!isDragging) return;
        const dx = e.clientX - dragStartX;
        const turns = dx / PX_PER_FULL_ROTATION;
        let t = dragStartTime + turns * duration;
        t = ((t % duration) + duration) % duration;
        video.currentTime = t;
      });

      const endDrag = (e) => {
        if (!isDragging) return;
        isDragging = false;
        stage.classList.remove('dragging');
        try { stage.releasePointerCapture(e.pointerId); } catch {}
        clearTimeout(idleTimer);
        idleTimer = setTimeout(() => { if (!reduce) startAutoSpin(); }, IDLE_RESUME_MS);
      };
      stage.addEventListener('pointerup', endDrag);
      stage.addEventListener('pointercancel', endDrag);
      stage.addEventListener('pointerleave', (e) => { if (isDragging) endDrag(e); });

      // Pause when offscreen (perf)
      const io = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          if (!isDragging && !reduce) startAutoSpin();
        } else {
          cancelAutoSpin();
        }
      }, { threshold: 0.1 });
      io.observe(stage);
    })();
  </script>

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_video_bg",
      "label": "Enable Background Video",
      "default": true
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Background Video URL",
      "default": "https://assets.mixkit.co/videos/preview/mixkit-pouring-hot-water-into-a-cup-with-tea-leaves-43034-large.mp4"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Mineral Bodycare · Est. India"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Wordmark / Heading",
      "default": "VURA"
    },
    {
      "type": "text",
      "id": "devanagari",
      "label": "Devanagari (Hindi)",
      "default": "वूरा"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Tagline",
      "default": "Single-mineral skincare, pressed from earth and dissolved into rose. Each release filed in the Mineral Archive, bottled in small batches."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Label",
      "default": "Order Series 01"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "ghost_btn_label",
      "label": "Label",
      "default": "Our Ritual"
    },
    {
      "type": "url",
      "id": "ghost_btn_link",
      "label": "Link"
    }
  ],
  "presets": [
    { "name": "Vura Hero" }
  ]
}
{% endschema %}
