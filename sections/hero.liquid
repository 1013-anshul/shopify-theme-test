<section class="hero-section">

  <!-- Background Video Loop -->
  {%- if section.settings.show_video_bg and section.settings.video_url != blank -%}
    <video autoplay loop muted playsinline class="hero-video-bg">
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- endif -%}

  <!-- Botanical florals (decorative, aria-hidden) -->
  <img src="{{ 'flower-marigold.png' | asset_url }}" 
       alt="" 
       class="hero-floral-right" 
       aria-hidden="true">
  <img src="{{ 'flower-bouquet.png' | asset_url }}" 
       alt="" 
       class="hero-floral-left" 
       aria-hidden="true">

  <!-- Mineral Archive Seal -->
  <img src="{{ 'seal-mineral-archive.png' | asset_url }}" 
       alt="Mineral Archive Registry" 
       class="hero-seal" 
       aria-hidden="true">

  <div class="hero-content">

    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow | escape }}</div>
    {%- endif -%}

    <h1 class="hero-title">{{ section.settings.title | default: shop.name | escape }}</h1>

    {%- if section.settings.devanagari != blank -%}
      <div class="hero-devanagari dev" lang="hi">{{ section.settings.devanagari | escape }}</div>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="hero-lede">{{ section.settings.text | escape }}</p>
    {%- endif -%}

    <div class="hero-cta">
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_link | default: '/collections/all' }}" 
           class="button button-primary">
          {{ section.settings.btn_label | escape }}
        </a>
      {%- endif -%}
      {%- if section.settings.ghost_btn_label != blank -%}
        <a href="{{ section.settings.ghost_btn_link | default: '/collections/all' }}" 
           class="button button-ghost">
          {{ section.settings.ghost_btn_label | escape }} &rarr;
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_video_bg",
      "label": "Enable Background Video",
      "default": true
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Background Video URL",
      "default": "https://assets.mixkit.co/videos/preview/mixkit-pouring-hot-water-into-a-cup-with-tea-leaves-43034-large.mp4"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Mineral Bodycare · Est. India"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Wordmark / Heading",
      "default": "VURA"
    },
    {
      "type": "text",
      "id": "devanagari",
      "label": "Devanagari (Hindi)",
      "default": "वूरा"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Tagline",
      "default": "Single-mineral skincare, pressed from earth and dissolved into rose. Each release filed in the Mineral Archive, bottled in small batches."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Label",
      "default": "Read Series 01"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "ghost_btn_label",
      "label": "Label",
      "default": "Browse the Archive"
    },
    {
      "type": "url",
      "id": "ghost_btn_link",
      "label": "Link"
    }
  ],
  "presets": [
    { "name": "Vura Hero" }
  ]
}
{% endschema %}
