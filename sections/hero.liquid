<section class="hero-section">
  
  <!-- Background Video Loop if enabled -->
  {%- if section.settings.show_video_bg and section.settings.video_url != blank -%}
    <video autoplay loop muted playsinline class="hero-video-bg">
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- endif -%}

  <div class="container hero-container">
    
    <div class="hero-main-content">
      <!-- Devanagari branding (small) -->
      {%- if section.settings.devanagari != blank -%}
        <div class="hero-brand-devanagari dev" lang="hi">{{ section.settings.devanagari | escape }}</div>
      {%- endif -%}

      <!-- Bold Typographic Headline -->
      <h1 class="hero-big-title">
        {{ section.settings.title | default: "VURA SKINCARE" | escape }}
      </h1>

      <!-- Dotted Separator Line -->
      <div class="hero-dotted-line">
        <svg viewBox="0 0 1000 1">
          <line x1="0" y1="0.5" x2="1000" y2="0.5" stroke="var(--vura-hairline)" stroke-width="1" stroke-dasharray="10, 10"></line>
        </svg>
      </div>

      <!-- Subheading -->
      {%- if section.settings.text != blank -%}
        <p class="hero-subtext">{{ section.settings.text | escape }}</p>
      {%- endif -%}

      <!-- CTA -->
      {%- if section.settings.btn_label != blank -%}
        <div class="hero-actions">
          <a href="{{ section.settings.btn_link | default: '#Vura3DExplorer' }}" class="button button-primary hero-btn">
            {{ section.settings.btn_label | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <!-- Bottom Partner Logo Strip (Trust indicators styled like Hydroflow) -->
    <div class="hero-trust-bar">
      <div class="trust-bar-wrapper">
        <div class="trust-item">
          <i data-lucide="shield-check" aria-hidden="true"></i>
          <span>100% Active Minerals</span>
        </div>
        <div class="trust-item">
          <i data-lucide="droplet" aria-hidden="true"></i>
          <span>Copper-Still Rosewater</span>
        </div>
        <div class="trust-item">
          <i data-lucide="leaf" aria-hidden="true"></i>
          <span>Wild Aloe Infused</span>
        </div>
        <div class="trust-item">
          <i data-lucide="package-check" aria-hidden="true"></i>
          <span>Small Batch Registry</span>
        </div>
        <div class="trust-item">
          <i data-lucide="award" aria-hidden="true"></i>
          <span>Apothecary Quality</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
.hero-section {
  position: relative;
  background-color: var(--vura-forest-deep);
  border-bottom: 1px solid var(--border-soft);
  min-height: 85vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: var(--s-12) 0;
}
.hero-video-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.15;
  pointer-events: none;
  z-index: 1;
}
.hero-container {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 70vh;
  width: 100%;
}
.hero-main-content {
  text-align: center;
  margin: auto 0;
  max-width: 900px;
  margin-inline: auto;
}
.hero-brand-devanagari {
  color: var(--vura-saffron);
  font-size: var(--size-base);
  letter-spacing: 0.3em;
  margin-bottom: var(--s-4);
  text-transform: uppercase;
}
.hero-big-title {
  font-family: Roca One, Georgia, serif;
  font-weight: 700;
  font-size: clamp(48px, 8vw, 96px);
  line-height: 1.0;
  letter-spacing: -0.03em;
  color: var(--vura-cream);
  margin: 0;
  text-shadow: 4px 4px 0 var(--vura-terracotta);
}
.hero-dotted-line {
  margin: var(--s-8) 0;
  width: 100%;
  height: 2px;
}
.hero-subtext {
  font-size: var(--size-base);
  line-height: 1.6;
  color: var(--fg-muted);
  max-width: 600px;
  margin: 0 auto var(--s-8);
}
.hero-btn {
  padding: var(--s-4) var(--s-8);
  font-size: var(--size-sm);
  letter-spacing: var(--track-loose);
}

/* Trust Bar Styling matching Hydroflow's logo marquee */
.hero-trust-bar {
  border-top: 1px solid var(--border-soft);
  padding-top: var(--s-8);
  margin-top: var(--s-12);
  width: 100%;
}
.trust-bar-wrapper {
  display: flex;
  justify-content: space-around;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--s-6);
}
.trust-item {
  display: flex;
  align-items: center;
  gap: var(--s-2);
  color: var(--fg-faint);
  font-size: var(--size-xs);
  text-transform: uppercase;
  letter-spacing: var(--track-mid);
  font-weight: 500;
}
.trust-item i {
  color: var(--vura-saffron);
  width: 16px;
  height: 16px;
  stroke-width: 1.5;
}

@media (max-width: 767px) {
  .hero-big-title {
    text-shadow: 2px 2px 0 var(--vura-terracotta);
  }
  .trust-bar-wrapper {
    justify-content: center;
    gap: var(--s-4);
  }
}
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_video_bg",
      "label": "Enable Background Video",
      "default": true
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Background Video URL",
      "default": "https://assets.mixkit.co/videos/preview/mixkit-pouring-hot-water-into-a-cup-with-tea-leaves-43034-large.mp4"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Wordmark / Heading",
      "default": "VURA SKINCARE"
    },
    {
      "type": "text",
      "id": "devanagari",
      "label": "Devanagari (Hindi)",
      "default": "वूरा"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Tagline",
      "default": "Pure. Mineral-Powered. Apothecary-Tradition. Handcrafted small batches from India's geothermal deposits."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Order Series 01"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    { "name": "Vura Hero" }
  ]
}
{% endschema %}
