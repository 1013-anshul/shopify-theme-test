<!-- Testimonials Section (Tactile Paper-Ink Theme) -->
<section id="testimonials" class="vura-testimonials-section">
  <div class="container">
    
    <div class="vura-testimonials-head">
      <h2 class="testimonials-heading">{{ section.settings.title | default: "Become part of our archive" | escape }}</h2>
      <p class="testimonials-subheading">{{ section.settings.subheading | default: "Read what our early small-batch release customers say about VURA." | escape }}</p>
    </div>

    <!-- Testimonials grid/scroll -->
    <div class="vura-testimonials-wrapper">
      <div class="vura-testimonials-grid">
        
        <!-- Card 1 -->
        <div class="testimonial-card">
          <div class="testimonial-top">
            <div class="avatar-circle"><span class="avatar-initials">JC</span></div>
            <p class="testimonial-quote">"VURA has completely replaced my standard underarm deodorants. The Phitkari spritz keeps me dry and odor-free all day without any synthetic chemicals."</p>
          </div>
          <div class="testimonial-bottom">
            <p class="testimonial-name">James Carter</p>
            <p class="testimonial-title">Early Backer, Apothecary Enthusiast</p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="testimonial-card">
          <div class="testimonial-top">
            <div class="avatar-circle"><span class="avatar-initials">EM</span></div>
            <p class="testimonial-quote">"Simple ingredients, traditional copper-still rosewater, and aloe. It's clean underarm protection that doesn't feel sticky or clog pores. Highly recommend."</p>
          </div>
          <div class="testimonial-bottom">
            <p class="testimonial-name">Ethan Miller</p>
            <p class="testimonial-title">Skin Health Specialist</p>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="testimonial-card">
          <div class="testimonial-top">
            <div class="avatar-circle"><span class="avatar-initials">LB</span></div>
            <p class="testimonial-quote">"The design is gorgeous, but the mist inside is even better. It is soothing post-shave or post-shower and controls body odor perfectly. Ordering more from Batch 02."</p>
          </div>
          <div class="testimonial-bottom">
            <p class="testimonial-name">Lucas Bennett</p>
            <p class="testimonial-title">Series 01 Specimen Collector</p>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
.vura-testimonials-section {
  padding: var(--s-20) 0;
  background-color: var(--vura-paper);
  border-top: 1px solid var(--vura-hairline-soft);
}

.vura-testimonials-head {
  text-align: center;
  margin-bottom: var(--s-12);
}

.testimonials-heading {
  font-family: var(--font-display);
  font-size: clamp(32px, 4vw, 48px);
  color: var(--vura-forest-deep);
  margin: 0 0 var(--s-2);
}

.testimonials-subheading {
  font-size: 13px;
  color: var(--vura-paper-ink-muted);
  margin: 0;
}

.vura-testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--s-6);
}

.testimonial-card {
  background: var(--vura-cream);
  border: 1px solid var(--vura-hairline);
  border-radius: var(--r-2);
  padding: var(--s-6);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 250px;
  box-shadow: 3px 3px 0 0 var(--vura-terracotta);
  transition: all var(--t-base) var(--ease-out);
}

.testimonial-card:hover {
  border-color: var(--vura-forest-deep);
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 0 var(--vura-terracotta);
}

.testimonial-top {
  display: flex;
  flex-direction: column;
  gap: var(--s-4);
}

.avatar-circle {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--vura-paper-deep);
  border: 1px solid var(--vura-hairline);
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar-initials {
  color: var(--vura-terracotta);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: var(--track-mid);
}

.testimonial-quote {
  font-size: 13px;
  line-height: 1.6;
  color: var(--vura-paper-ink-muted);
  font-style: italic;
  margin: 0;
}

.testimonial-bottom {
  margin-top: var(--s-6);
  border-top: 1px dashed var(--vura-hairline);
  padding-top: var(--s-4);
}

.testimonial-name {
  font-size: 11px;
  font-weight: 600;
  color: var(--vura-forest-deep);
  text-transform: uppercase;
  letter-spacing: var(--track-mid);
  margin: 0 0 var(--s-1);
}

.testimonial-title {
  font-size: 11px;
  color: var(--vura-paper-ink-faint);
  margin: 0;
}

@media (max-width: 991px) {
  .vura-testimonials-grid {
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }
}
</style>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Become part of our archive"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Read what our early small-batch release customers say about VURA."
    }
  ],
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}
