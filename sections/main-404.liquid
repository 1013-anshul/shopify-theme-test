<section class="error-404-section container text-center" style="padding: 8rem 0;">
  <div class="glass-card" style="max-width: 600px; margin: 0 auto; padding: 4rem 2rem;">
    <h1 style="font-size: 5rem; font-weight: 800; background: linear-gradient(135deg, #6366f1, #14b8a6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">404</h1>
    <h2 style="font-size: 2rem; margin-top: 1rem; margin-bottom: 1.5rem;">{{ 'general.404.title' | t }}</h2>
    <p class="text-muted" style="font-size: 1.1rem; margin-bottom: 2.5rem;">{{ 'general.404.subtext' | t }}</p>
    
    <div style="display: flex; gap: 1rem; justify-content: center;">
      <a href="/" class="button button-primary">Home</a>
      <a href="/collections/all" class="button button-secondary">{{ 'general.404.continue_shopping' | t }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "404 Error Page"
}
{% endschema %}
