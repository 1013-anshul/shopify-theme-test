{% comment %}
  Vura product image gallery.
  - Mobile: horizontal swipe / scroll-snap card stack (neighbours peek at the edges).
  - Desktop: same track, navigated with clickable prev/next arrows.
  Each card links through to the product page. Images are pulled live from the
  selected product, so adding/removing product images updates this automatically.
{% endcomment %}

{%- assign gallery_product = section.settings.product -%}
{%- if gallery_product != blank -%}
  {%- assign gallery_images = gallery_product.images -%}
  {%- assign gallery_url = gallery_product.url -%}
{%- endif -%}

{%- style -%}
  #vura-gallery-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background }};
  }
  #vura-gallery-{{ section.id }} .vura-gallery__header {
    max-width: var(--page-width, 1200px);
    margin: 0 auto 0.8rem;
    padding: 0 1.5rem;
    text-align: {{ section.settings.text_alignment }};
  }
  #vura-gallery-{{ section.id }} .vura-gallery__eyebrow {
    display: block;
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--vura-terracotta, #8D3B2D);
  }
  #vura-gallery-{{ section.id }} .vura-gallery__heading {
    margin: 0;
    font-family: var(--font-display, Georgia, serif);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1.1;
    color: var(--vura-ink, #1A2A22);
  }
  #vura-gallery-{{ section.id }} .vura-gallery__viewport {
    position: relative;
  }
  /* Card deck — one card in front, the rest curve away behind it. Same on
     every screen size; only the dimensions change. */
  #vura-gallery-{{ section.id }} .vura-gallery__track {
    display: block;
    position: relative;
    height: 98vw;
    margin: 0;
    padding: 0;
    list-style: none;
    overflow: visible;
    perspective: 1100px;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 68vw;
    transform: translate(-50%, -50%);
    border-radius: 20px;
    overflow: hidden;
    background: var(--vura-paper, #F8F3E7);
    box-shadow: 0 18px 44px rgba(26, 42, 34, 0.24);
    touch-action: pan-y;
    -webkit-user-select: none;
    user-select: none;
    backface-visibility: hidden;
    will-change: transform, opacity;
    cursor: pointer;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__card a {
    -webkit-user-drag: none;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__card a,
  #vura-gallery-{{ section.id }} .vura-gallery__card img {
    display: block;
    width: 100%;
    height: 100%;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__card img {
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  #vura-gallery-{{ section.id }} .vura-gallery__hint {
    display: none;
    margin: 1.2rem 0 0;
    text-align: center;
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--vura-terracotta, #8D3B2D);
    opacity: 0.72;
  }

  #vura-gallery-{{ section.id }} .vura-gallery__viewport {
    overflow-x: clip;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__hint {
    display: block;
  }

  @media screen and (min-width: 750px) {
    #vura-gallery-{{ section.id }} .vura-gallery__track {
      height: 560px;
    }
    #vura-gallery-{{ section.id }} .vura-gallery__card {
      width: min(380px, 30vw);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #vura-gallery-{{ section.id }} .vura-gallery__card { transition: none; }
  }
{%- endstyle -%}

<section id="vura-gallery-{{ section.id }}" class="vura-gallery{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="vura-gallery__header" data-vura-stagger>
      {%- if section.settings.eyebrow != blank -%}
        <span class="vura-gallery__eyebrow" data-vura-reveal="up">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="vura-gallery__heading" data-vura-reveal="mask"><span class="vura-line">{{ section.settings.heading }}</span></h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="vura-gallery__viewport">
    <ul class="vura-gallery__track" data-gallery-track>
      {%- if gallery_images != blank and gallery_images.size > 0 -%}
        {%- for image in gallery_images -%}
          <li class="vura-gallery__card">
            <a href="{{ gallery_url }}" aria-label="{{ gallery_product.title | escape }}">
              {{
                image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 340px, 78vw',
                  widths: '400, 600, 800, 1000',
                  alt: image.alt | default: gallery_product.title | escape
              }}
            </a>
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <li class="vura-gallery__card">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>

  <p class="vura-gallery__hint" aria-hidden="true">&#8592;&ensp;Swipe or tap&ensp;&#8594;</p>
</section>

<script>
  (function () {
    var root = document.getElementById('vura-gallery-{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('[data-gallery-track]');
    if (!track) return;
    var cards = Array.prototype.slice.call(track.querySelectorAll('.vura-gallery__card'));
    var N = cards.length;
    if (!N) return;

    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    /* Continuous circular wheel carousel (coverflow), RAF-eased. Runs at every
       screen size so desktop behaves exactly like mobile. */
    var pos = 0;          // fractional current index
    var target = 0;       // where it eases to
    var dragUnit = 165;   // px of horizontal drag = one card (recalculated on resize)
    var raf = null;
    var drag = null;
    var on = false;

    function mod(n, m) { return ((n % m) + m) % m; }
    // shortest signed distance from card i to the current position, wrapped circularly
    function delta(i) {
      var d = mod(i - pos, N);
      if (d > N / 2) d -= N;
      return d;
    }
    function transformFor(d) {
      var spread = 0.55, radius = window.innerWidth >= 750 ? 420 : 300;
      var ang = d * spread;
      var x = Math.sin(ang) * radius;
      var z = (Math.cos(ang) - 1) * radius;      // <= 0, pushes side cards back
      var ry = -(ang * 180 / Math.PI) * 0.5;     // subtle turn toward centre
      return 'translate(-50%, -50%) translate3d(' + x.toFixed(2) + 'px, 0, ' + z.toFixed(2) + 'px) rotateY(' + ry.toFixed(2) + 'deg)';
    }
    function opacityFor(d) {
      var a = Math.abs(d);
      if (a <= 1) return 1;
      if (a >= 1.85) return 0;
      return 1 - (a - 1) / 0.85;
    }
    function render() {
      var frontIdx = mod(Math.round(pos), N);
      for (var i = 0; i < N; i++) {
        var d = delta(i);
        var c = cards[i];
        c.style.transform = transformFor(d);
        c.style.opacity = opacityFor(d).toFixed(3);
        c.style.zIndex = String(1000 - Math.round(Math.abs(d) * 100));
        c.style.pointerEvents = (i === frontIdx) ? 'auto' : 'none';
      }
    }
    function animate() {
      var ease = reduce.matches ? 1 : 0.16;
      var diff = target - pos;
      if (Math.abs(diff) < 0.0008) {
        pos = target;
        render();
        raf = null;
        return;
      }
      pos += diff * ease;
      render();
      raf = requestAnimationFrame(animate);
    }
    function startAnim() { if (!raf) raf = requestAnimationFrame(animate); }

    /* The wheel sits at manual + scrollTurn. `manual` is what drag and tap own;
       `scrollTurn` is what the page scroll contributes. Keeping them separate
       means scrolling never fights a card the visitor just chose, and a drag
       never resets the scroll contribution. */
    var manual = 0;
    var scrollTurn = 0;
    var TURNS = N * 0.5;   // cards advanced across one full pass of the viewport

    // A drag writes `pos` straight out for 1:1 finger tracking, so scroll must
    // stay out of the way until the finger lifts.
    function retarget() { if (drag) return; target = manual + scrollTurn; startAnim(); }
    function goTo(t) { manual = t - scrollTurn; retarget(); }

    function suppressClickOnce(card) {
      var link = card && card.querySelector('a');
      if (!link) return;
      var h = function (ev) { ev.preventDefault(); ev.stopPropagation(); };
      link.addEventListener('click', h, true);
      setTimeout(function () { link.removeEventListener('click', h, true); }, 60);
    }

    function onDown(e) {
      if (!on || drag) return;
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      if (raf) { cancelAnimationFrame(raf); raf = null; }
      drag = { x: e.clientX, y: e.clientY, startPos: pos, vel: 0, decided: false, horizontal: false, moved: false };
    }
    function onMove(e) {
      if (!drag) return;
      var dx = e.clientX - drag.x;
      var dy = e.clientY - drag.y;
      if (!drag.decided) {
        if (Math.abs(dx) < 5 && Math.abs(dy) < 5) return;
        drag.decided = true;
        drag.horizontal = Math.abs(dx) > Math.abs(dy);
      }
      if (!drag.horizontal) return;
      if (e.cancelable) e.preventDefault();
      if (Math.abs(dx) > 6) drag.moved = true;
      var prevPos = pos;
      pos = drag.startPos - dx / dragUnit;
      drag.vel = pos - prevPos;   // card-units since last move
      render();
    }
    function onUp() {
      if (!drag) return;
      var moved = drag.moved;
      var vel = drag.vel;
      var frontCard = cards[mod(Math.round(pos), N)];
      drag = null;
      // snap to the nearest card; a quick flick nudges one further
      var momentum = Math.max(-0.6, Math.min(0.6, vel * 3));
      goTo(Math.round(pos + momentum));
      if (moved) suppressClickOnce(frontCard);
    }

    // Once a drag is judged horizontal, stop the browser from panning the page
    // vertically at the same time. pointermove's preventDefault can't do this,
    // so it needs its own non-passive touchmove listener.
    function onTouchMove(e) {
      if (drag && drag.decided && drag.horizontal && e.cancelable) e.preventDefault();
    }

    /* Page scroll turns the wheel while the section is on screen. The page goes
       on scrolling exactly as it did — this rides along on top of it and never
       captures the gesture. */
    var inView = false;
    var scrollQueued = false;
    var scrollIO = null;

    function measureScroll() {
      scrollQueued = false;
      var r = root.getBoundingClientRect();
      var vh = window.innerHeight || 0;
      if (!vh) return;
      // 0 while the section's top edge is at the bottom of the viewport,
      // 1 once its bottom edge has cleared the top.
      var p = (vh - r.top) / (vh + r.height);
      scrollTurn = Math.max(0, Math.min(1, p)) * TURNS;
      retarget();
    }
    function onPageScroll() {
      if (!inView || scrollQueued) return;
      scrollQueued = true;
      requestAnimationFrame(measureScroll);
    }

    function enable() {
      if (on) return;
      on = true;
      pos = 0; target = 0; manual = 0; scrollTurn = 0;
      render();
      if (!reduce.matches && 'IntersectionObserver' in window) {
        scrollIO = new IntersectionObserver(function (entries) {
          inView = entries[0].isIntersecting;
          if (inView) measureScroll();
        });
        scrollIO.observe(root);
        window.addEventListener('scroll', onPageScroll, { passive: true });
        window.addEventListener('resize', onPageScroll, { passive: true });
      }
      track.addEventListener('pointerdown', onDown);
      track.addEventListener('touchmove', onTouchMove, { passive: false });
      window.addEventListener('pointermove', onMove, { passive: false });
      window.addEventListener('pointerup', onUp);
      window.addEventListener('pointercancel', onUp);
    }
    function disable() {
      if (!on) return;
      on = false; drag = null;
      if (raf) { cancelAnimationFrame(raf); raf = null; }
      if (scrollIO) { scrollIO.disconnect(); scrollIO = null; }
      inView = false;
      window.removeEventListener('scroll', onPageScroll);
      window.removeEventListener('resize', onPageScroll);
      track.removeEventListener('pointerdown', onDown);
      track.removeEventListener('touchmove', onTouchMove);
      window.removeEventListener('pointermove', onMove);
      window.removeEventListener('pointerup', onUp);
      window.removeEventListener('pointercancel', onUp);
      cards.forEach(function (c) {
        c.style.transform = ''; c.style.opacity = ''; c.style.zIndex = ''; c.style.pointerEvents = '';
      });
    }
    // Tap or click the image to move through the photos: left half goes back,
    // right half goes forward, the same as the product page. A clean tap
    // advances; a drag is suppressed above so it never navigates or double-fires.
    track.addEventListener('click', function (e) {
      e.preventDefault();                    // don't follow the card's product link
      var r = track.getBoundingClientRect();
      var dir = (e.clientX - r.left) / r.width < 0.5 ? -1 : 1;
      goTo(Math.round(target) + dir);
    });

    enable();
  })();
</script>

{% schema %}
{
  "name": "Vura gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Its images are shown in the stack."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Every angle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Take a closer look"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#EFE9DA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Vura gallery"
    }
  ],
  "enabled_on": {
    "templates": ["index", "page"]
  }
}
{% endschema %}
