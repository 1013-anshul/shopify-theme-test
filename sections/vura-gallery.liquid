{% comment %}
  Vura product image gallery.
  - Mobile: horizontal swipe / scroll-snap card stack (neighbours peek at the edges).
  - Desktop: same track, navigated with clickable prev/next arrows.
  Each card links through to the product page. Images are pulled live from the
  selected product, so adding/removing product images updates this automatically.
{% endcomment %}

{%- assign gallery_product = section.settings.product -%}
{%- if gallery_product != blank -%}
  {%- assign gallery_images = gallery_product.images -%}
  {%- assign gallery_url = gallery_product.url -%}
{%- endif -%}

{%- style -%}
  #vura-gallery-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background }};
  }
  /* Mobile-only section: the card-stack gallery is hidden on desktop */
  @media screen and (min-width: 750px) {
    #vura-gallery-{{ section.id }} {
      display: none;
    }
  }
  #vura-gallery-{{ section.id }} .vura-gallery__header {
    max-width: var(--page-width, 1200px);
    margin: 0 auto 1.6rem;
    padding: 0 1.5rem;
    text-align: {{ section.settings.text_alignment }};
  }
  #vura-gallery-{{ section.id }} .vura-gallery__eyebrow {
    display: block;
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--vura-terracotta, #8D3B2D);
  }
  #vura-gallery-{{ section.id }} .vura-gallery__heading {
    margin: 0;
    font-family: var(--font-display, Georgia, serif);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1.1;
    color: var(--vura-ink, #1A2A22);
  }
  #vura-gallery-{{ section.id }} .vura-gallery__viewport {
    position: relative;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__track {
    display: flex;
    gap: 16px;
    margin: 0;
    padding: 0.5rem 1.5rem 1.5rem;
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__track::-webkit-scrollbar {
    display: none;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__card {
    flex: 0 0 auto;
    scroll-snap-align: center;
    width: 300px;
    border-radius: 20px;
    overflow: hidden;
    background: var(--vura-paper, #F8F3E7);
    box-shadow: 0 12px 30px rgba(26, 42, 34, 0.16);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__card a,
  #vura-gallery-{{ section.id }} .vura-gallery__card img {
    display: block;
    width: 100%;
    height: 100%;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__card img {
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  /* Clickable arrows — desktop only */
  #vura-gallery-{{ section.id }} .vura-gallery__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: none;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: none;
    border-radius: 50%;
    background: var(--vura-paper, #F8F3E7);
    color: var(--vura-ink, #1A2A22);
    box-shadow: 0 6px 18px rgba(26, 42, 34, 0.22);
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__arrow:hover {
    background: #fff;
    transform: translateY(-50%) scale(1.06);
  }
  #vura-gallery-{{ section.id }} .vura-gallery__arrow[disabled] {
    opacity: 0.35;
    cursor: default;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__arrow svg {
    width: 20px;
    height: 20px;
  }
  #vura-gallery-{{ section.id }} .vura-gallery__arrow--prev { left: 1.5rem; }
  #vura-gallery-{{ section.id }} .vura-gallery__arrow--next { right: 1.5rem; }

  #vura-gallery-{{ section.id }} .vura-gallery__hint {
    display: none;
    margin: 1.2rem 0 0;
    text-align: center;
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--vura-terracotta, #8D3B2D);
    opacity: 0.72;
  }

  @media screen and (min-width: 750px) {
    #vura-gallery-{{ section.id }} .vura-gallery__card {
      width: 340px;
    }
    #vura-gallery-{{ section.id }} .vura-gallery__card:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(26, 42, 34, 0.22);
    }
    #vura-gallery-{{ section.id }} .vura-gallery__track {
      padding-left: 5rem;
      padding-right: 5rem;
      scroll-padding-left: 5rem;
    }
    #vura-gallery-{{ section.id }} .vura-gallery__arrow {
      display: flex;
    }
  }

  /* Mobile: stacked card deck — one card in front, others peek behind */
  @media screen and (max-width: 749px) {
    #vura-gallery-{{ section.id }} .vura-gallery__viewport {
      overflow-x: clip;
    }
    #vura-gallery-{{ section.id }} .vura-gallery__track {
      display: block;
      position: relative;
      height: 106vw;
      margin: 0;
      padding: 0;
      overflow: visible;
      scroll-snap-type: none;
    }
    #vura-gallery-{{ section.id }} .vura-gallery__card {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 72vw;
      transform: translate(-50%, -50%);
      transition: transform 0.38s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.3s ease;
      touch-action: pan-y;
      box-shadow: 0 18px 44px rgba(26, 42, 34, 0.24);
      -webkit-user-select: none;
      user-select: none;
      will-change: transform;
    }
    #vura-gallery-{{ section.id }} .vura-gallery__card a {
      -webkit-user-drag: none;
    }
    #vura-gallery-{{ section.id }} .vura-gallery__hint {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #vura-gallery-{{ section.id }} .vura-gallery__track { scroll-behavior: auto; }
    #vura-gallery-{{ section.id }} .vura-gallery__card { transition: none; }
  }
{%- endstyle -%}

<section id="vura-gallery-{{ section.id }}" class="vura-gallery">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="vura-gallery__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="vura-gallery__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="vura-gallery__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="vura-gallery__viewport">
    <button
      type="button"
      class="vura-gallery__arrow vura-gallery__arrow--prev"
      aria-label="Previous image"
      data-gallery-prev
    >
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <ul class="vura-gallery__track" data-gallery-track>
      {%- if gallery_images != blank and gallery_images.size > 0 -%}
        {%- for image in gallery_images -%}
          <li class="vura-gallery__card">
            <a href="{{ gallery_url }}" aria-label="{{ gallery_product.title | escape }}">
              {{
                image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 340px, 78vw',
                  widths: '400, 600, 800, 1000',
                  alt: image.alt | default: gallery_product.title | escape
              }}
            </a>
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <li class="vura-gallery__card">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>

    <button
      type="button"
      class="vura-gallery__arrow vura-gallery__arrow--next"
      aria-label="Next image"
      data-gallery-next
    >
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

  <p class="vura-gallery__hint" aria-hidden="true">&#8592;&ensp;Swipe&ensp;&#8594;</p>
</section>

<script>
  (function () {
    var root = document.getElementById('vura-gallery-{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('[data-gallery-track]');
    if (!track) return;
    var prev = root.querySelector('[data-gallery-prev]');
    var next = root.querySelector('[data-gallery-next]');
    var cards = Array.prototype.slice.call(track.querySelectorAll('.vura-gallery__card'));
    if (!cards.length) return;

    /* ---------- Desktop: clickable arrow scroll ---------- */
    function step() {
      var gap = parseInt(getComputedStyle(track).columnGap || getComputedStyle(track).gap || '16', 10) || 16;
      return cards[0].getBoundingClientRect().width + gap;
    }
    function updateArrows() {
      if (!prev || !next) return;
      var maxScroll = track.scrollWidth - track.clientWidth - 2;
      prev.disabled = track.scrollLeft <= 2;
      next.disabled = track.scrollLeft >= maxScroll;
    }
    if (prev && next) {
      prev.addEventListener('click', function () { track.scrollBy({ left: -step(), behavior: 'smooth' }); });
      next.addEventListener('click', function () { track.scrollBy({ left: step(), behavior: 'smooth' }); });
      track.addEventListener('scroll', updateArrows, { passive: true });
    }

    /* ---------- Mobile: peeking card-stack deck ---------- */
    var mq = window.matchMedia('(max-width: 749px)');
    var order = cards.map(function (_, i) { return i; });
    var deckOn = false;
    var drag = null;

    function tf(p) {
      if (p === 0) return 'translate(-50%, -50%) rotate(0deg) scale(1)';
      if (p === 1) return 'translate(calc(-50% + 24px), calc(-50% + 10px)) rotate(4deg) scale(0.94)';
      if (p === 2) return 'translate(calc(-50% - 24px), calc(-50% + 10px)) rotate(-4deg) scale(0.88)';
      return 'translate(-50%, calc(-50% + 16px)) rotate(0deg) scale(0.84)';
    }
    function place(card, p, animate) {
      card.style.transition = animate ? '' : 'none';
      card.style.transform = tf(p);
      card.style.zIndex = String(100 - p);
      card.style.opacity = p <= 2 ? '1' : '0';
      card.style.pointerEvents = p === 0 ? 'auto' : 'none';
    }
    function render(animate) {
      order.forEach(function (idx, p) { place(cards[idx], p, animate !== false); });
    }
    function cycleForward() {
      order.push(order.shift());
      render(true);
    }
    function suppressClickOnce(card) {
      var link = card.querySelector('a');
      if (!link) return;
      var handler = function (ev) { ev.preventDefault(); ev.stopPropagation(); };
      link.addEventListener('click', handler, true);
      setTimeout(function () { link.removeEventListener('click', handler, true); }, 60);
    }

    function onDown(e) {
      if (!deckOn || drag) return;
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      var card = cards[order[0]];
      if (!e.target.closest || e.target.closest('.vura-gallery__card') !== card) return;
      drag = { x: e.clientX, y: e.clientY, dx: 0, decided: false, horizontal: false, moved: false, card: card };
      card.style.transition = 'none';
    }
    function onMove(e) {
      if (!drag) return;
      var dx = e.clientX - drag.x;
      var dy = e.clientY - drag.y;
      if (!drag.decided) {
        if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return;
        drag.decided = true;
        drag.horizontal = Math.abs(dx) > Math.abs(dy);
      }
      if (!drag.horizontal) return;
      if (e.cancelable) e.preventDefault();
      drag.dx = dx;
      if (Math.abs(dx) > 8) drag.moved = true;
      drag.card.style.transform = 'translate(calc(-50% + ' + dx + 'px), -50%) rotate(' + (dx * 0.05) + 'deg) scale(1)';
    }
    function onUp() {
      if (!drag) return;
      var card = drag.card;
      var dx = drag.dx;
      var moved = drag.moved;
      drag = null;
      card.style.transition = '';
      var threshold = card.getBoundingClientRect().width * 0.32;
      if (Math.abs(dx) > threshold) {
        var dir = dx > 0 ? 1 : -1;
        card.style.transform = 'translate(calc(-50% + ' + (dir * 460) + 'px), -50%) rotate(' + (dir * 14) + 'deg) scale(0.94)';
        card.style.opacity = '0';
        var done = false;
        var finish = function () {
          if (done) return;
          done = true;
          card.removeEventListener('transitionend', finish);
          cycleForward();
        };
        card.addEventListener('transitionend', finish);
        setTimeout(finish, 420);
      } else {
        render(true);
      }
      if (moved) suppressClickOnce(card);
    }

    function enableDeck() {
      if (deckOn) return;
      deckOn = true;
      order = cards.map(function (_, i) { return i; });
      render(false);
      track.addEventListener('pointerdown', onDown);
      window.addEventListener('pointermove', onMove, { passive: false });
      window.addEventListener('pointerup', onUp);
      window.addEventListener('pointercancel', onUp);
    }
    function disableDeck() {
      if (!deckOn) return;
      deckOn = false;
      drag = null;
      track.removeEventListener('pointerdown', onDown);
      window.removeEventListener('pointermove', onMove);
      window.removeEventListener('pointerup', onUp);
      window.removeEventListener('pointercancel', onUp);
      cards.forEach(function (card) {
        card.style.transition = '';
        card.style.transform = '';
        card.style.zIndex = '';
        card.style.opacity = '';
        card.style.pointerEvents = '';
      });
    }
    function sync() {
      if (mq.matches) {
        enableDeck();
      } else {
        disableDeck();
        updateArrows();
      }
    }
    if (mq.addEventListener) { mq.addEventListener('change', sync); } else { mq.addListener(sync); }
    window.addEventListener('resize', updateArrows);
    sync();
  })();
</script>

{% schema %}
{
  "name": "Vura gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Its images are shown in the stack."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Every angle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Take a closer look"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#EFE9DA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Vura gallery"
    }
  ],
  "enabled_on": {
    "templates": ["index", "page"]
  }
}
{% endschema %}
