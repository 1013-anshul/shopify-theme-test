{%- liquid
  assign cols = 'perfume,deodorant,roll_on,vura' | split: ','
-%}

{%- style -%}
  .vura-cmp {
    background: #ffffff;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .vura-cmp__wrap { max-width: 920px; margin: 0 auto; padding: 0 1.5rem; }
  .vura-cmp__head { text-align: center; margin-bottom: 2.6rem; }
  .vura-cmp__eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1.1rem; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--vura-terracotta, #8D3B2D); margin: 0 0 0.9rem;
  }
  .vura-cmp__heading {
    font-family: var(--font-display, Georgia, serif);
    font-size: clamp(2.6rem, 4vw, 3.6rem); line-height: 1.1;
    color: var(--vura-paper-ink, #1A2A22); margin: 0;
  }
  .vura-cmp__scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .vura-cmp__table { width: 100%; border-collapse: collapse; min-width: 560px; }
  .vura-cmp__table th,
  .vura-cmp__table td { padding: 1.4rem 1rem; text-align: center; vertical-align: middle; }
  .vura-cmp__table thead th {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1.3rem; font-weight: 500; color: #6E6E73; border-bottom: 1px solid #ECECEC;
  }
  .vura-cmp__table tbody th {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1.4rem; font-weight: 500; text-align: left; color: #3A3A3A; white-space: nowrap;
  }
  .vura-cmp__table tbody td,
  .vura-cmp__table tbody th { border-bottom: 1px solid #F1F1F1; }
  .vura-cmp__table th.is-vura,
  .vura-cmp__table td.is-vura { background: var(--vura-terracotta-tint, #F4E9E4); }
  .vura-cmp__table thead th.is-vura {
    color: var(--vura-terracotta, #8D3B2D);
    font-family: var(--font-display, Georgia, serif); font-weight: 700; font-size: 1.7rem;
    border-top: 3px solid var(--vura-terracotta, #8D3B2D);
    border-top-left-radius: 10px; border-top-right-radius: 10px;
  }
  .vura-cmp__table tbody tr:last-child td.is-vura {
    border-bottom-left-radius: 10px; border-bottom-right-radius: 10px; border-bottom-color: transparent;
  }
  .cmp-ic { display: inline-flex; }
  .cmp-ic svg { width: 22px; height: 22px; }
  .cmp-ic--yes { color: #2B2B2B; }
  .cmp-ic--vura { color: var(--vura-terracotta, #8D3B2D); }
  .cmp-ic--no { color: #CFCFCF; }
  .cmp-ic--partial { color: #B8B8B8; }
  .vura-cmp__legend {
    display: flex; flex-wrap: wrap; gap: 2rem; justify-content: center; margin-top: 2.2rem;
    font-family: var(--font-body, 'Inter', sans-serif); font-size: 1.2rem; color: #86868B;
  }
  .vura-cmp__legend span { display: inline-flex; align-items: center; gap: 0.5rem; }
{%- endstyle -%}

{%- capture icon_yes -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>{%- endcapture -%}
{%- capture icon_partial -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="6" y1="12" x2="18" y2="12"/></svg>{%- endcapture -%}
{%- capture icon_no -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="17" y1="7" x2="7" y2="17"/><line x1="7" y1="7" x2="17" y2="17"/></svg>{%- endcapture -%}

<section class="vura-cmp{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="vura-cmp__wrap">
    <div class="vura-cmp__head">
      {%- if section.settings.eyebrow != blank -%}<p class="vura-cmp__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="vura-cmp__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>

    <div class="vura-cmp__scroll">
      <table class="vura-cmp__table">
        <thead>
          <tr>
            <th scope="col"><span class="visually-hidden">Attribute</span></th>
            <th scope="col">{{ section.settings.label_perfume | default: 'Perfume' }}</th>
            <th scope="col">{{ section.settings.label_deodorant | default: 'Deodorant' }}</th>
            <th scope="col">{{ section.settings.label_rollon | default: 'Roll-on' }}</th>
            <th scope="col" class="is-vura">{{ section.settings.label_vura | default: 'VURA' }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            <tr {{ block.shopify_attributes }}>
              <th scope="row">{{ block.settings.label }}</th>
              {%- for c in cols -%}
                {%- assign val = block.settings[c] -%}
                <td class="{% if c == 'vura' %}is-vura{% endif %}">
                  {%- if val == 'yes' -%}
                    <span class="cmp-ic cmp-ic--yes{% if c == 'vura' %} cmp-ic--vura{% endif %}" role="img" aria-label="Yes">{{ icon_yes }}</span>
                  {%- elsif val == 'partial' -%}
                    <span class="cmp-ic cmp-ic--partial" role="img" aria-label="Partial">{{ icon_partial }}</span>
                  {%- else -%}
                    <span class="cmp-ic cmp-ic--no" role="img" aria-label="No">{{ icon_no }}</span>
                  {%- endif -%}
                </td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    <div class="vura-cmp__legend">
      <span><span class="cmp-ic cmp-ic--yes">{{ icon_yes }}</span> Yes</span>
      <span><span class="cmp-ic cmp-ic--partial">{{ icon_partial }}</span> Partial</span>
      <span><span class="cmp-ic cmp-ic--no">{{ icon_no }}</span> No</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vura Comparison Table",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The VURA difference" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How VURA compares" },
    { "type": "header", "content": "Column labels" },
    { "type": "text", "id": "label_perfume", "label": "Column 1", "default": "Perfume" },
    { "type": "text", "id": "label_deodorant", "label": "Column 2", "default": "Deodorant" },
    { "type": "text", "id": "label_rollon", "label": "Column 3", "default": "Roll-on" },
    { "type": "text", "id": "label_vura", "label": "Highlighted column", "default": "VURA" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 52 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        { "type": "text", "id": "label", "label": "Attribute", "default": "Controls odour" },
        { "type": "select", "id": "perfume", "label": "Perfume", "default": "no", "options": [ { "value": "yes", "label": "Yes" }, { "value": "partial", "label": "Partial" }, { "value": "no", "label": "No" } ] },
        { "type": "select", "id": "deodorant", "label": "Deodorant", "default": "no", "options": [ { "value": "yes", "label": "Yes" }, { "value": "partial", "label": "Partial" }, { "value": "no", "label": "No" } ] },
        { "type": "select", "id": "roll_on", "label": "Roll-on", "default": "no", "options": [ { "value": "yes", "label": "Yes" }, { "value": "partial", "label": "Partial" }, { "value": "no", "label": "No" } ] },
        { "type": "select", "id": "vura", "label": "VURA", "default": "yes", "options": [ { "value": "yes", "label": "Yes" }, { "value": "partial", "label": "Partial" }, { "value": "no", "label": "No" } ] }
      ]
    }
  ],
  "max_blocks": 14,
  "presets": [
    {
      "name": "Vura Comparison Table",
      "blocks": [
        { "type": "row", "settings": { "label": "Controls odour", "perfume": "partial", "deodorant": "yes", "roll_on": "yes", "vura": "yes" } },
        { "type": "row", "settings": { "label": "Long-lasting", "perfume": "partial", "deodorant": "partial", "roll_on": "yes", "vura": "yes" } },
        { "type": "row", "settings": { "label": "Gentle on skin", "perfume": "no", "deodorant": "no", "roll_on": "partial", "vura": "yes" } },
        { "type": "row", "settings": { "label": "No residue", "perfume": "no", "deodorant": "partial", "roll_on": "no", "vura": "yes" } },
        { "type": "row", "settings": { "label": "Even coverage", "perfume": "partial", "deodorant": "partial", "roll_on": "no", "vura": "yes" } },
        { "type": "row", "settings": { "label": "Can be layered", "perfume": "yes", "deodorant": "no", "roll_on": "no", "vura": "yes" } },
        { "type": "row", "settings": { "label": "Soothing after shaving", "perfume": "no", "deodorant": "no", "roll_on": "partial", "vura": "yes" } },
        { "type": "row", "settings": { "label": "Travel-friendly", "perfume": "partial", "deodorant": "yes", "roll_on": "yes", "vura": "yes" } },
        { "type": "row", "settings": { "label": "Touch-free mist", "perfume": "partial", "deodorant": "partial", "roll_on": "no", "vura": "yes" } }
      ]
    }
  ]
}
{% endschema %}
