

<style>
  .vura-comparison {
    background: var(--vura-paper, #F8F3E7);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .vura-comparison .page-width {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .vura-comparison__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .vura-comparison__eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--vura-paper-ink-muted, #4A5750);
    margin-bottom: 12px;
  }

  .vura-comparison__heading {
    font-family: var(--font-display, 'Roca One', Georgia, serif);
    font-size: 44px;
    line-height: 50px;
    color: var(--vura-paper-ink, #1A2A22);
    margin: 0;
  }

  /* ── Table ── */
  .vura-comparison__table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid rgba(26, 42, 34, 0.16);
    border-radius: 6px;
    overflow: hidden;
  }

  .vura-comparison__table thead th {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--vura-paper-ink, #1A2A22);
    background: var(--vura-paper-deep, #EDE5D2);
    padding: 14px 20px;
    text-align: center;
    border-bottom: 1px solid rgba(26, 42, 34, 0.16);
  }

  .vura-comparison__table thead th:first-child {
    text-align: left;
  }

  .vura-comparison__table tbody td {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 15px;
    line-height: 24px;
    color: var(--vura-paper-ink, #1A2A22);
    padding: 16px 20px;
    text-align: center;
    border-bottom: 1px solid rgba(26, 42, 34, 0.10);
    vertical-align: middle;
  }

  .vura-comparison__table tbody td:first-child {
    text-align: left;
    font-weight: 500;
    color: var(--vura-paper-ink-muted, #4A5750);
  }

  .vura-comparison__table tbody tr:last-child td {
    border-bottom: none;
  }

  .vura-comparison__table tbody tr:hover {
    background: rgba(99, 119, 70, 0.04);
  }

  /* ── Icon cells ── */
  .vura-comparison__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .vura-comparison__icon--check {
    color: var(--vura-sage, #637746);
  }

  .vura-comparison__icon--cross {
    color: var(--vura-terracotta, #8D3B2D);
  }

  .vura-comparison__text-varies {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 500;
    color: var(--vura-paper-ink-muted, #4A5750);
    letter-spacing: 0.04em;
  }

  /* ── Mobile responsive ── */
  @media screen and (max-width: 749px) {
    .vura-comparison__heading {
      font-size: 30px;
      line-height: 36px;
    }

    .vura-comparison__header {
      margin-bottom: 28px;
    }

    .vura-comparison__table thead th {
      font-size: 11px;
      padding: 12px 10px;
      letter-spacing: 0.06em;
    }

    .vura-comparison__table tbody td {
      font-size: 13px;
      padding: 12px 10px;
      line-height: 20px;
    }

    .vura-comparison__icon svg {
      width: 18px;
      height: 18px;
    }
  }
</style>

<section class="vura-comparison">
  <div class="page-width">
    <header class="vura-comparison__header">
      <p class="vura-comparison__eyebrow">{{ section.settings.subheading | default: 'THE DIFFERENCE' }}</p>
      <h2 class="vura-comparison__heading">{{ section.settings.heading | default: 'Why Vura' }}</h2>
    </header>

    <table class="vura-comparison__table" role="table">
      <thead>
        <tr>
          <th scope="col">&nbsp;</th>
          <th scope="col">Vura</th>
          <th scope="col">Typical Body Spray</th>
        </tr>
      </thead>
      <tbody>
        {%- comment -%} Row 1: Natural-inspired ingredients {%- endcomment -%}
        <tr>
          <td>Natural-inspired ingredients</td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--check" aria-label="Yes">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
          </td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--cross" aria-label="No">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </span>
          </td>
        </tr>

        {%- comment -%} Row 2: Alum-based odour control {%- endcomment -%}
        <tr>
          <td>Alum-based odour control</td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--check" aria-label="Yes">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
          </td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--cross" aria-label="No">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </span>
          </td>
        </tr>

        {%- comment -%} Row 3: Harsh aerosol propellants {%- endcomment -%}
        <tr>
          <td>Harsh aerosol propellants</td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--cross" aria-label="No">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </span>
          </td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--check" aria-label="Yes">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
          </td>
        </tr>

        {%- comment -%} Row 4: No synthetic fragrances {%- endcomment -%}
        <tr>
          <td>No synthetic fragrances</td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--check" aria-label="Yes">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
          </td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--cross" aria-label="No">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </span>
          </td>
        </tr>

        {%- comment -%} Row 5: Designed for daily use {%- endcomment -%}
        <tr>
          <td>Designed for daily use</td>
          <td>
            <span class="vura-comparison__icon vura-comparison__icon--check" aria-label="Yes">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
          </td>
          <td>
            <span class="vura-comparison__text-varies">Varies</span>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

{% schema %}
{
  "name": "Vura Comparison Table",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow text",
      "default": "THE DIFFERENCE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Vura"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Vura Comparison Table"
    }
  ]
}
{% endschema %}
