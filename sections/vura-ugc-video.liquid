<style>
  .vura-ugc {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--vura-paper-deep, #EDE5D2);
    color: var(--vura-paper-ink, #1A2A22);
  }

  .vura-ugc__container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .vura-ugc__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .vura-ugc__eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--vura-paper-ink-muted, #4A5750);
    margin-bottom: 12px;
  }

  .vura-ugc__heading {
    font-family: var(--font-display, 'Roca One', Georgia, serif);
    font-size: clamp(26px, 4vw, 44px);
    line-height: 1.15;
    color: var(--vura-paper-ink, #1A2A22);
    margin: 0;
  }

  .vura-ugc__scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(26,42,34,0.2) transparent;
  }

  .vura-ugc__scroll::-webkit-scrollbar {
    height: 4px;
  }

  .vura-ugc__scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .vura-ugc__scroll::-webkit-scrollbar-thumb {
    background: rgba(26,42,34,0.2);
    border-radius: 2px;
  }

  .vura-ugc__card {
    flex: 0 0 260px;
    scroll-snap-align: start;
    border-radius: 16px !important;
    overflow: hidden;
    background: var(--vura-paper, #F8F3E7);
    border: 1px solid var(--border-on-paper, rgba(26,42,34,0.12));
    box-sizing: border-box;
    box-shadow: 0 4px 16px rgba(26,42,34,0.06);
    transition: transform 0.28s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.28s ease;
  }

  .vura-ugc__card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 12px 32px rgba(26,42,34,0.12);
  }

  .vura-ugc__media {
    position: relative;
    aspect-ratio: 9/16;
    background: var(--vura-forest, #162D24);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 12px;
    margin: 8px 8px 0 8px; /* Frame margin around top/sides of video */
  }

  .vura-ugc__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vura-ugc__play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.9;
    transition: opacity 200ms ease;
  }

  .vura-ugc__card:hover .vura-ugc__play-icon {
    opacity: 1;
  }

  .vura-ugc__play-icon svg {
    width: 20px;
    height: 20px;
    margin-left: 3px;
    color: var(--vura-forest, #162D24);
  }

  .vura-ugc__placeholder {
    color: rgba(255,255,255,0.4);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    text-align: center;
    padding: 20px;
    line-height: 1.5;
  }

  .vura-ugc__caption {
    padding: 12px 14px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    line-height: 1.45;
    color: var(--vura-paper-ink-muted, #4A5750);
  }

  @media (min-width: 750px) {
    .vura-ugc__card {
      flex: 0 0 220px;
    }
  }
</style>

<section class="vura-ugc" aria-labelledby="ugc-heading-{{ section.id }}">
  <div class="vura-ugc__container">
    <header class="vura-ugc__header">
      <p class="vura-ugc__eyebrow">REAL STORIES</p>
      <h2 class="vura-ugc__heading" id="ugc-heading-{{ section.id }}">
        {{ section.settings.heading }}
      </h2>
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="vura-ugc__scroll">
        {%- for block in section.blocks -%}
          <div class="vura-ugc__card" {{ block.shopify_attributes }}>
            <div class="vura-ugc__media">
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: autoplay: false, loop: true, muted: true, controls: true, preload: 'metadata' }}
              {%- else -%}
                <div class="vura-ugc__placeholder">
                  <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:8px;opacity:0.5;">
                    <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect>
                    <line x1="7" y1="2" x2="7" y2="22"></line>
                    <line x1="17" y1="2" x2="17" y2="22"></line>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <line x1="2" y1="7" x2="7" y2="7"></line>
                    <line x1="2" y1="17" x2="7" y2="17"></line>
                    <line x1="17" y1="7" x2="22" y2="7"></line>
                    <line x1="17" y1="17" x2="22" y2="17"></line>
                  </svg>
                  <br>
                  Video coming soon
                </div>
                <div class="vura-ugc__play-icon">
                  <svg viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            {%- if block.settings.caption != blank -%}
              <div class="vura-ugc__caption">{{ block.settings.caption }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center; color: var(--vura-paper-ink-muted); font-size: 14px; font-style: italic;">
        Real customer stories coming soon.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "VURA UGC Video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hear From Real Users"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": ""
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "VURA UGC Video",
      "blocks": [
        {
          "type": "video_card",
          "settings": {
            "caption": "\"Game-changer for my gym bag\" — Priya, Mumbai"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "caption": "\"No white marks, no irritation\" — Arjun, Bangalore"
          }
        },
        {
          "type": "video_card",
          "settings": {
            "caption": "\"My whole family uses it now\" — Meera, Delhi"
          }
        }
      ]
    }
  ]
}
{% endschema %}
