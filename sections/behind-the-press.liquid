<!-- Editorial Story Section with Parallax Stamps (Behind the Press) -->
<section class="story" id="story">
  <!-- Floating Stamps (Parallax driven by scroll script) -->
  <div class="stamp angle-a" data-parallax="0.18" style="top: 8%; left: 4%;">Batch 24·17·002</div>
  <div class="stamp angle-b dotted" data-parallax="-0.22" style="top: 22%; right: 6%;">Lot-traceable</div>
  <div class="stamp angle-c" data-parallax="0.30" style="bottom: 14%; left: 7%;"><span class="big">FILED</span>14 May 2026</div>
  <div class="stamp angle-d dotted" data-parallax="-0.16" style="bottom: 32%; right: 9%;">Single mineral</div>
  <div class="stamp angle-a" data-parallax="0.10" style="top: 56%; left: 38%;">No. 001</div>

  <div class="narrow">
    <div class="story-grid">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow | default: "From the archive" | escape }}</span>
        <h2>{{ section.settings.title | default: "Old things,<br>written down<br><em>carefully.</em>" }}</h2>
      </div>
      <div class="story-body">
        <p>{{ section.settings.p1 | default: "We started Vura because the things our grandmothers kept in tins — phitkari, the crystalline mineral salt — worked, and nothing on the shelf admitted to using them." | escape }}</p>
        <p>{{ section.settings.p2 | default: "The first formulation begins as an entry in the Mineral Archive: a single mineral, a documented intent, no more than three botanicals. The entry is dated. The lot is logged. The bottle carries the lot." | escape }}</p>
        <p class="small">{{ section.settings.p3 | default: "The archive is open. If you want to know what's in lot 24·17·002 — the ratio of phitkari to rose hydrosol, the pH after 48 hours, the supplier of the alum — write to us. We'll tell you. That's the whole point." | escape }}</p>
        <span class="story-signature">{{ section.settings.signature | default: "— Aanya & Vikram, founders" | escape }}</span>
      </div>
    </div>
  </div>
</section>

<style>
/* =====================================================================
   EDITORIAL STORY SECTION & PARALLAX STAMPS
   ===================================================================== */
.story {
  background: var(--vura-paper-deep);
  padding: var(--s-20) 0 var(--s-24);
  position: relative;
  overflow: hidden;
}
.stamp {
  position: absolute;
  font-family: var(--font-mono);
  color: var(--vura-terracotta);
  text-transform: uppercase;
  letter-spacing: var(--track-loose);
  font-size: 11px;
  padding: 10px 18px;
  border: 1.5px solid var(--vura-terracotta);
  will-change: transform;
  opacity: 0.85;
  pointer-events: none;
  background: var(--vura-paper-deep);
  box-shadow: 2px 2px 0 0 rgba(141, 59, 45, 0.15);
  z-index: 1;
}
.stamp.angle-a { transform: rotate(-8deg); }
.stamp.angle-b { transform: rotate(11deg); }
.stamp.angle-c { transform: rotate(-4deg); }
.stamp.angle-d { transform: rotate(14deg); }
.stamp.dotted { border-style: dashed; }
.stamp .big {
  font-family: var(--font-display);
  font-size: 22px;
  display: block;
  margin-bottom: 2px;
}

.story-grid {
  display: grid;
  grid-template-columns: 1fr 1.6fr;
  gap: var(--s-16);
  align-items: start;
  position: relative;
  z-index: 2;
}

.story h2 {
  font-family: var(--font-display);
  font-size: clamp(40px, 5.2vw, 80px);
  line-height: 0.96;
  color: var(--vura-forest-deep);
  margin: 0;
}
.story h2 em {
  font-style: normal;
  color: var(--vura-terracotta);
}

.story-body p {
  font-family: var(--font-display);
  font-size: 22px;
  line-height: 1.5;
  color: var(--vura-paper-ink);
  margin: 0 0 var(--s-6);
  max-width: 38ch;
}
.story-body p.small {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--vura-paper-ink-muted);
  line-height: 1.7;
  max-width: 56ch;
}
.story-signature {
  font-family: var(--font-display);
  font-size: 26px;
  color: var(--vura-terracotta);
  margin-top: var(--s-8);
  display: inline-block;
  transform: rotate(-3deg);
}

.narrow {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 24px;
}

@media (max-width: 991px) {
  .story-grid {
    grid-template-columns: 1fr;
    gap: var(--s-12);
  }
  .stamp {
    width: auto;
    padding: 6px 12px;
    font-size: 9px;
  }
}
</style>

{% schema %}
{
  "name": "Behind the Press",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From the archive"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Old things,<br>written down<br><em>carefully.</em>"
    },
    {
      "type": "textarea",
      "id": "p1",
      "label": "Paragraph 1",
      "default": "We started Vura because the things our grandmothers kept in tins — phitkari, the crystalline mineral salt — worked, and nothing on the shelf admitted to using them."
    },
    {
      "type": "textarea",
      "id": "p2",
      "label": "Paragraph 2",
      "default": "The first formulation begins as an entry in the Mineral Archive: a single mineral, a documented intent, no more than three botanicals. The entry is dated. The lot is logged. The bottle carries the lot."
    },
    {
      "type": "textarea",
      "id": "p3",
      "label": "Paragraph 3 (Small Font)",
      "default": "The archive is open. If you want to know what's in lot 24·17·002 — the ratio of phitkari to rose hydrosol, the pH after 48 hours, the supplier of the alum — write to us. We'll tell you. That's the whole point."
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Signature",
      "default": "— Aanya & Vikram, founders"
    }
  ],
  "presets": [
    {
      "name": "Behind the Press"
    }
  ]
}
{% endschema %}
