<section class="pillars-section">
  <div class="shell">
    <div class="pillars-grid">

      <div class="pillar-item">
        <img src="{{ 'icon-mineral.png' | asset_url }}" alt="" class="pillar-icon" aria-hidden="true">
        <div class="pillar-title">Powered by Natural Minerals</div>
        <div class="pillar-divider" aria-hidden="true"></div>
      </div>

      <div class="pillar-item">
        <img src="{{ 'icon-aloe-rose.png' | asset_url }}" alt="" class="pillar-icon" aria-hidden="true">
        <div class="pillar-title">Aloe and Rose Goodness</div>
        <div class="pillar-divider" aria-hidden="true"></div>
      </div>

      <div class="pillar-item">
        <img src="{{ 'icon-pure-drops.png' | asset_url }}" alt="" class="pillar-icon" aria-hidden="true">
        <div class="pillar-title">Pure &amp; Effective</div>
        <div class="pillar-divider" aria-hidden="true"></div>
      </div>

      <div class="pillar-item">
        <img src="{{ 'icon-made-in-india.png' | asset_url }}" alt="" class="pillar-icon" aria-hidden="true">
        <div class="pillar-title">Made in India with Care</div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Pillars",
  "presets": [
    { "name": "Brand Pillars" }
  ]
}
{% endschema %}
