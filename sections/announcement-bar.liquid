<div class="announcement-bar">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}">{{ section.settings.text | escape }}</a>
  {%- else -%}
    <span>{{ section.settings.text | escape }}</span>
  {%- endif -%}
  <span style="opacity:0.35">·</span>
  <span>MADE IN INDIA WITH CARE</span>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement",
      "default": "FREE SHIPPING ACROSS INDIA OVER ₹999"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}
