{%- style -%}
  .vfc { background: #ffffff; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
  .vfc__wrap { max-width: 760px; margin: 0 auto; padding: 0 1.5rem; }
  .vfc__img { width: 100%; height: auto; display: block; }
{%- endstyle -%}

<section class="vfc">
  <div class="vfc__wrap">
    <svg class="vfc__img" viewBox="0 0 680 430" xmlns="http://www.w3.org/2000/svg" role="img">
      <title>{{ section.settings.heading | escape }}</title>
      <desc>Four deodorant formats — roll-on, stick, cream and mist — compared across five categories, with the mist format highlighted in terracotta and a large VURA mist bottle on the right.</desc>

      <text x="40" y="44" font-family="var(--font-body, 'Inter', sans-serif)" font-size="11" font-weight="600" letter-spacing="2" fill="#8D3B2D">{{ section.settings.eyebrow | escape }}</text>
      <text x="40" y="76" font-family="var(--font-display, Georgia, serif)" font-size="24" fill="#1A2A22">{{ section.settings.heading | escape }}</text>

      <rect x="466" y="92" width="48" height="300" rx="10" fill="#F4E9E4"/>

      <circle cx="235" cy="104" r="7" fill="#1A2A22"/>
      <rect x="222" y="110" width="26" height="42" rx="12" fill="#1A2A22"/>
      <rect x="309" y="98" width="22" height="8" rx="2" fill="#1A2A22"/>
      <rect x="307" y="106" width="26" height="46" rx="10" fill="#1A2A22"/>
      <rect x="383" y="120" width="44" height="8" rx="3" fill="#1A2A22"/>
      <rect x="385" y="128" width="40" height="24" rx="6" fill="#1A2A22"/>
      <rect x="484" y="94" width="12" height="9" rx="1" fill="#8D3B2D"/>
      <rect x="496" y="97" width="7" height="4" rx="1" fill="#8D3B2D"/>
      <rect x="479" y="103" width="22" height="6" rx="3" fill="#8D3B2D"/>
      <rect x="478" y="109" width="24" height="43" rx="10" fill="#8D3B2D"/>

      <g font-family="var(--font-body, 'Inter', sans-serif)" font-size="12" text-anchor="middle">
        <text x="235" y="172" fill="#6E6E73">Roll-on</text>
        <text x="320" y="172" fill="#6E6E73">Stick</text>
        <text x="405" y="172" fill="#6E6E73">Cream</text>
        <text x="490" y="172" fill="#8D3B2D" font-weight="600">Mist</text>
      </g>

      <line x1="40" y1="188" x2="514" y2="188" stroke="#EEEEEE" stroke-width="1"/>

      <g font-family="var(--font-body, 'Inter', sans-serif)" font-size="12.5" fill="#6E6E73" text-anchor="end">
        <text x="196" y="214">Quick dry</text>
        <text x="196" y="254">Low residue</text>
        <text x="196" y="294">Touch-free</text>
        <text x="196" y="334">Travel-friendly</text>
        <text x="196" y="374">Even coverage</text>
      </g>

      <g>
        <circle cx="235" cy="210" r="5" fill="none" stroke="#E2E2E2" stroke-width="1.5"/>
        <circle cx="320" cy="210" r="5" fill="#D2D2D2"/>
        <circle cx="405" cy="210" r="5" fill="none" stroke="#E2E2E2" stroke-width="1.5"/>
        <circle cx="490" cy="210" r="6" fill="#8D3B2D"/>

        <circle cx="235" cy="250" r="5" fill="#D2D2D2"/>
        <circle cx="320" cy="250" r="5" fill="#D2D2D2"/>
        <circle cx="405" cy="250" r="5" fill="none" stroke="#E2E2E2" stroke-width="1.5"/>
        <circle cx="490" cy="250" r="6" fill="#8D3B2D"/>

        <circle cx="235" cy="290" r="5" fill="none" stroke="#E2E2E2" stroke-width="1.5"/>
        <circle cx="320" cy="290" r="5" fill="none" stroke="#E2E2E2" stroke-width="1.5"/>
        <circle cx="405" cy="290" r="5" fill="none" stroke="#E2E2E2" stroke-width="1.5"/>
        <circle cx="490" cy="290" r="6" fill="#8D3B2D"/>

        <circle cx="235" cy="330" r="5" fill="#1A2A22"/>
        <circle cx="320" cy="330" r="5" fill="#1A2A22"/>
        <circle cx="405" cy="330" r="5" fill="#D2D2D2"/>
        <circle cx="490" cy="330" r="6" fill="#8D3B2D"/>

        <circle cx="235" cy="370" r="5" fill="#D2D2D2"/>
        <circle cx="320" cy="370" r="5" fill="#D2D2D2"/>
        <circle cx="405" cy="370" r="5" fill="none" stroke="#E2E2E2" stroke-width="1.5"/>
        <circle cx="490" cy="370" r="6" fill="#8D3B2D"/>
      </g>

      <ellipse cx="592" cy="356" rx="44" ry="6" fill="#F2EAE7"/>
      <circle cx="580" cy="110" r="2.5" fill="#8D3B2D"/>
      <circle cx="600" cy="104" r="2" fill="#CBA197"/>
      <circle cx="606" cy="116" r="1.6" fill="#CBA197"/>
      <rect x="580" y="122" width="24" height="16" rx="3" fill="#1A2A22"/>
      <rect x="585" y="138" width="14" height="9" fill="#1A2A22"/>
      <rect x="556" y="147" width="72" height="205" rx="18" fill="#8D3B2D"/>
      <rect x="556" y="214" width="72" height="52" fill="#FFFFFF"/>
      <text x="592" y="240" text-anchor="middle" font-family="var(--font-display, Georgia, serif)" font-size="17" font-weight="700" fill="#8D3B2D">VURA</text>
      <text x="592" y="253" text-anchor="middle" font-family="var(--font-body, 'Inter', sans-serif)" font-size="7" letter-spacing="1.5" fill="#B8736A">MINERAL MIST</text>
      <text x="592" y="382" text-anchor="middle" font-family="var(--font-body, 'Inter', sans-serif)" font-size="11" fill="#1A2A22">{{ section.settings.caption | escape }}</text>
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "Vura Format Compare",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "WHY A MIST" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Four formats. One clean finish." },
    { "type": "text", "id": "caption", "label": "Caption under bottle", "default": "Only VURA: a touch-free mist" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 56 }
  ],
  "presets": [ { "name": "Vura Format Compare" } ],
  "enabled_on": { "templates": ["product", "index", "page"] }
}
{% endschema %}
