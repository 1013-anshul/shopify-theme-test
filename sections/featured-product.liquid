<section id="FeaturedProduct" class="pdp-section featured-product-section">
  <div class="container">

    {%- assign product = all_products[section.settings.product] | default: collections.all.products.first -%}

    {%- if product != blank -%}
      <div class="pdp-grid">

        <!-- Left: Product media column -->
        <div class="pdp-bottle-column">
          <div class="pdp-bottle-frame">

            <!-- Circular registry seal stamp with spin-hover -->
            <img src="{{ 'seal-mineral-archive.png' | asset_url }}" 
                 alt="Mineral Archive Registry" 
                 class="pdp-bottle-seal vura-spin-hover" 
                 aria-hidden="true">

            {%- if product.featured_image != blank -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" 
                   alt="{{ product.featured_image.alt | escape }}" 
                   class="pdp-main-image"
                   id="FeaturedProductImage-{{ section.id }}"
                   loading="lazy">
            {%- else -%}
              <img src="{{ 'vura-bottle-still.png' | asset_url }}" 
                   alt="" 
                   class="pdp-main-image" 
                   aria-hidden="true">
            {%- endif -%}

            <!-- Subtle floral background behind the product with drift/sway animation -->
            <img src="{{ 'flower-bouquet.png' | asset_url }}" 
                 alt="" 
                 class="pdp-bottle-floral-bg vura-drift" 
                 aria-hidden="true">

          </div>

          <!-- Thumbnail strip -->
          {%- if product.images.size > 1 -%}
            <div class="pdp-thumbnails">
              {%- for image in product.images -%}
                <button class="product-thumbnail{% if forloop.first %} active{% endif %}" 
                        data-image-src="{{ image | image_url: width: 600 }}"
                        id="FeaturedThumb-{{ section.id }}-{{ forloop.index }}">
                  <img src="{{ image | image_url: width: 120 }}" 
                       alt="{{ image.alt | escape }}">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <!-- Right: Info column / Buy Box -->
        <div class="pdp-info-column">
          
          <div class="eyebrow">Series 01 · {{ product.type | default: 'Single-Mineral' }}</div>

          <h2 class="pdp-product-title">
            {{ product.title }}
          </h2>
          
          {%- if product.metafields.vura.hindi != blank -%}
            <div class="pdp-product-hindi dev" lang="hi">
              {{ product.metafields.vura.hindi }}
            </div>
          {%- else -%}
            <div class="pdp-product-hindi dev" lang="hi">फिटकरी</div>
          {%- endif -%}

          <div id="ProductPrice-{{ section.id }}">
            <hr class="rule-dashed">
            <div class="pdp-price-line">
              {%- assign variant = product.selected_or_first_available_variant -%}
              {%- if variant.compare_at_price > variant.price -%}
                <span class="pdp-price price-sale" id="PriceDisplay-{{ section.id }}">
                  {{ variant.price | money }}
                </span>
                <span class="pdp-price-size price-compare" id="ComparePriceDisplay-{{ section.id }}">
                  {{ variant.compare_at_price | money }}
                </span>
              {%- else -%}
                <span class="pdp-price" id="PriceDisplay-{{ section.id }}">{{ variant.price | money }}</span>
                <span class="pdp-price-size price-compare" id="ComparePriceDisplay-{{ section.id }}" style="display:none;"></span>
              {%- endif -%}
              
              {%- if variant.unit_price_measurement -%}
                <span class="pdp-price-size" id="UnitPriceDisplay-{{ section.id }}">· {{ variant.unit_price_measurement.reference_value }}{{ variant.unit_price_measurement.reference_unit }}</span>
              {%- endif -%}
            </div>
          </div>

          <!-- Product description summary / short text above buy button -->
          <div class="pdp-description-short">
            {%- if product.description != blank -%}
              {{ product.description | strip_html | truncatewords: 30 }}
            {%- else -%}
              A single mineral block, pressed from natural mineral alum crystals. Calms the skin, tightens pores, and protects. Essential post-wash ritual.
            {%- endif -%}
          </div>

          <!-- Variant Selector (if multiple variants exist) -->
          {%- unless product.has_only_default_variant -%}
            <div id="VariantSelector-{{ section.id }}" class="pdp-variant-selector">
              {%- for option in product.options_with_values -%}
                <div class="pdp-variant-group">
                  <div class="eyebrow pdp-variant-label">{{ option.name }}</div>
                  <div class="pdp-variant-swatches">
                    {%- for value in option.values -%}
                      <label class="pdp-swatch-label">
                        <input type="radio"
                               name="options[{{ option.name }}]"
                               value="{{ value | escape }}"
                               class="variant-radio-{{ section.id }} pdp-swatch-input"
                               data-option-position="{{ option.position }}"
                               id="opt-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                               {% if option.selected_value == value %}checked{% endif %}>
                        <span class="variant-swatch">
                          {{ value }}
                        </span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <!-- Purchase Form -->
          <form method="post" action="/cart/add" id="product-form-{{ section.id }}">
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="ProductVariantId-{{ section.id }}">

            <div class="pdp-qty-row">
              <div class="qty-selector">
                <button type="button" class="qty-btn" onclick="var i=document.getElementById('qty-{{ section.id }}');var v=parseInt(i.value);if(v>1)i.value=v-1;" aria-label="Decrease quantity">&minus;</button>
                <input type="text" id="qty-{{ section.id }}" name="quantity" class="qty-input" value="1" aria-label="Quantity" readonly>
                <button type="button" class="qty-btn" onclick="var i=document.getElementById('qty-{{ section.id }}');i.value=parseInt(i.value)+1;" aria-label="Increase quantity">+</button>
              </div>
              <button type="submit" name="add" id="AddToCartBtn-{{ section.id }}" class="button button-primary"
                {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                {%- if product.selected_or_first_available_variant.available -%}
                  {{ 'products.product.add_to_order' | t }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </button>
            </div>

            <!-- Trust Badges & Shipping details -->
            <div class="pdp-trust-badges">
              <div class="pdp-trust-badge">
                <img src="{{ 'icon-pure-drops.png' | asset_url }}" alt="" aria-hidden="true">
                <span>Pure Drops</span>
              </div>
              <div class="pdp-trust-badge">
                <img src="{{ 'icon-mineral.png' | asset_url }}" alt="" aria-hidden="true">
                <span>100% Mineral</span>
              </div>
              <div class="pdp-trust-badge">
                <img src="{{ 'icon-made-in-india.png' | asset_url }}" alt="" aria-hidden="true">
                <span>Made In India</span>
              </div>
            </div>

            <div class="pdp-ship-note">
              <i data-lucide="truck" aria-hidden="true"></i>
              <span>Ships across India in 2&ndash;3 working days &middot; Free over ₹999</span>
            </div>
          </form>

          <!-- Accordion / Tabs -->
          <hr class="rule-dashed">
          <div class="pdp-tabs" id="PdpTabs-{{ section.id }}">
            <button class="pdp-tab active" data-tab="ritual-{{ section.id }}">Ritual</button>
            <button class="pdp-tab" data-tab="ingredients-{{ section.id }}">Ingredients</button>
            <button class="pdp-tab" data-tab="caution-{{ section.id }}">Caution</button>
          </div>

          <div class="pdp-tab-body" id="pdp-tab-ritual-{{ section.id }}">
            {%- if product.description != blank -%}
              {{ product.description }}
            {%- else -%}
              <p>Wet a small piece of phitkari. Pass it once across clean skin — after shaving, after a workout, after a long day. Let it air-dry. Do not rinse.</p>
            {%- endif -%}
          </div>

          <div class="pdp-tab-body" id="pdp-tab-ingredients-{{ section.id }}" style="display:none;">
            {%- if product.metafields.vura.ingredients != blank -%}
              {{ product.metafields.vura.ingredients }}
            {%- else -%}
              <p style="margin-bottom:1rem;">Five ingredients. No more.</p>
              <ul class="pdp-ingredients">
                <li><strong>Aqua</strong> &mdash; distilled water</li>
                <li><strong>Rosa Damascena Flower Water</strong> &mdash; copper-still hydrosol</li>
                <li><strong>Potassium Alum</strong> &mdash; the mineral</li>
                <li><strong>Aloe Barbadensis Leaf Extract</strong> &mdash; fresh, cold-pressed</li>
                <li><strong>Glycerin, Propanediol</strong> &mdash; gentle solvents</li>
              </ul>
            {%- endif -%}
          </div>

          <div class="pdp-tab-body" id="pdp-tab-caution-{{ section.id }}" style="display:none;">
            <p>For external use only. Avoid contact with eyes. If contact occurs, rinse thoroughly with water. Keep out of reach of children. Store in a cool, dry place away from direct sunlight.</p>
          </div>

        </div>

      </div>

      <!-- JSON product data for variant switcher -->
      <script type="application/json" id="ProductJson-{{ section.id }}">
        {{ product | json }}
      </script>

    {%- else -%}
      <div style="text-align:center;padding:5rem 0;border:1px dashed var(--border);border-radius:var(--r-3);">
        <p style="color:var(--fg-muted);">Please select a product in the section settings to display the buy box.</p>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product to Showcase"
    }
  ],
  "presets": [
    {
      "name": "Featured Product Buy Box",
      "category": "Product"
    }
  ]
}
{% endschema %}
