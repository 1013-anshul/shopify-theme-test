<div class="header-wrapper">
  <div class="header-inner">

    <!-- Brand Wordmark -->
    <a href="/" class="header-brand" aria-label="{{ shop.name }}">
      <span class="header-wordmark">VURA</span>
      <span class="header-devanagari dev" lang="hi">वूरा</span>
    </a>

    <!-- Navigation -->
    <nav id="HeaderNav" class="header-nav" role="navigation">
      {%- if section.settings.use_anchor_menu -%}
        <a href="#FeaturedProduct" class="header-nav-link">The Block</a>
        <a href="#FeaturedProduct" class="header-nav-link" data-action="open-ritual">The Ritual</a>
        <a href="#Pillars" class="header-nav-link">The Origin</a>
      {%- else -%}
        {%- for link in linklists[section.settings.menu].links -%}
          <a href="{{ link.url }}" 
             class="header-nav-link{% if link.active %} active{% endif %}"
             {% if link.current %}aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <a href="/search" class="header-icon-btn" aria-label="Search">
        <i data-lucide="search" style="width:18px;height:18px;stroke-width:1.5"></i>
      </a>

      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" 
           class="header-icon-btn" 
           aria-label="Account">
          <i data-lucide="user" style="width:18px;height:18px;stroke-width:1.5"></i>
        </a>
      {%- endif -%}

      <button class="header-icon-btn" onclick="window.theme.CartDrawer.open()" aria-label="Open cart">
        <i data-lucide="shopping-bag" style="width:18px;height:18px;stroke-width:1.5"></i>
        <span class="cart-pip" id="CartCount" {% if cart.item_count == 0 %}style="display:none"{% endif %}>
          {{ cart.item_count }}
        </span>
      </button>

      <!-- Mobile toggle -->
      <button class="header-mobile-toggle" 
              aria-label="Toggle menu"
              aria-expanded="false">
        <i data-lucide="menu" style="width:22px;height:22px;stroke-width:1.5"></i>
      </button>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_anchor_menu",
      "label": "Use One-Product Anchor Menu",
      "default": true
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
