<style>
  .vura-ingredients {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--vura-paper, #F8F3E7);
    color: var(--vura-paper-ink, #1A2A22);
  }

  .vura-ingredients__container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .vura-ingredients__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .vura-ingredients__eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--vura-paper-ink-muted, #4A5750);
    margin-bottom: 12px;
  }

  .vura-ingredients__heading {
    font-family: var(--font-display, 'Roca One', Georgia, serif);
    font-size: clamp(26px, 4vw, 44px);
    line-height: 1.15;
    color: var(--vura-paper-ink, #1A2A22);
    margin: 0;
  }

  .vura-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  @media (min-width: 750px) {
    .vura-ingredients__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }

  .vura-ingredients__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 16px;
    background: var(--vura-paper-deep, #EDE5D2);
    border: 1px solid var(--border-on-paper, rgba(26,42,34,0.16));
    border-radius: 6px;
    transition: box-shadow 220ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .vura-ingredients__card:hover {
    box-shadow: 0 8px 24px rgba(26,42,34,0.10);
  }

  .vura-ingredients__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(99, 119, 70, 0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    color: var(--vura-sage, #637746);
    flex-shrink: 0;
  }

  .vura-ingredients__icon svg {
    width: 32px;
    height: 32px;
  }

  .vura-ingredients__name {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--vura-paper-ink, #1A2A22);
    margin: 0 0 6px 0;
  }

  .vura-ingredients__desc {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    line-height: 1.5;
    color: var(--vura-paper-ink-muted, #4A5750);
    margin: 0;
  }

  @media (min-width: 750px) {
    .vura-ingredients__card {
      padding: 32px 20px;
    }

    .vura-ingredients__name {
      font-size: 17px;
    }
  }
</style>

<section class="vura-ingredients" aria-labelledby="ingredients-heading-{{ section.id }}">
  <div class="vura-ingredients__container">
    <header class="vura-ingredients__header">
      <p class="vura-ingredients__eyebrow">TRANSPARENCY</p>
      <h2 class="vura-ingredients__heading" id="ingredients-heading-{{ section.id }}">
        {{ section.settings.heading }}
      </h2>
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="vura-ingredients__grid">
        {%- for block in section.blocks -%}
          <article class="vura-ingredients__card" {{ block.shopify_attributes }}>
            <div class="vura-ingredients__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'crystal' -%}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M 22 16 L 26 36 L 18 48 L 12 36 Z"/>
                    <path d="M 22 16 L 26 36 L 30 16 L 26 8 Z"/>
                    <path d="M 30 16 L 38 36 L 30 48 L 26 36 Z"/>
                    <path d="M 38 16 L 46 36 L 50 16 L 42 8 Z"/>
                    <path d="M 46 36 L 52 48 L 56 36"/>
                    <path d="M 12 36 L 14 30 M 38 36 L 40 30 M 52 48 L 56 56"/>
                  </svg>
                {%- when 'leaf' -%}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M 32 56 C 32 40 24 32 14 28 C 22 32 30 38 32 50"/>
                    <path d="M 14 28 C 14 22 18 18 22 18 C 18 22 16 26 18 30"/>
                    <path d="M 32 56 C 32 38 38 28 50 24 C 42 28 36 34 34 46"/>
                    <path d="M 50 24 C 50 18 46 14 42 14 C 46 18 48 22 46 26"/>
                    <path d="M 26 38 C 24 38 22 40 22 42 C 26 42 28 40 28 38 Z"/>
                    <path d="M 36 32 C 34 32 32 34 32 36 C 36 36 38 34 38 32 Z"/>
                  </svg>
                {%- when 'drop' -%}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M 26 10 C 14 26 14 40 26 48 C 38 40 38 26 26 10 Z"/>
                    <path d="M 24 36 C 22 36 21 38 22 40"/>
                    <path d="M 44 22 C 36 32 36 42 44 48 C 52 42 52 32 44 22 Z"/>
                    <path d="M 42 38 C 41 38 40 40 41 41"/>
                  </svg>
                {%- when 'flower' -%}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="32" cy="32" r="6"/>
                    <ellipse cx="32" cy="18" rx="5" ry="10"/>
                    <ellipse cx="32" cy="46" rx="5" ry="10"/>
                    <ellipse cx="18" cy="32" rx="10" ry="5"/>
                    <ellipse cx="46" cy="32" rx="10" ry="5"/>
                  </svg>
              {%- endcase -%}
            </div>
            <h3 class="vura-ingredients__name">{{ block.settings.name }}</h3>
            <p class="vura-ingredients__desc">{{ block.settings.description }}</p>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "VURA Ingredients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's Inside"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient name",
          "default": "Ingredient"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Brief description of this ingredient"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "crystal", "label": "Crystal" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "drop", "label": "Drop" },
            { "value": "flower", "label": "Flower" }
          ],
          "default": "crystal"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "VURA Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "name": "Phitkari (Alum)",
            "description": "Traditional mineral salt for natural odour control",
            "icon": "crystal"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Aloe Vera",
            "description": "Soothing hydration for delicate skin",
            "icon": "leaf"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Rose Water",
            "description": "Gentle toning with a subtle natural fragrance",
            "icon": "flower"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Purified Water",
            "description": "Clean base, nothing synthetic",
            "icon": "drop"
          }
        }
      ]
    }
  ]
}
{% endschema %}
