{% comment %}
  VURA Hero Banner — one wide image with a left-aligned headline over the empty
  space. The whole banner links to the product. On desktop the image is capped
  to fit within the viewport (below the header); on mobile it keeps its full
  aspect ratio. Falls back to the bundled asset if no image set.
{% endcomment %}
{%- liquid
  assign heading = section.settings.heading
  assign eyebrow = section.settings.eyebrow
  assign link = section.settings.link
  if section.settings.image != blank
    assign hero_src = section.settings.image | image_url: width: 2200
    assign hero_w = section.settings.image.width
    assign hero_h = section.settings.image.height
  else
    assign hero_src = 'vura_hero_banner_light.jpg' | asset_url
    assign hero_w = 1672
    assign hero_h = 941
  endif
-%}
{%- style -%}
  .vura-herob { position: relative; width: 100%; background: #C9B99A; overflow: hidden; line-height: 0; }
  .vura-herob__link { display: block; text-decoration: none; color: inherit; }
  .vura-herob__img { display: block; width: 100%; height: auto; transition: filter 0.4s ease; }
  @media (min-width: 750px) {
    .vura-herob__img {
      height: calc(100vh - 190px);
      height: calc(100svh - 190px);
      max-height: 660px;
      min-height: 380px;
      object-fit: cover;
      object-position: center 42%;
    }
  }
  .vura-herob__link:hover .vura-herob__img { filter: brightness(0.97); }
  .vura-herob__text {
    position: absolute; left: 6%; top: 50%; transform: translateY(-50%);
    width: 42%; max-width: 640px; z-index: 2; line-height: 1.1;
  }
  .vura-herob__eyebrow {
    margin: 0 0 0.55em; font-family: var(--font-body, Inter, sans-serif);
    text-transform: uppercase; letter-spacing: 0.22em; font-weight: 600;
    color: var(--vura-terracotta, #8D3B2D); font-size: clamp(0.62rem, 1.45vw, 1.5rem);
  }
  .vura-herob__title {
    margin: 0; font-family: var(--font-display, Georgia, serif); font-weight: 700;
    color: var(--vura-forest, #162D24); line-height: 1.05; text-wrap: balance;
    font-size: clamp(1.35rem, 4.7vw, 5rem);
  }
{%- endstyle -%}

<section class="vura-herob">
  {%- if link != blank -%}<a class="vura-herob__link" href="{{ link }}" aria-label="{{ heading | default: 'VURA' | escape }}">{%- endif -%}
    <img
      class="vura-herob__img"
      src="{{ hero_src }}"
      alt="{{ heading | default: 'VURA' | escape }}"
      width="{{ hero_w }}"
      height="{{ hero_h }}"
      loading="eager"
      fetchpriority="high"
    >
    {%- if eyebrow != blank or heading != blank -%}
      <div class="vura-herob__text">
        {%- if eyebrow != blank -%}<p class="vura-herob__eyebrow">{{ eyebrow }}</p>{%- endif -%}
        {%- if heading != blank -%}<h1 class="vura-herob__title">{{ heading }}</h1>{%- endif -%}
      </div>
    {%- endif -%}
  {%- if link != blank -%}</a>{%- endif -%}
</section>

{% schema %}
{
  "name": "VURA Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image", "info": "Wide banner. Uses the bundled vura_hero_banner.webp if left empty." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Introducing" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Phitkari in a spray" },
    { "type": "url", "id": "link", "label": "Banner link", "info": "The whole banner links here (defaults to the product)." }
  ],
  "presets": [{ "name": "VURA Hero Banner" }]
}
{% endschema %}
