<section class="archive-note-section">
  <div class="shell-narrow archive-note-inner">
    
    <!-- Floating Floral Detail -->
    {%- if section.settings.show_floral -%}
      <img src="{% if section.settings.floral_image != blank %}{{ section.settings.floral_image | image_url: width: 320 }}{% else %}{{ 'flower-burgundy-tall.png' | asset_url }}{% endif %}" 
           alt="" 
           class="archive-note-floral" 
           loading="lazy"
           aria-hidden="true">
    {%- endif -%}

    <div class="eyebrow" style="margin-bottom: 18px;">{{ section.settings.eyebrow | escape }}</div>
    
    <h2 class="archive-note-heading">
      {{ section.settings.heading | escape }}
    </h2>
    
    <p class="archive-note-tagline">
      {{ section.settings.tagline | escape }}
    </p>

  </div>
</section>

{% schema %}
{
  "name": "Archive Note",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From the Mineral Archive"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Quote / Heading",
      "default": "We start each batch with one mineral, and a list of five ingredients we are willing to defend."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Made in India with Care"
    },
    {
      "type": "header",
      "content": "Floral Illustration decoration"
    },
    {
      "type": "checkbox",
      "id": "show_floral",
      "label": "Show Floral Illustration",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "floral_image",
      "label": "Floral Illustration Image",
      "info": "Fallback is flower-burgundy-tall.png from assets"
    }
  ],
  "presets": [
    {
      "name": "Archive Note",
      "category": "Brand"
    }
  ]
}
{% endschema %}
