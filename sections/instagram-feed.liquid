<!-- VURA Instagram Feed Section -->
<section id="InstagramFeed" class="vura-instagram-section">
  <div class="container">
    
    <div class="vura-instagram-header">
      <span class="eyebrow">{{ section.settings.eyebrow | default: "Social Archive" | escape }}</span>
      <h2 class="instagram-heading">{{ section.settings.title | default: "Follow our skincare ritual" | escape }}</h2>
      <p class="instagram-subtext">Join us on Instagram <a href="https://instagram.com/vura.official" target="_blank" class="instagram-handle">@vura.official</a> for stories of traditional distillation and batch release logs.</p>
    </div>

    <div class="vura-instagram-grid">
      
      <div class="instagram-item">
        <a href="https://instagram.com/vura.official" target="_blank" class="instagram-link">
          <img src="{{ '36f1b2ce-0cd8-420b-811b-b6e73a0e8dac.jpg' | asset_url }}" alt="VURA ritual post" class="instagram-img" loading="lazy">
          <div class="instagram-overlay">
            <i data-lucide="instagram" class="instagram-icon"></i>
          </div>
        </a>
      </div>

      <div class="instagram-item">
        <a href="https://instagram.com/vura.official" target="_blank" class="instagram-link">
          <img src="{{ '3fc61467-ca08-4dbe-8f99-ef379ff57e09.jpg' | asset_url }}" alt="VURA ritual post" class="instagram-img" loading="lazy">
          <div class="instagram-overlay">
            <i data-lucide="instagram" class="instagram-icon"></i>
          </div>
        </a>
      </div>

      <div class="instagram-item">
        <a href="https://instagram.com/vura.official" target="_blank" class="instagram-link">
          <img src="{{ 'a33fa202-206d-4abe-a0c7-cb55f2a601a2.jpg' | asset_url }}" alt="VURA ritual post" class="instagram-img" loading="lazy">
          <div class="instagram-overlay">
            <i data-lucide="instagram" class="instagram-icon"></i>
          </div>
        </a>
      </div>

      <div class="instagram-item">
        <a href="https://instagram.com/vura.official" target="_blank" class="instagram-link">
          <img src="{{ 'a9407fe8-c488-4a34-a534-cd945dfa6ea7.jpg' | asset_url }}" alt="VURA ritual post" class="instagram-img" loading="lazy">
          <div class="instagram-overlay">
            <i data-lucide="instagram" class="instagram-icon"></i>
          </div>
        </a>
      </div>

    </div>

  </div>
</section>

<style>
.vura-instagram-section {
  padding: 80px 0;
  background-color: var(--vura-paper);
  border-top: 1px dashed var(--border-on-paper);
}

.vura-instagram-header {
  text-align: center;
  margin-bottom: var(--s-10);
  max-width: 600px;
  margin-inline: auto;
}

.instagram-heading {
  font-family: var(--font-display);
  font-size: clamp(32px, 4vw, 44px);
  color: var(--vura-forest-deep);
  margin: var(--s-2) 0;
}

.instagram-subtext {
  font-size: 13px;
  color: var(--vura-paper-ink-muted);
}

.instagram-handle {
  font-weight: 600;
  color: var(--vura-terracotta);
  border-bottom: 1px solid var(--vura-terracotta);
}

.instagram-handle:hover {
  color: var(--vura-burgundy);
  border-color: var(--vura-burgundy);
}

.vura-instagram-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--s-4);
}

.instagram-item {
  position: relative;
  aspect-ratio: 1/1;
  overflow: hidden;
  border-radius: var(--r-3);
  border: 1px solid var(--border-on-paper-soft);
  box-shadow: var(--shadow-sm);
}

.instagram-link {
  display: block;
  width: 100%;
  height: 100%;
  border-bottom: none;
}

.instagram-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--t-slow) var(--ease-out);
}

.instagram-overlay {
  position: absolute;
  inset: 0;
  background: rgba(14, 33, 24, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity var(--t-base) var(--ease-out);
  z-index: 2;
}

.instagram-icon {
  width: 24px;
  height: 24px;
  color: var(--vura-cream);
  stroke-width: 1.5;
  transform: scale(0.9);
  transition: transform var(--t-base) var(--ease-out);
}

.instagram-item:hover .instagram-img {
  transform: scale(1.05);
}

.instagram-item:hover .instagram-overlay {
  opacity: 1;
}

.instagram-item:hover .instagram-icon {
  transform: scale(1);
}

@media (max-width: 768px) {
  .vura-instagram-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>

{% schema %}
{
  "name": "Instagram Feed Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Social Archive"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "Follow our skincare ritual"
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed Grid"
    }
  ]
}
{% endschema %}
