<section class="pdp-section">
  <div class="shell">

    <a href="{{ routes.root_url }}collections/all" class="button button-ghost" style="margin-bottom:2.5rem;display:inline-flex;">
      &larr; Back to the Archive
    </a>

    <div class="pdp-grid">

      <!-- Left: Product media column -->
      <div class="pdp-bottle-column">
        <div class="pdp-bottle-frame">

          <img src="{{ 'seal-mineral-archive.png' | asset_url }}" 
               alt="Mineral Archive Registry" 
               class="pdp-bottle-seal" 
               aria-hidden="true">

          {%- if product.featured_image != blank -%}
            <img src="{{ product.featured_image | image_url: width: 600 }}" 
                 alt="{{ product.featured_image.alt | escape }}" 
                 class="pdp-main-image"
                 id="MainProductImage"
                 loading="eager">
          {%- else -%}
            <img src="{{ 'vura-bottle-still.png' | asset_url }}" 
                 alt="" 
                 class="pdp-main-image" 
                 aria-hidden="true">
          {%- endif -%}

          <!-- Subtle floral background behind the product -->
          <img src="{{ 'flower-bouquet.png' | asset_url }}" 
               alt="" 
               class="pdp-bottle-floral-bg" 
               style="opacity: 0.25;"
               aria-hidden="true">

        </div>

        <!-- Thumbnail strip -->
        {%- if product.images.size > 1 -%}
          <div style="display:flex;gap:0.5rem;margin-top:1rem;overflow-x:auto;padding-bottom:0.25rem;">
            {%- for image in product.images -%}
              <button class="pdp-thumb{% if forloop.first %} active{% endif %}" 
                      data-src="{{ image | image_url: width: 600 }}"
                      style="width:64px;height:64px;border:1px solid var(--border-soft);border-radius:var(--r-2);overflow:hidden;padding:0;cursor:pointer;background:var(--vura-forest-lift);flex-shrink:0;transition:border-color var(--t-fast);">
                <img src="{{ image | image_url: width: 120 }}" 
                     alt="{{ image.alt | escape }}" 
                     style="width:100%;height:100%;object-fit:cover;">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right: Info column -->
      <div class="pdp-info-column">

        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
          {%- case block.type -%}

            {%- when '@app' -%}
              {% render block %}

            {%- when 'eyebrow' -%}
              <div class="eyebrow">Series 01 · {{ product.type }}</div>

            {%- when 'title' -%}
              <h1 class="pdp-product-title vura-wordmark" style="color:var(--fg);text-shadow:none;">
                {{ product.title }}
              </h1>
              {%- if product.metafields.vura.hindi != blank -%}
                <div class="pdp-product-hindi dev" lang="hi">
                  {{ product.metafields.vura.hindi }}
                </div>
              {%- endif -%}

            {%- when 'price' -%}
              <div id="ProductPrice-{{ section.id }}">
                <hr class="rule-dashed">
                <div class="pdp-price-line">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="pdp-price" style="color:var(--vura-saffron);">
                      {{ product.price | money }}
                    </span>
                    <span class="pdp-price-size" style="text-decoration:line-through;">
                      {{ product.compare_at_price | money }}
                    </span>
                  {%- else -%}
                    <span class="pdp-price">{{ product.price | money }}</span>
                  {%- endif -%}
                  {%- if product.selected_or_first_available_variant.unit_price_measurement -%}
                    <span class="pdp-price-size">· {{ product.selected_or_first_available_variant.unit_price_measurement.reference_value }}{{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}</span>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'variant_picker' -%}
              {%- unless product.has_only_default_variant -%}
                <div>
                  {%- for option in product.options_with_values -%}
                    <div style="margin-bottom:1rem;">
                      <div class="eyebrow" style="margin-bottom:0.5rem;">{{ option.name }}</div>
                      <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
                        {%- for value in option.values -%}
                          <label style="display:inline-flex;align-items:center;">
                            <input type="radio"
                                   name="options[{{ option.name }}]"
                                   value="{{ value | escape }}"
                                   id="opt-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                                   {% if option.selected_value == value %}checked{% endif %}
                                   style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);">
                            <span style="display:inline-flex;align-items:center;height:40px;padding:0 1rem;border:1px solid var(--border);border-radius:var(--r-2);font-size:var(--size-sm);color:var(--fg-muted);cursor:pointer;transition:all var(--t-fast) var(--ease-out);">
                              {{ value }}
                            </span>
                          </label>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endunless -%}

            {%- when 'buy_buttons' -%}
              <form method="post" action="/cart/add" id="product-form-{{ section.id }}">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="ProductVariantId-{{ section.id }}">

                <div class="pdp-qty-row">
                  <div class="qty-selector">
                    <button type="button" class="qty-btn" onclick="var i=document.getElementById('qty-{{ section.id }}');var v=parseInt(i.value);if(v>1)i.value=v-1;" aria-label="Decrease quantity">&minus;</button>
                    <input type="text" id="qty-{{ section.id }}" name="quantity" class="qty-input" value="1" aria-label="Quantity">
                    <button type="button" class="qty-btn" onclick="var i=document.getElementById('qty-{{ section.id }}');i.value=parseInt(i.value)+1;" aria-label="Increase quantity">+</button>
                  </div>
                  <button type="submit" name="add" class="button button-primary" style="flex:1;"
                    {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                    {%- if product.selected_or_first_available_variant.available -%}
                      {{ 'products.product.add_to_order' | t }}
                    {%- else -%}
                      {{ 'products.product.sold_out' | t }}
                    {%- endif -%}
                  </button>
                </div>

                <div class="pdp-ship-note">
                  <i data-lucide="truck" style="width:16px;height:16px;stroke-width:1.5;color:var(--fg-faint);flex-shrink:0;"></i>
                  <span>Ships across India in 2&ndash;3 working days &middot; Free over ₹999</span>
                </div>
              </form>

            {%- when 'tabs' -%}
              <hr class="rule-dashed">
              <div class="pdp-tabs" id="PdpTabs-{{ section.id }}">
                <button class="pdp-tab active" data-tab="ritual">Ritual</button>
                <button class="pdp-tab" data-tab="ingredients">Ingredients</button>
                <button class="pdp-tab" data-tab="caution">Caution</button>
              </div>

              <div class="pdp-tab-body" id="pdp-tab-ritual-{{ section.id }}">
                {%- if product.description != blank -%}
                  {{ product.description }}
                {%- else -%}
                  <p>Wet a small piece of phitkari. Pass it once across clean skin — after shaving, after a workout, after a long day. Let it air-dry. Do not rinse.</p>
                {%- endif -%}
              </div>

              <div class="pdp-tab-body" id="pdp-tab-ingredients-{{ section.id }}" style="display:none;">
                {%- if product.metafields.vura.ingredients != blank -%}
                  {{ product.metafields.vura.ingredients }}
                {%- else -%}
                  <p style="margin-bottom:1rem;">Five ingredients. No more.</p>
                  <ul class="pdp-ingredients">
                    <li><strong>Aqua</strong> &mdash; distilled water</li>
                    <li><strong>Rosa Damascena Flower Water</strong> &mdash; copper-still hydrosol</li>
                    <li><strong>Potassium Alum</strong> &mdash; the mineral</li>
                    <li><strong>Aloe Barbadensis Leaf Extract</strong> &mdash; fresh, cold-pressed</li>
                    <li><strong>Glycerin, Propanediol</strong> &mdash; gentle solvents</li>
                  </ul>
                {%- endif -%}
              </div>

              <div class="pdp-tab-body" id="pdp-tab-caution-{{ section.id }}" style="display:none;">
                <p>For external use only. Avoid contact with eyes. If contact occurs, rinse thoroughly with water. Keep out of reach of children. Store in a cool, dry place away from direct sunlight.</p>
              </div>

              <script>
                (function(){
                  var tabs = document.querySelectorAll('#PdpTabs-{{ section.id }} .pdp-tab');
                  tabs.forEach(function(btn){
                    btn.addEventListener('click', function(){
                      tabs.forEach(function(b){ b.classList.remove('active'); });
                      btn.classList.add('active');
                      ['ritual','ingredients','caution'].forEach(function(id){
                        var el = document.getElementById('pdp-tab-'+id+'-{{ section.id }}');
                        if(el) el.style.display = (id === btn.dataset.tab) ? 'block' : 'none';
                      });
                    });
                  });
                })();
              </script>

          {%- endcase -%}
          </div>
        {%- endfor -%}

      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Product Information",
  "blocks": [
    { "type": "@app" },
    { "type": "eyebrow", "name": "Series Label", "limit": 1 },
    { "type": "title",   "name": "Title", "limit": 1 },
    { "type": "price",   "name": "Price", "limit": 1 },
    { "type": "variant_picker", "name": "Variant Picker", "limit": 1 },
    { "type": "buy_buttons", "name": "Buy Buttons", "limit": 1 },
    { "type": "tabs", "name": "Ritual / Ingredients / Caution", "limit": 1 }
  ],
  "default": {
    "blocks": [
      { "type": "eyebrow" },
      { "type": "title" },
      { "type": "price" },
      { "type": "variant_picker" },
      { "type": "buy_buttons" },
      { "type": "tabs" }
    ]
  }
}
{% endschema %}
