<section class="page-section container" style="padding: 4rem 0;">
  <div style="max-width: 800px; margin: 0 auto;">
    <h1 style="font-size: 2.5rem; margin-bottom: 2rem; text-align: center;">{{ page.title }}</h1>
    <div class="page-content text-muted" style="line-height: 1.8; font-size: 1.05rem;">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content"
}
{% endschema %}
