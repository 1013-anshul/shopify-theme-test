{%- paginate collection.products by section.settings.products_per_page -%}
<section class="collection-page container" style="padding: 4rem 0;">
  
  <!-- Collection Info Banner -->
  <div class="collection-header" style="margin-bottom: 3rem; text-align: center;">
    <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-description text-muted" style="max-width: 700px; margin: 0 auto; line-height: 1.6;">
        {{ collection.description }}
      </div>
    {%- endif -%}
  </div>

  <!-- Product Grid -->
  <div class="grid grid-{{ section.settings.columns_desktop }}">
    {%- for product in collection.products -%}
      {%- render 'card-product', card_product: product -%}
    {%- else -%}
      <div class="text-center" style="grid-column: 1 / -1; padding: 4rem 0;">
        <p class="text-muted" style="font-size: 1.2rem;">No products found in this collection.</p>
      </div>
    {%- endfor -%}
  </div>

  <!-- Pagination Links -->
  {%- if paginate.pages > 1 -%}
    <div class="pagination flex flex-center" style="margin-top: 4rem; gap: 1.5rem; font-size: 1.1rem;">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="button button-secondary">&laquo; Previous</a>
      {%- endif -%}
      
      <span class="pagination-page text-muted">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>

      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="button button-secondary">Next &raquo;</a>
      {%- endif -%}
    </div>
  {%- endif -%}

</section>
{%- endpaginate -%}

<style>
  .pagination a {
    padding: 0.5rem 1.2rem;
  }
</style>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Columns on Desktop"
    }
  ]
}
{% endschema %}
