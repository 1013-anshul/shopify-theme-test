<!-- Unified Product Hero & Specifications (Tactile Apothecary Theme) -->
{%- assign product = all_products[section.settings.product] | default: collections.all.products.first -%}

<div class="vura-hero-explorer-wrapper featured-product-section" id="VuraProductExplorer-{{ section.id }}">
  
  <!-- Hero Column Split -->
  <section class="hero-section">
    <div class="container hero-container">
      <div class="hero-main-grid">
        
        <!-- Left: Product Media Gallery Frame (drift floral overlay + spin seal) -->
        <div class="pdp-bottle-column">
          <div class="pdp-bottle-frame">
            <!-- Circular registry seal stamp with spin-hover -->
            <img src="{{ 'seal-mineral-archive.png' | asset_url }}" 
                 alt="Mineral Archive Registry" 
                 class="pdp-bottle-seal vura-spin-hover" 
                 aria-hidden="true"
                 width="120"
                 height="120">

            {%- if product != blank and product.featured_image != blank -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" 
                   alt="{{ product.featured_image.alt | escape }}" 
                   class="pdp-main-image"
                   id="HeroProductImage-{{ section.id }}"
                   width="600"
                   height="750"
                   loading="eager">
            {%- else -%}
              <img src="{{ 'vura-bottle-still.png' | asset_url }}" 
                   alt="Vura underarm mist bottle" 
                   class="pdp-main-image" 
                   aria-hidden="true"
                   width="600"
                   height="750"
                   loading="eager">
            {%- endif -%}

            <!-- Subtle floral background behind the product with drift/sway animation -->
            <img src="{{ 'flower-bouquet.png' | asset_url }}" 
                 alt="" 
                 class="pdp-bottle-floral-bg vura-drift" 
                 aria-hidden="true"
                 width="400"
                 height="500">
          </div>
        </div>

        <!-- Right: Copy & Buy Box Box -->
        <div class="hero-copy">
          <span class="eyebrow">{{ section.settings.hero_eyebrow | default: "Natural deodorant, slowly made" | escape }}</span>
          <h1 class="hero-h1">{{ section.settings.hero_title | default: "A mineral shield for <em>freshness</em>." }}</h1>
          
          <!-- Judge.me Review Badge Placeholder -->
          <div class="jdgm-widget jdgm-preview-badge" style="margin-top: 5px; margin-bottom: 5px; display: flex; align-items: center; gap: 6px; cursor: pointer;">
            <span class="jdgm-prev-badge__stars" style="color: #FFC820; display: inline-flex; gap: 2px;">
              <i data-lucide="star" style="width: 14px; height: 14px; fill: #FFC820; stroke-width: 1.5;"></i>
              <i data-lucide="star" style="width: 14px; height: 14px; fill: #FFC820; stroke-width: 1.5;"></i>
              <i data-lucide="star" style="width: 14px; height: 14px; fill: #FFC820; stroke-width: 1.5;"></i>
              <i data-lucide="star" style="width: 14px; height: 14px; fill: #FFC820; stroke-width: 1.5;"></i>
              <i data-lucide="star" style="width: 14px; height: 14px; fill: #FFC820; stroke-width: 1.5;"></i>
            </span>
            <span class="jdgm-prev-badge__text" style="color: var(--vura-cream-dim); font-size: 12px; font-family: var(--font-mono);">4.9/5 (182 reviews)</span>
          </div>
          
          {%- if product != blank -%}
            <div class="pdp-product-hindi dev" lang="hi" style="margin-top: -10px; margin-bottom: 5px; color: var(--vura-saffron); font-size: 16px; letter-spacing: 0.2em;">
              {{ product.metafields.vura.hindi | default: "फिटकरी" }}
            </div>
          {%- endif -%}

          <p class="hero-lede">{{ section.settings.hero_text | default: "Vura underarm mist starts with raw geothermal alum crystals and organic botanicals to prevent body odor. No aluminum chlorohydrate. No parabens. Just the archive." | escape }}</p>
          
          {%- if product != blank -%}
            <!-- Price Display -->
            <div id="ProductPrice-{{ section.id }}" style="margin: 15px 0 10px 0;">
              <div class="pdp-price-line">
                {%- assign variant = product.selected_or_first_available_variant -%}
                {%- if variant.compare_at_price > variant.price -%}
                  <span class="pdp-price price-sale" id="PriceDisplay-{{ section.id }}" style="font-size: 28px; font-family: var(--font-display); color: var(--vura-cream);">
                    {{ variant.price | money }}
                  </span>
                  <span class="pdp-price-size price-compare" id="ComparePriceDisplay-{{ section.id }}" style="font-size: 18px; text-decoration: line-through; color: var(--vura-cream-mute); margin-left: 10px;">
                    {{ variant.compare_at_price | money }}
                  </span>
                {%- else -%}
                  <span class="pdp-price" id="PriceDisplay-{{ section.id }}" style="font-size: 28px; font-family: var(--font-display); color: var(--vura-cream);">{{ variant.price | money }}</span>
                  <span class="pdp-price-size price-compare" id="ComparePriceDisplay-{{ section.id }}" style="display:none; font-size: 18px; text-decoration: line-through; color: var(--vura-cream-mute); margin-left: 10px;"></span>
                {%- endif -%}
              </div>
            </div>

            <!-- Variant Radio Selector -->
            {%- unless product.has_only_default_variant -%}
              <div id="VariantSelector-{{ section.id }}" class="pdp-variant-selector" style="margin: 20px 0 15px 0;">
                {%- for option in product.options_with_values -%}
                  <div class="pdp-variant-group" style="margin-bottom: 15px;">
                    <div class="eyebrow pdp-variant-label" style="font-size: 10px; margin-bottom: 6px;">{{ option.name }}</div>
                    <div class="pdp-variant-swatches" style="display: flex; gap: 8px;">
                      {%- for value in option.values -%}
                        <label class="pdp-swatch-label" style="cursor: pointer; display: inline-block; position: relative;">
                          <input type="radio"
                                 name="options[{{ option.name }}]"
                                 value="{{ value | escape }}"
                                 class="variant-radio-{{ section.id }} pdp-swatch-input"
                                 data-option-position="{{ option.position }}"
                                 id="opt-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                                 {% if option.selected_value == value %}checked{% endif %}
                                 style="position: absolute; opacity: 0; width: 0; height: 0;">
                          <span class="variant-swatch" style="display: inline-block; padding: 6px 16px; border: 1px solid var(--vura-hairline); border-radius: var(--r-pill); color: var(--vura-cream-dim); font-size: 12px; transition: all 0.2s;">
                            {{ value }}
                          </span>
                        </label>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- endunless -%}

            <!-- Purchase Form -->
            <form method="post" action="/cart/add" id="product-form-{{ section.id }}" style="margin: 20px 0 10px 0;">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="ProductVariantId-{{ section.id }}">
              
              <div class="pdp-qty-row" style="display: flex; gap: 15px; align-items: center; margin-bottom: 15px;">
                <div class="qty-selector" style="display: flex; align-items: center; border: 1px solid var(--vura-hairline); border-radius: var(--r-pill); padding: 4px; background: rgba(0,0,0,0.15);">
                  <button type="button" class="qty-btn" onclick="var i=document.getElementById('qty-{{ section.id }}');var v=parseInt(i.value);if(v>1)i.value=v-1;" aria-label="Decrease quantity" style="background: none; border: none; color: var(--vura-cream-dim); width: 30px; height: 30px; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center;">&minus;</button>
                  <input type="text" id="qty-{{ section.id }}" name="quantity" class="qty-input" value="1" aria-label="Quantity" readonly style="background: none; border: none; color: var(--vura-cream); width: 30px; text-align: center; font-size: 14px; font-weight: 600; padding: 0; outline: none;">
                  <button type="button" class="qty-btn" onclick="var i=document.getElementById('qty-{{ section.id }}');i.value=parseInt(i.value)+1;" aria-label="Increase quantity" style="background: none; border: none; color: var(--vura-cream-dim); width: 30px; height: 30px; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center;">+</button>
                </div>
                
                <button type="submit" name="add" id="AddToCartBtn-{{ section.id }}" class="btn-press lg" style="flex: 1; min-height: 48px; border-radius: var(--r-pill);"
                  {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                  {%- if product.selected_or_first_available_variant.available -%}
                    Add to Order &middot; {{ product.selected_or_first_available_variant.price | money }}
                  {%- else -%}
                    {{ 'products.product.sold_out' | t }}
                  {%- endif -%}
                </button>
              </div>

              <!-- Fastrr Headless Quick Checkout Button -->
              <div class="fastrr-checkout-container" style="margin-bottom: 20px; position: relative; width: 100%; margin-top: 25px;">
                <div class="sr-discount-label-mock" style="position: absolute; top: -11px; left: 16px; background: #0E2118; color: #7DAB62; font-size: 9px; padding: 2px 10px; border-radius: 3px; font-weight: 600; letter-spacing: 0.05em; z-index: 2; border: 1px solid var(--vura-hairline-soft);">
                  EXTRA 3% OFF ON PREPAID ORDERS
                </div>
                <button type="submit" name="add" class="sr-headless-checkout-btn" style="width: 100%; min-height: 52px; background: #7DAB62; color: #fff; border: 1px solid #7DAB62; border-radius: var(--r-pill); font-family: var(--font-body); font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background 0.2s, transform 0.2s; box-shadow: 0 4px 15px rgba(125, 171, 98, 0.25);">
                  <span>Direct Checkout &middot; UPI / COD</span>
                  <i data-lucide="arrow-right" style="width: 16px; height: 16px; stroke-width: 2;"></i>
                </button>
              </div>

              <!-- Ship details -->
              <div class="pdp-ship-note" style="font-size: 11px; color: var(--vura-cream-mute); display: flex; align-items: center; gap: 8px;">
                <i data-lucide="truck" aria-hidden="true" style="width: 14px; height: 14px; color: var(--vura-saffron);"></i>
                <span>Ships across India in 2&ndash;3 working days &middot; Free over ₹999</span>
              </div>
            </form>
          {%- else -%}
            <!-- Fallback Buy Link if no product -->
            <div class="hero-actions" style="margin: 25px 0 10px 0;">
              <a href="#SpecsRegistry" class="btn-press lg">Order Series 01 · ₹600</a>
              <a href="#SpecsRegistry" class="btn-link">Read the formulation →</a>
            </div>
          {%- endif -%}

          <div class="hero-stats" style="margin-top: 30px;">
            <div class="stat"><span class="num">01</span><span class="label">Mineral active</span></div>
            <div class="stat"><span class="num">24h</span><span class="label">Odor control</span></div>
            <div class="stat"><span class="num">100<em>·</em>ml</span><span class="label">Per bottle</span></div>
          </div>
        </div>
      </div>

      <!-- Hero Bottom Trust Indicators -->
      <div class="hero-trust-bar" style="margin-top: 50px;">
        <div class="trust-bar-wrapper">
          <div class="trust-item">
            <i data-lucide="shield-check"></i>
            <span>Active Minerals</span>
          </div>
          <div class="trust-item">
            <i data-lucide="droplet"></i>
            <span>Copper-Still Rosewater</span>
          </div>
          <div class="trust-item">
            <i data-lucide="leaf"></i>
            <span>Wild Aloe Infused</span>
          </div>
          <div class="trust-item">
            <i data-lucide="package-check"></i>
            <span>24h Odor Shield</span>
          </div>
          <div class="trust-item">
            <i data-lucide="award"></i>
            <span>Zero Toxic Chemicals</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bento specs & weight metrics -->
  <section id="SpecsRegistry" class="vura-3d-section" style="opacity: 1; visibility: visible; position: relative; height: auto; padding: 100px 0; background: var(--vura-forest-deep); border-top: 1px solid var(--vura-hairline-soft);">
    <div class="container">
      <div class="vura-3d-layout" style="display: grid; grid-template-columns: 1fr 1.1fr; gap: 60px; align-items: start;">
        
        <!-- Left: specs -->
        <div class="vura-layout-column vura-layout-left" style="display: flex; flex-direction: column; gap: 30px;">
          <div>
            <p class="specs-eyebrow">{{ section.settings.specs_eyebrow | default: "Registry Entry No. 001" | escape }}</p>
            <h3 class="specs-title" style="font-family: var(--font-display); font-size: 38px; color: var(--vura-cream); margin: 10px 0;">{{ product.title | default: "Phitkari Spray" | escape }}</h3>
            <p class="specs-desc" style="color: var(--vura-cream-dim); font-size: 14px; line-height: 1.6;">{{ product.description | strip_html | truncatewords: 30 | default: "Crystalline mineral salt bar spritz bottled in small batches." | escape }}</p>
          </div>
          <div style="border-left: 2px solid var(--vura-terracotta); padding-left: 20px; background: rgba(22, 45, 36, 0.4); padding-top: 15px; padding-bottom: 15px; border-radius: 0 var(--r-3) var(--r-3) 0;">
            <p class="ingredients-eyebrow" style="font-size: 11px; text-transform: uppercase; color: var(--vura-saffron); font-family: var(--font-mono); margin-bottom: 8px;">Registry specifications</p>
            <p class="ingredients-desc" style="font-family: var(--font-mono); font-size: 11px; line-height: 1.8; color: var(--vura-cream-dim);">
              <b>LOT NUMBER:</b> {{ section.settings.lot_number | default: "24·17·002" | escape }}<br>
              <b>BOTTLED:</b> {{ section.settings.bottled_date | default: "14 May 2026" | escape }}<br>
              <b>REGISTRY:</b> {{ section.settings.registry_info | default: "Series 01 / Batch 02" | escape }}<br>
              <b>ORIGIN:</b> Hyderabad, IN
            </p>
          </div>
          
          <span class="vura-small-note" style="font-family: var(--font-mono); font-size: 10px; color: var(--vura-cream-mute); text-transform: uppercase; letter-spacing: 0.1em;">Series 02 formulation in registry preparation.</span>
        </div>

        <!-- Right: formulation log table -->
        <div class="vura-layout-column vura-layout-right" style="background: var(--vura-forest); padding: 30px; border-radius: var(--r-3); border: 1px solid var(--vura-hairline-soft);">
          <div>
            <p class="intro-eyebrow" style="font-size: 11px; text-transform: uppercase; color: var(--vura-saffron); font-family: var(--font-mono); margin-bottom: 15px;">Formulation log · weight metrics</p>
            <div class="formulation-mini-table" style="display: flex; flex-direction: column; margin-bottom: 15px;">
              <div class="form-mini-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--vura-hairline-soft); font-size: 13px;">
                <span class="name" style="font-family: var(--font-display); color: var(--vura-cream);">Rosa damascena hydrosol</span>
                <span class="percent" style="font-family: var(--font-mono); color: var(--vura-saffron);">68.20%</span>
              </div>
              <div class="form-mini-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--vura-hairline-soft); font-size: 13px;">
                <span class="name" style="font-family: var(--font-display); color: var(--vura-cream);">Aloe barbadensis leaf extract</span>
                <span class="percent" style="font-family: var(--font-mono); color: var(--vura-saffron);">22.40%</span>
              </div>
              <div class="form-mini-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--vura-hairline-soft); font-size: 13px;">
                <span class="name" style="font-family: var(--font-display); color: var(--vura-cream);">Hamamelis virginiana distillate</span>
                <span class="percent" style="font-family: var(--font-mono); color: var(--vura-saffron);">6.10%</span>
              </div>
              <div class="form-mini-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--vura-hairline-soft); font-size: 13px;">
                <span class="name" style="font-family: var(--font-display); color: var(--vura-cream);">Glycerin (vegetable)</span>
                <span class="percent" style="font-family: var(--font-mono); color: var(--vura-saffron);">1.80%</span>
              </div>
              <div class="form-mini-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--vura-hairline-soft); font-size: 13px;">
                <span class="name" style="font-family: var(--font-display); color: var(--vura-cream);">Kalium alum sulfas (Phitkari)</span>
                <span class="percent" style="font-family: var(--font-mono); color: var(--vura-saffron);">0.80%</span>
              </div>
              <div class="form-mini-row" style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--vura-hairline-soft); font-size: 13px;">
                <span class="name" style="font-family: var(--font-display); color: var(--vura-cream);">Preservative / pH Adjusters</span>
                <span class="percent" style="font-family: var(--font-mono); color: var(--vura-saffron);">0.70%</span>
              </div>
            </div>
            <div class="form-mini-foot" style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; color: var(--vura-cream-mute); text-transform: uppercase; letter-spacing: 0.1em; padding-top: 10px;">
              <span>pH 4.6 · Stable</span>
              <span>Tested @ 40°C</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</div>

<!-- JSON product data for variant switcher -->
<script type="application/json" id="ProductJson-{{ section.id }}">
  {{ product | json }}
</script>

<style>
/* =====================================================================
   UNIFIED HERO & SPECIFICATIONS LAYOUT
   ===================================================================== */
.vura-hero-explorer-wrapper {
  position: relative;
  width: 100%;
  background-color: var(--vura-forest);
}

.hero-section {
  padding: 100px 0 60px 0;
  background-color: transparent;
}

.hero-container {
  width: 100%;
}

.hero-main-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--s-16);
  align-items: center;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  gap: var(--s-5);
}

.hero-h1 {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(36px, 5.5vw, 64px);
  line-height: 0.98;
  letter-spacing: var(--track-tight);
  color: var(--vura-cream);
  margin: 0;
}
.hero-h1 em {
  font-style: normal;
  color: var(--vura-saffron);
  position: relative;
  white-space: nowrap;
  z-index: 1;
}
.hero-h1 em::after {
  content: "";
  position: absolute;
  left: -2%; right: -2%; bottom: 6%;
  height: 0.18em;
  background: var(--vura-terracotta);
  z-index: -1;
  transform: skew(-8deg, -2deg);
}

.hero-lede {
  font-family: var(--font-display);
  font-size: 18px;
  line-height: 1.55;
  color: var(--vura-cream-dim);
  max-width: 44ch;
  margin: 0;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--s-6);
  width: 100%;
  margin-top: var(--s-2);
  padding-top: var(--s-5);
  border-top: 1px solid var(--vura-hairline);
}
.stat .num {
  font-family: var(--font-display);
  font-size: 32px;
  line-height: 1;
  color: var(--vura-cream);
  display: block;
}
.stat .label {
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: var(--track-loose);
  color: var(--vura-cream-mute);
  margin-top: var(--s-1);
  display: block;
}
.stat .num em {
  color: var(--vura-saffron);
  font-style: normal;
  font-size: 20px;
}

.hero-trust-bar {
  border-top: 1px solid var(--vura-hairline-soft);
  padding-top: var(--s-6);
  width: 100%;
}
.trust-bar-wrapper {
  display: flex;
  justify-content: space-around;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--s-6);
}
.trust-item {
  display: flex;
  align-items: center;
  gap: var(--s-2);
  color: var(--vura-cream-mute);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: var(--track-mid);
  font-weight: 500;
}
.trust-item i {
  color: var(--vura-saffron);
  width: 15px;
  height: 15px;
  stroke-width: 1.5;
}

/* 3D Explorer Section (repurposed for Specifications) */
.vura-3d-section {
  padding: 100px 0;
}

.vura-3d-layout {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 60px;
  align-items: start;
}

.vura-layout-column {
  display: flex;
  flex-direction: column;
  gap: var(--s-8);
}

.specs-eyebrow, .ingredients-eyebrow, .intro-eyebrow {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--vura-saffron);
  text-transform: uppercase;
  letter-spacing: var(--track-loose);
  margin: 0 0 var(--s-2);
}
.specs-title {
  font-family: var(--font-display);
  font-size: clamp(32px, 3.5vw, 44px);
  line-height: 1.1;
  color: var(--vura-cream);
  margin: 0 0 var(--s-2);
}
.specs-desc, .ingredients-desc, .intro-desc {
  font-size: 13px;
  line-height: 1.6;
  color: var(--vura-cream-dim);
  margin: 0;
}

.formulation-mini-table {
  border-top: 1px solid var(--vura-hairline);
  margin: var(--s-4) 0;
  display: flex;
  flex-direction: column;
}
.form-mini-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--vura-hairline-soft);
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--vura-cream-dim);
}
.form-mini-row .name {
  font-family: var(--font-display);
  font-size: 14px;
  color: var(--vura-cream);
}
.form-mini-row .percent {
  color: var(--vura-saffron);
  font-weight: 500;
}
.form-mini-foot {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--vura-cream-mute);
  display: flex;
  justify-content: space-between;
  text-transform: uppercase;
  letter-spacing: var(--track-mid);
}

/* Variant Swatches Styling */
.pdp-swatch-input:checked + .variant-swatch {
  background: var(--vura-saffron);
  color: var(--vura-forest-deep);
  border-color: var(--vura-saffron);
  font-weight: 600;
