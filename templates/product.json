        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Does it contain aluminium chlorohydrate?",
            "answer": "<p>No. We use potassium alum, which you may know as Phitkari. It is a natural mineral salt and it is not the same as the aluminium compounds in conventional antiperspirants.</p>"
