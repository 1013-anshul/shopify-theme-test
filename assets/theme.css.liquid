/* Reset & Global Styles */
*, *::before, *::after {
  box-sizing: border-box;
}

body, h1, h2, h3, h4, h5, p, figure, blockquote, dl, dd {
  margin: 0;
}

body {
  min-height: 100vh;
  scroll-behavior: smooth;
  text-rendering: optimizeSpeed;
  line-height: 1.5;
  font-family: var(--font-body);
  background-color: var(--color-bg);
  color: var(--color-text);
  overflow-x: hidden;
}

a {
  color: inherit;
  text-decoration: none;
  transition: color 0.2s ease;
}

button, input, select, textarea {
  font: inherit;
  background: transparent;
  border: none;
  color: inherit;
}

button {
  cursor: pointer;
}

/* Scrollbar Styling */
::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-track {
  background: var(--color-bg);
}
::-webkit-scrollbar-thumb {
  background: var(--color-border);
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--color-primary);
}

/* Containers & Grid */
.container {
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 1.5rem;
}

.grid {
  display: grid;
  gap: 2rem;
}
.grid-2 {
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
}
.grid-3 {
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
}
.grid-4 {
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}

.flex {
  display: flex;
}
.flex-between {
  justify-content: space-between;
  align-items: center;
}
.flex-center {
  justify-content: center;
  align-items: center;
}

/* Typography */
h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.02em;
}

h1 { font-size: 2.5rem; }
h2 { font-size: 2rem; }
h3 { font-size: 1.5rem; }

.text-muted {
  color: var(--color-text-muted);
}
.text-center {
  text-align: center;
}

/* Glassmorphism Styles */
.glass-card {
  background: rgba(24, 24, 27, 0.65);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--color-border);
  box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.4);
  border-radius: 12px;
  overflow: hidden;
  transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}

.glass-card:hover {
  border-color: rgba(99, 102, 241, 0.4);
  box-shadow: 0 12px 40px 0 rgba(99, 102, 241, 0.15);
}

.glass-navbar {
  background: rgba(9, 9, 11, 0.8);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
}

/* Buttons */
.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.8rem 1.8rem;
  font-size: 0.95rem;
  font-weight: 600;
  border-radius: 8px;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  text-align: center;
}

.button-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #ffffff;
  box-shadow: 0 4px 14px rgba(99, 102, 241, 0.3);
}

.button-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
  filter: brightness(1.1);
}

.button-secondary {
  border: 1px solid var(--color-border);
  background: rgba(255, 255, 255, 0.05);
  color: var(--color-text);
}

.button-secondary:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: var(--color-primary);
  transform: translateY(-2px);
}

.button-full-width {
  display: flex;
  width: 100%;
}

.button-disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: none !important;
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  border: 0;
}

/* Announcement Bar */
.announcement-bar {
  background: linear-gradient(90deg, #6366f1, #14b8a6);
  color: #ffffff;
  text-align: center;
  padding: 0.5rem 1rem;
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

/* Header & Navigation */
.header-wrapper {
  position: sticky;
  top: 0;
  z-index: 100;
}

.header {
  padding: 1.2rem 0;
}

.logo-link {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  background: linear-gradient(135deg, #6366f1, #14b8a6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
  padding: 0;
}

.nav-link {
  font-weight: 500;
  font-size: 0.95rem;
  color: var(--color-text-muted);
}

.nav-link:hover, .nav-link.active {
  color: var(--color-text);
}

.header-icons {
  display: flex;
  gap: 1.2rem;
  align-items: center;
}

.header-icon {
  position: relative;
  color: var(--color-text-muted);
  transition: color 0.2s ease;
}

.header-icon:hover {
  color: var(--color-text);
}

.cart-count-badge {
  position: absolute;
  top: -6px;
  right: -8px;
  background: var(--color-primary);
  color: white;
  font-size: 0.7rem;
  font-weight: 700;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Hero Section */
.hero-section {
  position: relative;
  padding: 8rem 0;
  overflow: hidden;
  background: radial-gradient(circle at 80% 20%, rgba(99, 102, 241, 0.15), transparent 45%),
              radial-gradient(circle at 10% 80%, rgba(20, 184, 166, 0.12), transparent 40%);
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 4rem;
}

@media (max-width: 768px) {
  .hero-grid {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 2rem;
  }
}

.hero-subtitle {
  color: var(--color-accent);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 1rem;
  display: block;
}

.hero-title {
  font-size: 3.5rem;
  margin-bottom: 1.5rem;
}

.hero-text {
  font-size: 1.1rem;
  margin-bottom: 2rem;
}

.hero-buttons {
  display: flex;
  gap: 1rem;
}

@media (max-width: 768px) {
  .hero-buttons {
    justify-content: center;
  }
}

.hero-image-wrapper {
  position: relative;
}

.hero-image-glow {
  position: absolute;
  inset: -10px;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  filter: blur(24px);
  opacity: 0.35;
  border-radius: 20px;
  z-index: 1;
}

.hero-img {
  width: 100%;
  height: auto;
  border-radius: 16px;
  position: relative;
  z-index: 2;
  border: 1px solid var(--color-border);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
}

/* Product Cards */
.product-card {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.product-card-image-wrapper {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
}

.product-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.product-card:hover .product-card-img {
  transform: scale(1.08);
}

.product-card-badges {
  position: absolute;
  top: 12px;
  left: 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  z-index: 10;
}

.badge {
  padding: 0.25rem 0.6rem;
  font-size: 0.75rem;
  font-weight: 700;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.badge-sale {
  background-color: #ef4444;
  color: white;
}

.badge-sold-out {
  background-color: var(--color-border);
  color: var(--color-text-muted);
}

.product-card-info {
  padding: 1.2rem;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}

.product-card-vendor {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.4rem;
}

.product-card-title {
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
  font-family: var(--font-body);
}

.product-card-price-wrapper {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  font-size: 1.05rem;
  font-weight: 600;
  margin-top: auto;
}

.price-regular {
  color: var(--color-text);
}

.price-compare {
  text-decoration: line-through;
  color: var(--color-text-muted);
  font-size: 0.9rem;
}

.price-sale {
  color: #ef4444;
}

/* AJAX Cart Drawer Container */
.cart-drawer-container {
  position: fixed;
  inset: 0;
  z-index: 999;
  visibility: hidden;
  transition: visibility 0.3s ease;
}

.cart-drawer-container.active {
  visibility: visible;
}

.cart-drawer-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.cart-drawer-container.active .cart-drawer-overlay {
  opacity: 1;
}

.cart-drawer-content {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  max-width: 440px;
  border-radius: 0;
  border-left: 1px solid var(--color-border);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.cart-drawer-container.active .cart-drawer-content {
  transform: translateX(0);
}

.cart-drawer-header {
  padding: 1.5rem;
  border-bottom: 1px solid var(--color-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-drawer-title {
  font-size: 1.4rem;
}

.cart-drawer-close {
  color: var(--color-text-muted);
  transition: color 0.2s ease;
}

.cart-drawer-close:hover {
  color: var(--color-text);
}

.cart-drawer-items-wrapper {
  flex-grow: 1;
  overflow-y: auto;
  padding: 1.5rem;
}

.cart-drawer-empty {
  text-align: center;
  padding: 3rem 0;
}

.cart-drawer-empty-text {
  font-size: 1.1rem;
  color: var(--color-text-muted);
  margin-bottom: 1.5rem;
}

.cart-drawer-item {
  display: flex;
  gap: 1rem;
  padding-bottom: 1.5rem;
  margin-bottom: 1.5rem;
  border-bottom: 1px solid var(--color-border);
}

.cart-drawer-item-img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 8px;
  border: 1px solid var(--color-border);
}

.cart-drawer-item-details {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}

.cart-drawer-item-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.cart-drawer-item-variant {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  margin-bottom: 0.5rem;
}

.cart-drawer-item-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.quantity-selector {
  display: flex;
  align-items: center;
  border: 1px solid var(--color-border);
  border-radius: 6px;
  overflow: hidden;
}

.quantity-btn {
  padding: 0.3rem 0.6rem;
  font-weight: bold;
}

.quantity-input {
  width: 32px;
  text-align: center;
  font-size: 0.9rem;
}

.cart-drawer-item-remove {
  font-size: 0.8rem;
  color: #ef4444;
  text-decoration: underline;
}

.cart-drawer-footer {
  padding: 1.5rem;
  border-top: 1px solid var(--color-border);
  background: rgba(9, 9, 11, 0.5);
}

.cart-drawer-summary {
  display: flex;
  justify-content: space-between;
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
}

.cart-drawer-view-link {
  display: block;
  text-align: center;
  font-size: 0.9rem;
  color: var(--color-text-muted);
  margin-top: 1rem;
  text-decoration: underline;
}

/* Product Detail Page Layout */
.product-detail-wrapper {
  padding: 4rem 0;
}

.product-detail-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 4rem;
}

@media (max-width: 991px) {
  .product-detail-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
}

.product-gallery {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.product-main-image-wrapper {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--color-border);
  background: rgba(255, 255, 255, 0.02);
}

.product-main-image {
  width: 100%;
  aspect-ratio: 1;
  object-fit: contain;
}

.product-thumbnails {
  display: flex;
  gap: 0.8rem;
  overflow-x: auto;
}

.product-thumbnail {
  width: 80px;
  aspect-ratio: 1;
  border-radius: 6px;
  border: 1px solid var(--color-border);
  cursor: pointer;
  overflow: hidden;
  opacity: 0.6;
  transition: opacity 0.2s, border-color 0.2s;
}

.product-thumbnail.active, .product-thumbnail:hover {
  opacity: 1;
  border-color: var(--color-primary);
}

.product-info-column {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.product-title {
  font-size: 2.2rem;
}

.product-price-container {
  font-size: 1.5rem;
  font-weight: 700;
}

.product-variants-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.option-group-title {
  font-size: 0.85rem;
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: var(--color-text-muted);
}

.option-swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.4rem;
}

.swatch-label {
  border: 1px solid var(--color-border);
  padding: 0.5rem 1rem;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.9rem;
  font-weight: 500;
  transition: border-color 0.2s, background-color 0.2s;
}

.swatch-input {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  border: 0;
}

.swatch-input:checked + .swatch-label {
  border-color: var(--color-primary);
  background-color: rgba(99, 102, 241, 0.1);
  color: white;
}

.swatch-input:focus + .swatch-label {
  box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.3);
}

/* Accordion Accordions */
.accordion {
  border-top: 1px solid var(--color-border);
  margin-top: 2rem;
}

.accordion-item {
  border-bottom: 1px solid var(--color-border);
}

.accordion-title {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 0;
  font-weight: 600;
  font-size: 1.05rem;
}

.accordion-content {
  padding-bottom: 1rem;
  font-size: 0.95rem;
  color: var(--color-text-muted);
  display: none;
}

.accordion-item.active .accordion-content {
  display: block;
}

.accordion-item.active .accordion-icon {
  transform: rotate(180deg);
}

.accordion-icon {
  transition: transform 0.2s ease;
}

/* Footer Section */
.footer {
  border-top: 1px solid var(--color-border);
  padding: 4rem 0 2rem;
  margin-top: 5rem;
  background: rgba(9, 9, 11, 0.5);
}

.footer-columns {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
  gap: 3rem;
  margin-bottom: 3rem;
}

@media (max-width: 991px) {
  .footer-columns {
    grid-template-columns: 1fr 1fr;
  }
}
@media (max-width: 576px) {
  .footer-columns {
    grid-template-columns: 1fr;
  }
}

.footer-heading {
  font-size: 1.1rem;
  margin-bottom: 1.2rem;
  color: var(--color-text);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.footer-links {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.footer-link {
  color: var(--color-text-muted);
  font-size: 0.95rem;
}

.footer-link:hover {
  color: var(--color-primary);
}

.footer-newsletter-form {
  display: flex;
  margin-top: 1rem;
  gap: 0.5rem;
}

.footer-newsletter-input {
  flex-grow: 1;
  border: 1px solid var(--color-border);
  border-radius: 6px;
  padding: 0.6rem 1rem;
  font-size: 0.9rem;
  background: rgba(255, 255, 255, 0.02);
}

.footer-newsletter-input:focus {
  border-color: var(--color-primary);
  outline: none;
}

.footer-bottom {
  border-top: 1px solid var(--color-border);
  padding-top: 2rem;
  font-size: 0.85rem;
  color: var(--color-text-muted);
}
